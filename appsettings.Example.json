{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=YOUR_HOST;Port=YOUR_PORT;Database=YOUR_DB;Username=YOUR_USER;Password=YOUR_PASSWORD;SSL Mode=Prefer;Trust Server Certificate=true"
  },
  "OpenRouteService": {
    "ApiKey": "YOUR_OPEN_ROUTE_SERVICE_API_KEY"
  },
  "OpenAI": {
    "ApiKey": "YOUR_OPEN_AI_API_KEY"
  },
  "AllowedHosts": "*"
}
