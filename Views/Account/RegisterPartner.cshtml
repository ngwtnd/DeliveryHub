@model dynamic
@{
    ViewData["Title"] = "Đăng ký Đối tác";
}

<section class="min-h-screen flex items-center justify-center pt-24 pb-12 px-6">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-brand-orange/10 rounded-full blur-[120px] pointer-events-none"></div>

    <div class="relative w-full max-w-2xl">
        <div class="bg-brand-dark/80 backdrop-blur-xl border border-white/10 rounded-[2.5rem] p-8 md:p-10 shadow-2xl overflow-hidden">
            <div class="text-center mb-8">
                <h2 class="text-3xl font-extrabold text-white mb-2">Đăng ký <span class="text-brand-orange">Đối Tác</span></h2>
                <p class="text-brand-gray">Cùng Delivery Hub mở rộng kinh doanh của bạn</p>
                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="mt-4 text-xs font-bold text-red-500 bg-red-500/10 p-3 rounded-xl border border-red-500/20"></div>
                }
            </div>

            <form asp-controller="Account" asp-action="RegisterPartner" method="post" enctype="multipart/form-data" class="flex flex-col gap-6">
                <!-- Thông tin cơ bản -->
                <div class="bg-white/[0.02] p-6 rounded-3xl border border-white/5 space-y-4">
                    <h3 class="text-sm font-black text-brand-orange uppercase tracking-widest border-b border-white/10 pb-2">Thông tin chủ cửa hàng</h3>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="flex flex-col gap-2">
                            <label class="text-xs font-bold text-brand-gray uppercase tracking-wider ml-1">Họ và tên</label>
                            <input type="text" name="fullName" class="w-full bg-black/50 border border-white/10 text-white py-3 px-4 rounded-xl focus:outline-none focus:border-brand-orange transition-all placeholder:text-gray-600" required>
                        </div>
                        <div class="flex flex-col gap-2">
                            <label class="text-xs font-bold text-brand-gray uppercase tracking-wider ml-1">Số điện thoại</label>
                            <input type="text" name="phoneNumber" class="w-full bg-black/50 border border-white/10 text-white py-3 px-4 rounded-xl focus:outline-none focus:border-brand-orange transition-all placeholder:text-gray-600" required>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div class="flex flex-col gap-2">
                            <label class="text-xs font-bold text-brand-gray uppercase tracking-wider ml-1">Email</label>
                            <input type="email" name="email" class="w-full bg-black/50 border border-white/10 text-white py-3 px-4 rounded-xl focus:outline-none focus:border-brand-orange transition-all placeholder:text-gray-600" required>
                        </div>
                        <div class="flex flex-col gap-2">
                            <label class="text-xs font-bold text-brand-gray uppercase tracking-wider ml-1">Mật khẩu</label>
                            <input type="password" name="password" class="w-full bg-black/50 border border-white/10 text-white py-3 px-4 rounded-xl focus:outline-none focus:border-brand-orange transition-all placeholder:text-gray-600" required>
                        </div>
                    </div>

                    <div class="flex flex-col gap-2 mt-2">
                        <label class="text-xs font-bold text-brand-gray uppercase tracking-wider ml-1">Ảnh Đại Diện (Chân dung)</label>
                        <input type="file" name="ownerAvatar" accept="image/*" class="w-full text-white file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:bg-brand-orange file:text-black file:font-bold hover:file:bg-white transition-all text-xs" required>
                    </div>
                </div>

                <!-- Thông tin cửa hàng -->
                <div class="bg-white/[0.02] p-6 rounded-3xl border border-white/5 space-y-4">
                    <h3 class="text-sm font-black text-brand-orange uppercase tracking-widest border-b border-white/10 pb-2">Thông tin đăng ký chi nhánh chính</h3>
                    
                    <div class="flex flex-col gap-2">
                        <label class="text-xs font-bold text-brand-gray uppercase tracking-wider ml-1">Tên cửa hàng (Chi nhánh)</label>
                        <input type="text" name="storeName" placeholder="VD: Bún Đậu Mắm Tôm Phố Cổ" class="w-full bg-black/50 border border-white/10 text-white py-3 px-4 rounded-xl focus:outline-none focus:border-brand-orange transition-all placeholder:text-gray-600" required>
                    </div>
                    
                    <div class="flex flex-col gap-2">
                        <label class="text-xs font-bold text-brand-gray uppercase tracking-wider ml-1">Địa chỉ cửa hàng</label>
                        <input type="text" name="storeAddress" placeholder="Sẽ thiết lập tọa độ sau trên hệ thống. Chỉ nhập số nhà, phường, quận..." class="w-full bg-black/50 border border-white/10 text-white py-3 px-4 rounded-xl focus:outline-none focus:border-brand-orange transition-all placeholder:text-gray-600" required>
                    </div>

                    <div class="flex flex-col gap-2 mt-2">
                        <label class="text-xs font-bold text-brand-gray uppercase tracking-wider ml-1">Ảnh Mặt tiền cửa hàng / Ảnh thương hiệu</label>
                        <input type="file" name="shopAvatar" accept="image/*" class="w-full text-white file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:bg-brand-orange file:text-black file:font-bold hover:file:bg-white transition-all text-xs" required>
                    </div>
                </div>

                <button type="submit" class="w-full bg-brand-orange text-black font-extrabold py-4 rounded-2xl text-lg hover:shadow-[0_0_20px_rgba(255,107,0,0.4)] hover:scale-[1.02] active:scale-[0.98] transition-all mt-4">
                    Gửi Hồ Sơ Đăng Ký Đối Tác
                </button>

                <div class="text-center mt-2">
                    <a href="@Url.Action("Login", "Account")" class="text-xs text-brand-gray hover:text-white transition-colors">Quay lại đăng nhập</a>
                </div>
            </form>
        </div>
    </div>
</section>
