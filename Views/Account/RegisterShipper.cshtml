@model dynamic
@{
    ViewData["Title"] = "Đăng ký Shipper";
}

<section class="min-h-screen flex items-center justify-center pt-24 pb-12 px-6">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-brand-orange/10 rounded-full blur-[120px] pointer-events-none"></div>

    <div class="relative w-full max-w-2xl">
        <div class="bg-brand-dark/80 backdrop-blur-xl border border-white/10 rounded-[2.5rem] p-8 md:p-10 shadow-2xl overflow-hidden">
            <div class="text-center mb-8">
                <h2 class="text-3xl font-extrabold text-white mb-2">Đăng ký <span class="text-brand-orange">Shipper</span></h2>
                <p class="text-brand-gray">Điền thông tin và tải lên hồ sơ của bạn</p>
                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="All" class="mt-4 text-xs font-bold text-red-500 bg-red-500/10 p-3 rounded-xl border border-red-500/20"></div>
                }
            </div>

            <form asp-controller="Account" asp-action="RegisterShipper" method="post" enctype="multipart/form-data" class="flex flex-col gap-6">
                <!-- Row 1: Name & Email -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="flex flex-col gap-2">
                        <label class="text-sm font-bold text-brand-gray uppercase tracking-wider ml-1">Họ và tên</label>
                        <input type="text" name="fullName" class="w-full bg-black/50 border border-white/10 text-white py-4 px-4 rounded-2xl focus:outline-none focus:border-brand-orange transition-all placeholder:text-gray-600" required>
                    </div>
                    <div class="flex flex-col gap-2">
                        <label class="text-sm font-bold text-brand-gray uppercase tracking-wider ml-1">Email</label>
                        <input type="email" name="email" class="w-full bg-black/50 border border-white/10 text-white py-4 px-4 rounded-2xl focus:outline-none focus:border-brand-orange transition-all placeholder:text-gray-600" required>
                    </div>
                </div>

                <!-- Row 2: Phone & Password -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="flex flex-col gap-2">
                        <label class="text-sm font-bold text-brand-gray uppercase tracking-wider ml-1">Số điện thoại</label>
                        <input type="text" name="phoneNumber" class="w-full bg-black/50 border border-white/10 text-white py-4 px-4 rounded-2xl focus:outline-none focus:border-brand-orange transition-all placeholder:text-gray-600" required>
                    </div>
                    <div class="flex flex-col gap-2">
                        <label class="text-sm font-bold text-brand-gray uppercase tracking-wider ml-1">Mật khẩu</label>
                        <input type="password" name="password" class="w-full bg-black/50 border border-white/10 text-white py-4 px-4 rounded-2xl focus:outline-none focus:border-brand-orange transition-all placeholder:text-gray-600" required>
                    </div>
                </div>

                <!-- Row 3: Vehicle -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="flex flex-col gap-2">
                        <label class="text-sm font-bold text-brand-gray uppercase tracking-wider ml-1">Loại xe</label>
                        <select name="vehicleType" class="w-full bg-black/50 border border-white/10 text-white py-4 px-4 rounded-2xl focus:outline-none focus:border-brand-orange transition-all" required>
                            <option value="Xe máy">Xe máy</option>
                            <option value="Xe tải">Xe tải</option>
                        </select>
                    </div>
                    <div class="flex flex-col gap-2">
                        <label class="text-sm font-bold text-brand-gray uppercase tracking-wider ml-1">Tên & Biển số xe</label>
                        <input type="text" name="vehicle" placeholder="VD: Yamaha Exciter (59A2-56789)" class="w-full bg-black/50 border border-white/10 text-white py-4 px-4 rounded-2xl focus:outline-none focus:border-brand-orange transition-all placeholder:text-gray-600" required>
                    </div>
                </div>

                <!-- Row 4: CCCD -->
                <div class="flex flex-col gap-2">
                    <label class="text-sm font-bold text-brand-gray uppercase tracking-wider ml-1">Số CCCD / CMND</label>
                    <input type="text" name="citizenId" class="w-full bg-black/50 border border-white/10 text-white py-4 px-4 rounded-2xl focus:outline-none focus:border-brand-orange transition-all placeholder:text-gray-600" required>
                </div>

                <!-- File Uploads -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="flex flex-col gap-2">
                        <label class="text-xs font-bold text-brand-gray uppercase tracking-wider ml-1">Ảnh CCCD Mặt Trước</label>
                        <input type="file" name="citizenIdFront" accept="image/*" class="w-full text-white file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:bg-brand-orange file:text-black file:font-bold hover:file:bg-white transition-all text-xs" required>
                    </div>
                    <div class="flex flex-col gap-2">
                        <label class="text-xs font-bold text-brand-gray uppercase tracking-wider ml-1">Ảnh CCCD Mặt Sau</label>
                        <input type="file" name="citizenIdBack" accept="image/*" class="w-full text-white file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:bg-brand-orange file:text-black file:font-bold hover:file:bg-white transition-all text-xs" required>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="flex flex-col gap-2">
                        <label class="text-xs font-bold text-brand-gray uppercase tracking-wider ml-1">Ảnh Bằng Lái Xe</label>
                        <input type="file" name="driverLicense" accept="image/*" class="w-full text-white file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:bg-brand-orange file:text-black file:font-bold hover:file:bg-white transition-all text-xs" required>
                    </div>
                    <div class="flex flex-col gap-2">
                        <label class="text-xs font-bold text-brand-gray uppercase tracking-wider ml-1">Ảnh Đại Diện (Chân dung)</label>
                        <input type="file" name="avatarFile" accept="image/*" class="w-full text-white file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:bg-brand-orange file:text-black file:font-bold hover:file:bg-white transition-all text-xs" required>
                    </div>
                </div>

                <button type="submit" class="w-full bg-brand-orange text-black font-extrabold py-4 rounded-2xl text-lg hover:shadow-[0_0_20px_rgba(255,107,0,0.4)] hover:scale-[1.02] active:scale-[0.98] transition-all mt-4">
                    Đăng Ký Trở Thành Shipper
                </button>
                
                <div class="text-center mt-2">
                    <a href="@Url.Action("Login", "Account")" class="text-xs text-brand-gray hover:text-white transition-colors">Quay lại đăng nhập</a>
                </div>
            </form>
        </div>
    </div>
</section>
