@{
    Layout = "~/Views/Shared/_ShipperLayout.cshtml";
    ViewData["Title"] = "Ví tiền";
    var user = ViewBag.ShipperUser as ApplicationUser;
    decimal totalIncome = ViewBag.TotalIncome ?? 0m;
    var incomeOrders = ViewBag.IncomeOrders as List<Order> ?? new List<Order>();
    decimal balance = user?.Balance ?? 0m;
}

<div class="max-w-4xl mx-auto space-y-6">
    <!-- Balance Card -->
    <div style="background:linear-gradient(135deg,#c2410c,#f97316,#fb923c); padding:2.5rem; border-radius:2rem; position:relative; overflow:hidden; box-shadow:0 20px 60px rgba(249,115,22,0.35);">
        <div style="position:absolute;top:-4rem;right:-4rem;width:16rem;height:16rem;background:rgba(255,255,255,0.08);border-radius:50%;filter:blur(3rem);"></div>
        <div style="position:absolute;bottom:-3rem;left:-3rem;width:12rem;height:12rem;background:rgba(0,0,0,0.15);border-radius:50%;filter:blur(2rem);"></div>
        <div style="position:relative; display:flex; flex-wrap:wrap; justify-content:space-between; align-items:center; gap:1.5rem;">
            <div>
                <div style="display:flex; align-items:center; gap:0.5rem; margin-bottom:0.75rem;">
                    <div style="width:2.25rem; height:2.25rem; border-radius:50%; background:rgba(255,255,255,0.2); display:flex; align-items:center; justify-content:center;">
                        <i class="fa-solid fa-wallet" style="color:white; font-size:0.9rem;"></i>
                    </div>
                    <span style="color:rgba(255,255,255,0.8); font-size:0.7rem; font-weight:800; text-transform:uppercase; letter-spacing:0.12em;">Số dư khả dụng</span>
                </div>
                <h2 style="font-size:3rem; font-weight:900; color:white; margin:0 0 0.5rem; line-height:1;">
                    @string.Format("{0:N0}", balance)<span style="font-size:1.2rem; color:rgba(255,255,255,0.7); margin-left:0.5rem;">VND</span>
                </h2>
                <p style="color:rgba(255,255,255,0.75); font-size:0.75rem; font-weight:600; margin:0;">
                    <i class="fa-solid fa-info-circle" style="margin-right:4px;"></i>Tổng thu nhập đã giao: <strong>@string.Format("{0:N0}", totalIncome) VND</strong>
                </p>
            </div>
            <div style="display:flex; flex-direction:column; gap:0.6rem;">
                <button style="padding:0.875rem 1.75rem; background:white; color:#c2410c; font-weight:900; border:none; border-radius:0.875rem; cursor:pointer; font-size:0.85rem; box-shadow:0 4px 15px rgba(0,0,0,0.2); transition:all 0.2s;" onmouseover="this.style.transform='translateY(-2px)'" onmouseout="this.style.transform='translateY(0)'">
                    <i class="fa-solid fa-building-columns" style="margin-right:0.5rem;"></i>Rút tiền
                </button>
            </div>
        </div>
    </div>

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:1.25rem;">
        <!-- Bank Info -->
        <div style="background:#0f172a; border:1px solid rgba(255,255,255,0.07); padding:1.75rem; border-radius:1.5rem;">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.25rem;">
                <h3 style="font-size:1rem; font-weight:900; color:white; margin:0;">
                    <i class="fa-solid fa-university" style="color:#f97316; margin-right:0.5rem;"></i>Thông tin shipper
                </h3>
            </div>
            <div style="display:flex; flex-direction:column; gap:0.75rem;">
                <div style="display:flex; align-items:center; gap:0.75rem; padding:1rem; background:#020617; border:1px solid rgba(255,255,255,0.06); border-radius:0.875rem;">
                    <div style="width:3rem; height:3rem; background:rgba(249,115,22,0.15); border-radius:0.75rem; display:flex; align-items:center; justify-content:center; border:1px solid rgba(249,115,22,0.25);">
                        <i class="fa-solid fa-motorcycle" style="color:#f97316;"></i>
                    </div>
                    <div>
                        <p style="color:white; font-weight:800; margin:0; font-size:0.9rem;">@(user?.FullName ?? "Shipper")</p>
                        <p style="color:#f97316; font-weight:700; font-size:0.7rem; margin:0;">@(user?.ShipperCode ?? "SH-0000")</p>
                    </div>
                </div>
                <div style="padding:1rem; background:#020617; border:1px solid rgba(255,255,255,0.06); border-radius:0.875rem;">
                    <p style="color:#64748b; font-size:0.65rem; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; margin:0 0 0.3rem;">Email</p>
                    <p style="color:white; font-weight:700; font-size:0.85rem; margin:0;">@(user?.Email ?? "—")</p>
                </div>
            </div>
        </div>

        <!-- Recent Transactions -->
        <div style="background:#0f172a; border:1px solid rgba(255,255,255,0.07); padding:1.75rem; border-radius:1.5rem;">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.25rem;">
                <h3 style="font-size:1rem; font-weight:900; color:white; margin:0;">
                    <i class="fa-solid fa-arrow-right-arrow-left" style="color:#f97316; margin-right:0.5rem;"></i>Giao dịch gần đây
                </h3>
                <a href="/Shipper/History" style="color:#94a3b8; font-size:0.75rem; font-weight:700; text-decoration:none;">Xem tất cả</a>
            </div>

            @if (!incomeOrders.Any())
            {
                <div style="display:flex; flex-direction:column; align-items:center; justify-content:center; padding:2rem; text-align:center; color:#334155;">
                    <i class="fa-solid fa-receipt" style="font-size:2rem; margin-bottom:0.75rem;"></i>
                    <p style="font-size:0.8rem; color:#64748b; margin:0;">Chưa có giao dịch nào</p>
                </div>
            }
            else
            {
                <div style="display:flex; flex-direction:column; gap:0.6rem; max-height:260px; overflow-y:auto; scrollbar-width:thin;">
                    @foreach (var order in incomeOrders)
                    {
                        <div style="display:flex; align-items:center; justify-content:space-between; padding:0.875rem; background:#020617; border:1px solid rgba(255,255,255,0.06); border-radius:0.875rem; transition:border-color 0.2s;" onmouseover="this.style.borderColor='rgba(255,255,255,0.12)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.06)'">
                            <div style="display:flex; align-items:center; gap:0.75rem;">
                                <div style="width:2.25rem; height:2.25rem; border-radius:50%; background:rgba(34,197,94,0.15); border:1px solid rgba(34,197,94,0.25); display:flex; align-items:center; justify-content:center; color:#4ade80; font-size:0.75rem;">
                                    <i class="fa-solid fa-arrow-down"></i>
                                </div>
                                <div>
                                    <p style="color:white; font-weight:700; font-size:0.8rem; margin:0;">@order.OrderCode</p>
                                    <p style="color:#64748b; font-size:0.65rem; margin:0;">@(order.CompletedAt?.ToString("HH:mm dd/MM") ?? order.CreatedAt.ToString("HH:mm dd/MM"))</p>
                                </div>
                            </div>
                            <span style="color:#22c55e; font-weight:900; font-size:0.9rem;">+@string.Format("{0:N0}", order.ShipperIncome)₫</span>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
