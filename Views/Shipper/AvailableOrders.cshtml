@model IEnumerable<Order>
@{
    Layout = "~/Views/Shared/_ShipperLayout.cshtml";
    ViewData["Title"] = "Đơn mới";
    var shipperUser = ViewBag.ShipperUser as ApplicationUser;
    bool isOnline = (bool)(ViewBag.IsOnline ?? false);
    bool hasActiveOrder = (bool)(ViewBag.HasActiveOrder ?? false);
}

<style>
    /* Override layout padding for full-height map */
    .available-orders-page { margin: -2rem; height: calc(100vh - 80px); display: flex; overflow: hidden; }
    .map-panel { flex: 1; min-width: 0; position: relative; }
    .orders-panel { width: 420px; flex-shrink: 0; background: #0f172a; border-left: 1px solid rgba(255,255,255,0.06); display: flex; flex-direction: column; overflow: hidden; }
    .orders-scroll { flex: 1; overflow-y: auto; padding: 1.25rem; scrollbar-width: thin; }
    .order-card { background: #020617; border: 1px solid rgba(255,255,255,0.07); border-radius: 1.25rem; padding: 1.25rem; margin-bottom: 1rem; cursor: pointer; transition: border-color 0.2s, box-shadow 0.2s; }
    .order-card:hover { border-color: rgba(249,115,22,0.5); box-shadow: 0 0 20px rgba(249,115,22,0.08); }
    .order-card.active { border-color: #f97316; box-shadow: 0 0 25px rgba(249,115,22,0.2); }
    .order-card.accepted { border-color: #22c55e; box-shadow: 0 0 25px rgba(34,197,94,0.2); background: rgba(34,197,94,0.03); }
    .order-card.delivering { border-color: #3b82f6; box-shadow: 0 0 25px rgba(59,130,246,0.2); background: rgba(59,130,246,0.03); }
    #availableMap { width: 100%; height: 100%; }
    .map-overlay-badge { position: absolute; top: 1rem; right: 1rem; z-index: 800; background: rgba(2,6,23,0.9); backdrop-filter: blur(8px); border: 1px solid rgba(249,115,22,0.3); border-radius: 0.75rem; padding: 0.6rem 1rem; display: flex; align-items: center; gap: 0.5rem; }
    .pulse-dot { width: 10px; height: 10px; border-radius: 50%; background: #f97316; animation: pulseDot 1.5s infinite; }
    @@keyframes pulseDot { 0%,100% { box-shadow: 0 0 0 0 rgba(249,115,22,0.5); } 50% { box-shadow: 0 0 0 8px rgba(249,115,22,0); } }
    .route-line { display: flex; flex-direction: column; align-items: center; margin-right: 0.75rem; }
    .dot-orange { width: 10px; height: 10px; border-radius: 50%; background: #f97316; border: 2px solid rgba(249,115,22,0.3); flex-shrink: 0; }
    .dot-blue   { width: 10px; height: 10px; border-radius: 50%; background: #3b82f6; border: 2px solid rgba(59,130,246,0.3); flex-shrink: 0; }
    .route-seg  { width: 2px; flex: 1; min-height: 18px; background: linear-gradient(to bottom, #f97316, #3b82f6); opacity: 0.4; }

    /* Route info floating panel */
    .route-info-floating { position: absolute; bottom: 1.5rem; left: 1.5rem; right: 1.5rem; z-index: 800; background: rgba(2,6,23,0.95); backdrop-filter: blur(12px); border: 1px solid rgba(249,115,22,0.3); border-radius: 1.25rem; padding: 1.25rem 1.5rem; display: none; }
    .route-info-floating.visible { display: block; animation: slideUp 0.4s cubic-bezier(0.175,0.885,0.32,1.275); }
    @@keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

    .stat-pill { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08); border-radius: 0.75rem; padding: 0.6rem 0.75rem; text-align: center; flex: 1; }

    /* Animated route line */
    .animated-route { stroke-dasharray: 12 6; animation: routeFlow 1.5s linear infinite; }
    @@keyframes routeFlow { to { stroke-dashoffset: -18; } }

    /* Phase badges */
    .phase-badge { display: inline-flex; align-items: center; gap: 0.3rem; padding: 0.25rem 0.6rem; border-radius: 999px; font-size: 0.6rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.08em; }
    .phase-pickup { background: rgba(249,115,22,0.15); border: 1px solid rgba(249,115,22,0.3); color: #f97316; }
    .phase-deliver { background: rgba(59,130,246,0.15); border: 1px solid rgba(59,130,246,0.3); color: #3b82f6; }
    .phase-done { background: rgba(34,197,94,0.15); border: 1px solid rgba(34,197,94,0.3); color: #22c55e; }
</style>

<div class="available-orders-page">

    <!-- ===== MAP PANEL ===== -->
    <div class="map-panel">
        <div id="availableMap"></div>

        <!-- Floating status badge -->
        <div class="map-overlay-badge">
            <div class="@(isOnline ? "pulse-dot" : "")" style="@(!isOnline ? "width:10px;height:10px;border-radius:50%;background:#ef4444;" : "")"></div>
            <span style="font-size:0.7rem; font-weight:800; color:@(isOnline?"#f97316":"#ef4444"); text-transform:uppercase; letter-spacing:0.1em;">@(isOnline ? "Trực tuyến" : "Ngoại tuyến")</span>
            <span style="font-size:0.7rem; color:#64748b; font-weight:600;">| @(isOnline ? "Bán kính 5km" : "Chưa khả dụng")</span>
        </div>

        <!-- Route info floating panel -->
        <div class="route-info-floating" id="routeInfoPanel">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.75rem;">
                <div style="display:flex; align-items:center; gap:0.5rem;">
                    <div style="width:2rem; height:2rem; border-radius:0.6rem; display:flex; align-items:center; justify-content:center;" id="routeIconBox">
                        <i class="fa-solid fa-route" id="routeIcon"></i>
                    </div>
                    <div>
                        <h3 style="font-size:0.9rem; font-weight:900; color:white; margin:0;" id="routeTitle">Đường đến quán</h3>
                        <p style="font-size:0.55rem; color:#64748b; font-weight:600; margin:0;" id="routeSubtitle">Quãng đường lấy hàng</p>
                    </div>
                </div>
                <span class="phase-badge phase-pickup" id="routePhaseBadge">
                    <i class="fa-solid fa-store"></i> Lấy hàng
                </span>
            </div>
            <div style="display:flex; gap:0.5rem; margin-bottom:0.75rem;">
                <div class="stat-pill">
                    <p style="font-size:1.1rem; font-weight:900; color:#f97316; margin:0;" id="routeDistanceVal">--</p>
                    <p style="font-size:0.5rem; color:#64748b; font-weight:700; text-transform:uppercase; margin:0;">Km</p>
                </div>
                <div class="stat-pill">
                    <p style="font-size:1.1rem; font-weight:900; color:#22c55e; margin:0;" id="routeTimeVal">--</p>
                    <p style="font-size:0.5rem; color:#64748b; font-weight:700; text-transform:uppercase; margin:0;">Phút</p>
                </div>
                <div class="stat-pill">
                    <p style="font-size:1.1rem; font-weight:900; color:#3b82f6; margin:0;" id="routeDestVal">--</p>
                    <p style="font-size:0.5rem; color:#64748b; font-weight:700; text-transform:uppercase; margin:0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;" id="routeDestLabel">Điểm đến</p>
                </div>
            </div>
            <div style="display:flex; align-items:center; gap:0.5rem; padding:0.5rem 0.75rem; background:rgba(255,255,255,0.03); border:1px solid rgba(255,255,255,0.06); border-radius:0.6rem;">
                <i class="fa-solid fa-location-dot" style="color:#f97316; font-size:0.7rem;"></i>
                <p style="font-size:0.7rem; color:#cbd5e1; font-weight:600; margin:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" id="routeDestAddress">--</p>
            </div>
        </div>
    </div>

    <!-- ===== ORDERS PANEL ===== -->
    <div class="orders-panel">
        <!-- Header -->
        <div style="padding:1.5rem 1.25rem 1rem; border-bottom:1px solid rgba(255,255,255,0.06);">
            <div style="display:flex; justify-content:space-between; align-items:center;">
                <div>
                    <h2 style="font-size:1.25rem; font-weight:900; color:white; margin:0;">
                        <i class="fa-solid fa-fire" style="color:#f97316; margin-right:0.5rem;"></i>Đơn Đang Nổ!
                    </h2>
                    <p style="font-size:0.65rem; color:#64748b; font-weight:700; text-transform:uppercase; letter-spacing:0.12em; margin:0.25rem 0 0;">Các đơn đang chờ bạn nhận</p>
                </div>
                <div style="background:rgba(249,115,22,0.1); border:1px solid rgba(249,115,22,0.25); border-radius:999px; padding:0.4rem 1rem;">
                    @{
                        int totalAvailable = Model.Count() + ((ViewBag.AvailableBatches as List<BatchOrder>)?.Count ?? 0);
                    }
                    <span style="font-size:0.85rem; font-weight:900; color:#f97316;" id="orderCountBadge">@totalAvailable đơn</span>
                </div>
            </div>
        </div>

        <!-- Order List -->
        <div class="orders-scroll">
            @if (!isOnline)
            {
                <div style="display:flex; flex-direction:column; align-items:center; justify-content:center; height:100%; padding:3rem 1rem; text-align:center;">
                    <div style="width:5rem; height:5rem; border-radius:50%; background:rgba(239,68,68,0.1); border:1px solid rgba(239,68,68,0.2); display:flex; align-items:center; justify-content:center; margin-bottom:1rem;">
                        <i class="fa-solid fa-power-off" style="font-size:1.75rem; color:#ef4444;"></i>
                    </div>
                    <h4 style="font-size:1rem; font-weight:900; color:white; margin:0 0 0.5rem;">Bạn đang ngoại tuyến</h4>
                    <p style="font-size:0.75rem; color:#64748b;">Chưa thể tìm đơn hàng xung quanh. Vui lòng bật trạng thái trực tuyến.</p>
                </div>
            }
            else if (hasActiveOrder)
            {
                <div style="display:flex; flex-direction:column; align-items:center; justify-content:center; height:100%; padding:3rem 1rem; text-align:center;">
                    <div style="width:5rem; height:5rem; border-radius:50%; background:rgba(59,130,246,0.1); border:1px solid rgba(59,130,246,0.25); display:flex; align-items:center; justify-content:center; margin-bottom:1rem;">
                        <i class="fa-solid fa-truck-fast" style="font-size:1.75rem; color:#3b82f6;"></i>
                    </div>
                    <h4 style="font-size:1rem; font-weight:900; color:white; margin:0 0 0.5rem;">Đạng trong quá trình giao hàng</h4>
                    <p style="font-size:0.75rem; color:#64748b; margin-bottom:1.5rem;">Hoàn thành đơn hiện tại trước khi nhận đơn mới.</p>
                    <a href="/Shipper" style="padding:0.75rem 1.5rem; background:#3b82f6; border:none; border-radius:0.875rem; color:white; font-size:0.8rem; font-weight:900; cursor:pointer; text-decoration:none; display:inline-flex; align-items:center; gap:0.5rem; box-shadow:0 4px 15px rgba(59,130,246,0.35);">
                        <i class="fa-solid fa-arrow-left"></i> Về Dashboard
                    </a>
                </div>
            }
            else if (Model.Any() || (ViewBag.AvailableBatches as List<BatchOrder>)?.Any() == true)
            {
                <!-- Batch orders section -->
                @if (ViewBag.AvailableBatches != null)
                {
                    @foreach (var batch in (ViewBag.AvailableBatches as List<BatchOrder>)!)
                    {
                        var totalItems = batch.Items.Sum(bi => bi.Order?.OrderItems?.Sum(oi => oi.Quantity) ?? 0);
                        var storeCount = batch.Items.Count;
                        var firstStore = batch.Items.OrderBy(bi => bi.Sequence).FirstOrDefault()?.Order?.Store;

                        <div class="order-card" style="border-width:2px; border-color:rgba(168,85,247,0.4); background:rgba(168,85,247,0.03);" id="batch-card-@batch.Id">
                            <!-- Card Header -->
                            <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:0.875rem;">
                                <div style="display:flex; align-items:center; gap:0.6rem;">
                                    <div style="width:2rem; height:2rem; border-radius:0.5rem; background:rgba(168,85,247,0.15); border:1px solid rgba(168,85,247,0.25); display:flex; align-items:center; justify-content:center;">
                                        <i class="fa-solid fa-layer-group" style="color:#a855f7; font-size:0.75rem;"></i>
                                    </div>
                                    <div>
                                        <div style="display:flex; align-items:center; gap:0.4rem;">
                                            <p style="font-size:0.8rem; font-weight:900; color:#a855f7; margin:0;">@batch.BatchCode</p>
                                            <span style="background:#a855f7; color:white; font-size:0.55rem; font-weight:900; padding:1px 4px; border-radius:4px; text-transform:uppercase;">Gom đơn</span>
                                        </div>
                                        <p style="font-size:0.6rem; color:#64748b; font-weight:600; margin:0;">@batch.CreatedAt.ToString("HH:mm - dd/MM/yyyy")</p>
                                    </div>
                                </div>
                                <div style="text-align:right;">
                                    <p style="font-size:1.1rem; font-weight:900; color:white; margin:0;">@string.Format("{0:N0}", batch.TotalIncome)</p>
                                    <p style="font-size:0.6rem; color:#64748b; font-weight:700; text-transform:uppercase; margin:0;">VND</p>
                                </div>
                            </div>

                            <!-- Stores Summary -->
                            <div style="background:rgba(255,255,255,0.03); border-radius:0.75rem; padding:0.75rem; margin-bottom:0.875rem; border:1px solid rgba(255,255,255,0.05);">
                                <p style="font-size:0.6rem; font-weight:800; color:#a855f7; text-transform:uppercase; letter-spacing:0.1em; margin:0 0 6px;">Lộ trình gộp @storeCount cửa hàng</p>
                                <div style="display:flex; flex-direction:column; gap:6px;">
                                    @foreach (var item in batch.Items.OrderBy(bi => bi.Sequence))
                                    {
                                        <div style="display:flex; align-items:center; gap:8px;">
                                            <div style="width:14px; height:14px; border-radius:50%; background:rgba(168,85,247,0.2); border:1px solid #a855f7; display:flex; align-items:center; justify-content:center; flex-shrink:0;">
                                                <span style="font-size:8px; color:white; font-weight:900;">@item.Sequence</span>
                                            </div>
                                            <p style="font-size:0.75rem; color:#cbd5e1; font-weight:700; margin:0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">@(item.Order?.Store?.Name ?? "Quán ăn")</p>
                                        </div>
                                    }
                                    <div style="display:flex; align-items:center; gap:8px; margin-top:4px; padding-top:4px; border-top:1px solid rgba(255,255,255,0.05);">
                                        <i class="fa-solid fa-location-dot" style="color:#3b82f6; font-size:12px; width:14px; text-align:center;"></i>
                                        <p style="font-size:0.7rem; color:#94a3b8; margin:0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">@batch.DeliveryAddress</p>
                                    </div>
                                </div>
                            </div>

                            <!-- Badges -->
                            <div style="display:flex; flex-wrap:wrap; gap:0.375rem; margin-bottom:0.875rem;">
                                <span style="background:rgba(168,85,247,0.1); border:1px solid rgba(168,85,247,0.2); border-radius:0.5rem; padding:0.3rem 0.6rem; font-size:0.65rem; font-weight:700; color:#d8b4fe;">
                                    <i class="fa-solid fa-route" style="margin-right:4px;"></i>@batch.TotalDistance.ToString("F1")km
                                </span>
                                <span style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.08); border-radius:0.5rem; padding:0.3rem 0.6rem; font-size:0.65rem; font-weight:700; color:#cbd5e1;">
                                    <i class="fa-solid fa-clock" style="color:#a855f7; margin-right:4px;"></i>~@Math.Round(batch.TotalDistance * 4) phút
                                </span>
                                <span style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.08); border-radius:0.5rem; padding:0.3rem 0.6rem; font-size:0.65rem; font-weight:700; color:#cbd5e1;">
                                    <i class="fa-solid fa-box" style="color:#a855f7; margin-right:4px;"></i>@totalItems món
                                </span>
                            </div>

                            <!-- Action Buttons -->
                            <div style="display:flex; gap:0.5rem;">
                                <button onclick="acceptBatch(@batch.Id, this)"
                                        style="flex:1; padding:0.75rem; background:#a855f7; border:none; border-radius:0.75rem; color:white; font-size:0.8rem; font-weight:900; cursor:pointer; transition:all 0.2s; box-shadow:0 4px 15px rgba(168,85,247,0.35);"
                                        onmouseover="this.style.background='#c084fc'; this.style.transform='translateY(-1px)'"
                                        onmouseout="this.style.background='#a855f7'; this.style.transform='translateY(0)'">
                                    <i class="fa-solid fa-check-double" style="margin-right:0.4rem;"></i>Nhận đợt gom này
                                </button>
                            </div>
                        </div>
                    }
                }

                @foreach (var order in Model)
                {
                    var itemCount = order.OrderItems?.Sum(oi => oi.Quantity) ?? 0;
                    <div class="order-card" id="card-@order.OrderCode"
                         data-id="@order.Id"
                         data-code="@order.OrderCode"
                         data-store-lat="@((order.Store?.Latitude ?? 0).ToString(System.Globalization.CultureInfo.InvariantCulture))"
                         data-store-lng="@((order.Store?.Longitude ?? 0).ToString(System.Globalization.CultureInfo.InvariantCulture))"
                         data-store-name="@(order.Store?.Name ?? "Cửa hàng")"
                         data-delivery-lat="@order.DeliveryLatitude.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                         data-delivery-lng="@order.DeliveryLongitude.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                         data-delivery-addr="@order.DeliveryAddress"
                         data-customer="@(order.User?.FullName ?? "Khách hàng")"
                         onclick="highlightOrder('@order.OrderCode')">
                        
                        <!-- Card Header -->
                        <div style="display:flex; justify-content:space-between; align-items:flex-start; margin-bottom:0.875rem;">
                            <div style="display:flex; align-items:center; gap:0.6rem;">
                                <div style="width:2rem; height:2rem; border-radius:0.5rem; background:rgba(249,115,22,0.15); border:1px solid rgba(249,115,22,0.25); display:flex; align-items:center; justify-content:center;">
                                    <i class="fa-solid fa-bag-shopping" style="color:#f97316; font-size:0.75rem;"></i>
                                </div>
                                <div>
                                    <p style="font-size:0.8rem; font-weight:900; color:#f97316; margin:0;">@order.OrderCode</p>
                                    <p style="font-size:0.6rem; color:#64748b; font-weight:600; margin:0;">@order.CreatedAt.ToString("HH:mm - dd/MM/yyyy")</p>
                                </div>
                            </div>
                            <div style="text-align:right;">
                                <p style="font-size:1.1rem; font-weight:900; color:white; margin:0;">@string.Format("{0:N0}", order.ShipperIncome)</p>
                                <p style="font-size:0.6rem; color:#64748b; font-weight:700; text-transform:uppercase; margin:0;">VND</p>
                            </div>
                        </div>

                        <!-- Route -->
                        <div style="display:flex; align-items:stretch; margin-bottom:0.875rem;">
                            <div class="route-line">
                                <div class="dot-orange"></div>
                                <div class="route-seg"></div>
                                <div class="dot-blue"></div>
                            </div>
                            <div style="flex:1; min-width:0;">
                                <div style="margin-bottom:0.6rem;">
                                    <p style="font-size:0.6rem; font-weight:800; color:#f97316; text-transform:uppercase; letter-spacing:0.1em; margin:0 0 2px;">Lấy hàng</p>
                                    <p style="font-size:0.8rem; font-weight:700; color:white; margin:0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">@(order.Store?.Name ?? "Cửa hàng")</p>
                                    <p style="font-size:0.65rem; color:#64748b; margin:0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">@order.PickupAddress</p>
                                </div>
                                <div>
                                    <p style="font-size:0.6rem; font-weight:800; color:#3b82f6; text-transform:uppercase; letter-spacing:0.1em; margin:0 0 2px;">Giao đến</p>
                                    <p style="font-size:0.8rem; font-weight:700; color:white; margin:0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">@(order.User?.FullName ?? "Khách hàng")</p>
                                    <p style="font-size:0.65rem; color:#64748b; margin:0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">@order.DeliveryAddress</p>
                                </div>
                            </div>
                        </div>

                        <!-- Badges -->
                        <div style="display:flex; flex-wrap:wrap; gap:0.375rem; margin-bottom:0.875rem;">
                            <span style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.08); border-radius:0.5rem; padding:0.3rem 0.6rem; font-size:0.65rem; font-weight:700; color:#cbd5e1;">
                                <i class="fa-solid fa-route" style="color:#f97316; margin-right:4px;"></i>@(order.Distance > 0 ? $"{order.Distance:F1}km" : "~1km")
                            </span>
                            <span style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.08); border-radius:0.5rem; padding:0.3rem 0.6rem; font-size:0.65rem; font-weight:700; color:#cbd5e1;">
                                <i class="fa-solid fa-box" style="color:#f97316; margin-right:4px;"></i>@itemCount món
                            </span>
                            @if (order.PaymentMethod == PaymentMethod.Cash) {
                                <span style="background:rgba(34,197,94,0.1); border:1px solid rgba(34,197,94,0.25); border-radius:0.5rem; padding:0.3rem 0.6rem; font-size:0.65rem; font-weight:700; color:#4ade80;">
                                    <i class="fa-solid fa-money-bill" style="margin-right:4px;"></i>Tiền mặt
                                </span>
                            } else {
                                <span style="background:rgba(168,85,247,0.1); border:1px solid rgba(168,85,247,0.25); border-radius:0.5rem; padding:0.3rem 0.6rem; font-size:0.65rem; font-weight:700; color:#c084fc;">
                                    <i class="fa-solid fa-wallet" style="margin-right:4px;"></i>Ví điện tử
                                </span>
                            }
                        </div>

                        <!-- Action Buttons -->
                        <div style="display:flex; gap:0.5rem;" onclick="event.stopPropagation()" id="actions-@order.OrderCode">
                            <button onclick="skipOrder(this, '@order.OrderCode')"
                                    style="flex:1; padding:0.6rem; background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.1); border-radius:0.75rem; color:#94a3b8; font-size:0.75rem; font-weight:700; cursor:pointer; transition:all 0.2s;"
                                    onmouseover="this.style.background='rgba(239,68,68,0.15)'; this.style.color='#f87171'; this.style.borderColor='rgba(239,68,68,0.3)'"
                                    onmouseout="this.style.background='rgba(255,255,255,0.04)'; this.style.color='#94a3b8'; this.style.borderColor='rgba(255,255,255,0.1)'">
                                Bỏ qua
                            </button>
                            <button onclick="acceptOrder('@order.OrderCode', this)"
                                    id="acceptBtn-@order.OrderCode"
                                    style="flex:2; padding:0.6rem; background:#f97316; border:none; border-radius:0.75rem; color:black; font-size:0.75rem; font-weight:900; cursor:pointer; transition:all 0.2s; box-shadow:0 4px 15px rgba(249,115,22,0.35);"
                                    onmouseover="this.style.background='#fb923c'; this.style.transform='translateY(-1px)'"
                                    onmouseout="this.style.background='#f97316'; this.style.transform='translateY(0)'">
                                <i class="fa-solid fa-check" style="margin-right:0.4rem;"></i>Nhận đơn
                            </button>
                        </div>
                    </div>
                }
            }
            else
            {
                <div style="display:flex; flex-direction:column; align-items:center; justify-content:center; height:100%; padding:3rem 1rem; text-align:center;">
                    <div style="width:5rem; height:5rem; border-radius:50%; background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); display:flex; align-items:center; justify-content:center; margin-bottom:1rem;">
                        <i class="fa-solid fa-satellite-dish" style="font-size:1.75rem; color:#334155;"></i>
                    </div>
                    <h4 style="font-size:1rem; font-weight:900; color:white; margin:0 0 0.5rem;">Đang quét tín hiệu...</h4>
                    <p style="font-size:0.75rem; color:#64748b;">Chưa có đơn hàng nào gần đây. Hãy giữ trạng thái trực tuyến.</p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
<script>
    const shipperLat = @( (shipperUser?.Latitude ?? 10.762622).ToString(System.Globalization.CultureInfo.InvariantCulture) );
    const shipperLng = @( (shipperUser?.Longitude ?? 106.660172).ToString(System.Globalization.CultureInfo.InvariantCulture) );

    async function acceptBatch(batchId, btn) {
        const originalHtml = btn.innerHTML;
        btn.innerHTML = `<i class="fa-solid fa-spinner fa-spin" style="margin-right:0.4rem;"></i>Đang nhận...`;
        btn.disabled = true;

        try {
            const res = await fetch('/Shipper/AcceptBatch', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ batchId: batchId })
            });
            const data = await res.json();
            if (data.success) {
                Swal.fire({
                    title: 'Thành công!',
                    text: 'Bạn đã nhận đợt gom đơn này. Hãy bắt đầu lộ trình!',
                    icon: 'success',
                    background: '#0f172a',
                    color: '#fff',
                    confirmButtonColor: '#a855f7'
                }).then(() => {
                    window.location.href = '/Shipper/BatchDetail/' + data.batchId;
                });
            } else {
                Swal.fire({
                    title: 'Thất bại',
                    text: data.message,
                    icon: 'error',
                    background: '#0f172a',
                    color: '#fff'
                });
                btn.innerHTML = originalHtml;
                btn.disabled = false;
            }
        } catch (e) {
            console.error(e);
            alert('Lỗi kết nối.');
            btn.innerHTML = originalHtml;
            btn.disabled = false;
        }
    }

    // --- State ---
    let currentShipperLat = shipperLat;
    let currentShipperLng = shipperLng;
    let shipperMarker = null;
    let routeLayer = null;
    let activeOrderCode = null;
    let activePhase = null; // 'pickup' or 'deliver'

    // --- Map Init (BRIGHT tile - CartoDB Voyager) ---
    const map = L.map('availableMap', { zoomControl: true }).setView([shipperLat, shipperLng], 13);

    L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png', {
        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> &copy; <a href="https://carto.com/">CARTO</a>',
        maxZoom: 20,
        subdomains: 'abcd'
    }).addTo(map);

    // 5km radius circle
    L.circle([shipperLat, shipperLng], {
        color: '@(isOnline ? "#f97316" : "#94a3b8")',
        fillColor: '@(isOnline ? "#f97316" : "#94a3b8")',
        fillOpacity: 0.06, weight: 2, dashArray: '8 4', radius: 5000
    }).addTo(map);

    // Shipper marker
    function createShipperIcon(phase) {
        const bg = phase === 'deliver' ? '#3b82f6' : '#f97316';
        const shadow = phase === 'deliver' ? 'rgba(59,130,246,0.7)' : 'rgba(249,115,22,0.7)';
        const icon = phase === 'deliver' ? 'fa-truck-fast' : 'fa-motorcycle';
        return L.divIcon({
            html: `<div style="width:48px;height:48px;background:${bg};border:3px solid white;border-radius:50%;display:flex;align-items:center;justify-content:center;color:white;font-size:20px;box-shadow:0 0 24px ${shadow},0 4px 12px rgba(0,0,0,0.3);transition:all 0.5s;"><i class="fa-solid ${icon}"></i></div>`,
            className: '', iconSize: [48, 48], iconAnchor: [24, 24]
        });
    }

    shipperMarker = L.marker([shipperLat, shipperLng], { icon: createShipperIcon('pickup'), zIndexOffset: 1000 })
        .addTo(map)
        .bindPopup(`<div style="font-weight:800;color:#f97316;font-size:13px;">📍 Vị trí của bạn</div>`)
        .openPopup();

    // Store markers
    const storeMarkers = {};
    const deliveryMarkers = {};

    @foreach (var order in Model)
    {
        var sLat = (order.Store?.Latitude ?? 0).ToString(System.Globalization.CultureInfo.InvariantCulture);
        var sLng = (order.Store?.Longitude ?? 0).ToString(System.Globalization.CultureInfo.InvariantCulture);
        if (order.Store?.Latitude != null && order.Store?.Latitude != 0)
        {
            @:addStoreMarker('@order.OrderCode', @sLat, @sLng, '@(order.Store?.Name ?? "Cửa hàng")');
        }
    }

    function addStoreMarker(code, lat, lng, name) {
        if (lat === 0 && lng === 0) return;
        const icon = L.divIcon({
            html: `<div style="width:36px;height:36px;background:white;border:3px solid #f97316;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#f97316;font-size:14px;box-shadow:0 2px 8px rgba(0,0,0,0.15),0 0 0 3px rgba(249,115,22,0.15);"><i class="fa-solid fa-store"></i></div>`,
            className: '', iconSize: [36, 36], iconAnchor: [18, 18]
        });
        storeMarkers[code] = L.marker([lat, lng], { icon })
            .addTo(map)
            .bindPopup(`<div style="font-weight:800;font-size:12px;color:#1e293b;"><i class="fa-solid fa-store" style="color:#f97316;margin-right:4px;"></i>${name}</div>`);
    }

    function addDeliveryMarker(code, lat, lng, customerName) {
        if (lat === 0 && lng === 0) return;
        if (deliveryMarkers[code]) map.removeLayer(deliveryMarkers[code]);
        const icon = L.divIcon({
            html: `<div style="width:36px;height:36px;background:white;border:3px solid #3b82f6;border-radius:50%;display:flex;align-items:center;justify-content:center;color:#3b82f6;font-size:14px;box-shadow:0 2px 8px rgba(0,0,0,0.15),0 0 0 3px rgba(59,130,246,0.15);"><i class="fa-solid fa-flag-checkered"></i></div>`,
            className: '', iconSize: [36, 36], iconAnchor: [18, 18]
        });
        deliveryMarkers[code] = L.marker([lat, lng], { icon })
            .addTo(map)
            .bindPopup(`<div style="font-weight:800;font-size:12px;color:#1e293b;"><i class="fa-solid fa-user" style="color:#3b82f6;margin-right:4px;"></i>${customerName}</div>`);
    }

    // --- Highlight order card ---
    function highlightOrder(code) {
        document.querySelectorAll('.order-card').forEach(c => {
            if (!c.classList.contains('accepted') && !c.classList.contains('delivering')) {
                c.classList.remove('active');
            }
        });
        const card = document.getElementById('card-' + code);
        if (card && !card.classList.contains('accepted') && !card.classList.contains('delivering')) {
            card.classList.add('active');
        }

        // Pan to store
        const sLat = parseFloat(card?.dataset.storeLat || 0);
        const sLng = parseFloat(card?.dataset.storeLng || 0);
        if (sLat !== 0 && sLng !== 0 && storeMarkers[code]) {
            const bounds = L.latLngBounds([[currentShipperLat, currentShipperLng], [sLat, sLng]]);
            map.fitBounds(bounds, { padding: [80, 80] });
            storeMarkers[code].openPopup();
        }
    }

    // --- Draw animated route ---
    function clearRoute() {
        if (routeLayer) { map.removeLayer(routeLayer); routeLayer = null; }
    }

    async function drawRoute(fromLat, fromLng, toLat, toLng, color, phase) {
        clearRoute();

        // Use straight line as fallback, try to get real route via OSRM
        const routeCoords = [[fromLat, fromLng], [toLat, toLng]];

        try {
            const osrmUrl = `https://router.project-osrm.org/route/v1/driving/${fromLng},${fromLat};${toLng},${toLat}?overview=full&geometries=geojson`;
            const res = await fetch(osrmUrl);
            const data = await res.json();

            if (data.routes && data.routes.length > 0) {
                const route = data.routes[0];
                const coords = route.geometry.coordinates.map(c => [c[1], c[0]]);
                const distance = (route.distance / 1000).toFixed(1);
                const duration = Math.round(route.duration / 60);

                // Draw with animation
                routeLayer = L.layerGroup().addTo(map);

                // Background line (shadow)
                L.polyline(coords, {
                    color: color === '#f97316' ? '#fed7aa' : '#bfdbfe',
                    weight: 10, opacity: 0.4, lineCap: 'round', lineJoin: 'round'
                }).addTo(routeLayer);

                // Main animated line
                const mainLine = L.polyline([], {
                    color: color, weight: 5, opacity: 0.9,
                    lineCap: 'round', lineJoin: 'round'
                }).addTo(routeLayer);

                // Animate drawing
                let idx = 0;
                const step = Math.max(1, Math.floor(coords.length / 60));
                function animateStep() {
                    if (idx < coords.length) {
                        mainLine.addLatLng(coords[idx]);
                        idx += step;
                        if (idx >= coords.length) {
                            mainLine.setLatLngs(coords); // final complete
                        }
                        requestAnimationFrame(animateStep);
                    } else {
                        // Add flowing dash overlay
                        addFlowingDash(coords, color);
                    }
                }
                animateStep();

                // Fit bounds
                const bounds = L.latLngBounds(coords);
                map.fitBounds(bounds, { padding: [80, 80] });

                // Update route info panel
                updateRouteInfo(distance, duration, phase);
                return { distance, duration };
            }
        } catch (e) {
            console.warn('OSRM route failed, using straight line:', e);
        }

        // Fallback: straight line
        routeLayer = L.polyline(routeCoords, {
            color: color, weight: 5, opacity: 0.8,
            dashArray: '12 6', lineCap: 'round'
        }).addTo(map);

        const dist = haversine(fromLat, fromLng, toLat, toLng).toFixed(1);
        const time = Math.round(parseFloat(dist) * 3); // rough estimate
        map.fitBounds(L.latLngBounds(routeCoords), { padding: [80, 80] });
        updateRouteInfo(dist, time, phase);
        return { distance: dist, duration: time };
    }

    function addFlowingDash(coords, color) {
        // Create SVG-based flowing animation using a second polyline
        const dashLine = L.polyline(coords, {
            color: 'white', weight: 3, opacity: 0.6,
            dashArray: '8 16', lineCap: 'round', lineJoin: 'round',
            className: 'animated-route'
        }).addTo(routeLayer);
    }

    function haversine(lat1, lon1, lat2, lon2) {
        const R = 6371;
        const dLat = (lat2 - lat1) * Math.PI / 180;
        const dLon = (lon2 - lon1) * Math.PI / 180;
        const a = Math.sin(dLat/2)**2 + Math.cos(lat1*Math.PI/180)*Math.cos(lat2*Math.PI/180)*Math.sin(dLon/2)**2;
        return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
    }

    function updateRouteInfo(distance, duration, phase) {
        const panel = document.getElementById('routeInfoPanel');
        const iconBox = document.getElementById('routeIconBox');
        const icon = document.getElementById('routeIcon');
        const title = document.getElementById('routeTitle');
        const subtitle = document.getElementById('routeSubtitle');
        const badge = document.getElementById('routePhaseBadge');
        const distVal = document.getElementById('routeDistanceVal');
        const timeVal = document.getElementById('routeTimeVal');
        const destVal = document.getElementById('routeDestVal');

        distVal.textContent = distance;
        distVal.style.color = phase === 'deliver' ? '#3b82f6' : '#f97316';
        timeVal.textContent = duration;

        if (phase === 'pickup') {
            iconBox.style.background = 'rgba(249,115,22,0.15)';
            iconBox.style.border = '1px solid rgba(249,115,22,0.25)';
            icon.style.color = '#f97316';
            title.textContent = 'Đường đến quán';
            subtitle.textContent = 'Đi lấy hàng cho khách';
            badge.className = 'phase-badge phase-pickup';
            badge.innerHTML = '<i class="fa-solid fa-store"></i> Lấy hàng';
            destVal.textContent = '🍜';
            document.getElementById('routeDestLabel').textContent = 'Quán ăn';
        } else {
            iconBox.style.background = 'rgba(59,130,246,0.15)';
            iconBox.style.border = '1px solid rgba(59,130,246,0.25)';
            icon.style.color = '#3b82f6';
            title.textContent = 'Đường đến khách';
            subtitle.textContent = 'Giao hàng cho khách';
            badge.className = 'phase-badge phase-deliver';
            badge.innerHTML = '<i class="fa-solid fa-location-dot"></i> Giao hàng';
            destVal.textContent = '📍';
            document.getElementById('routeDestLabel').textContent = 'Khách hàng';
        }

        panel.classList.add('visible');
    }

    // --- Move shipper marker with smooth animation ---
    function moveShipperTo(lat, lng, phase) {
        currentShipperLat = lat;
        currentShipperLng = lng;

        // Update icon based on phase
        shipperMarker.setIcon(createShipperIcon(phase));

        // Animate position
        const startLatLng = shipperMarker.getLatLng();
        const endLatLng = L.latLng(lat, lng);
        const frames = 40;
        let frame = 0;

        function animate() {
            frame++;
            const t = frame / frames;
            // Ease out cubic
            const ease = 1 - Math.pow(1 - t, 3);
            const newLat = startLatLng.lat + (endLatLng.lat - startLatLng.lat) * ease;
            const newLng = startLatLng.lng + (endLatLng.lng - startLatLng.lng) * ease;
            shipperMarker.setLatLng([newLat, newLng]);

            if (frame < frames) {
                requestAnimationFrame(animate);
            } else {
                shipperMarker.setLatLng(endLatLng);
                if (phase === 'deliver') {
                    shipperMarker.bindPopup(`<div style="font-weight:800;color:#3b82f6;font-size:13px;">📍 Đã lấy hàng - Đang giao</div>`).openPopup();
                }
            }
        }
        animate();
    }

    // --- Accept Order ---
    async function acceptOrder(orderCode, btn) {
        btn.innerHTML = `<i class="fa-solid fa-spinner fa-spin" style="margin-right:0.4rem;"></i>Đang nhận...`;
        btn.disabled = true;
        try {
            const res = await fetch('/Shipper/AcceptOrder', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(orderCode)
            });
            const data = await res.json();
            if (data.success) {
                activeOrderCode = orderCode;
                activePhase = 'pickup';

                // Update card state
                const card = document.getElementById('card-' + orderCode);
                card.classList.remove('active');
                card.classList.add('accepted');

                // Replace buttons with pickup button
                const actionsDiv = document.getElementById('actions-' + orderCode);
                actionsDiv.innerHTML = `
                    <button onclick="markPickedUp('${orderCode}', this)"
                            style="flex:1; padding:0.7rem; background:linear-gradient(135deg, #22c55e, #16a34a); border:none; border-radius:0.75rem; color:white; font-size:0.8rem; font-weight:900; cursor:pointer; transition:all 0.2s; box-shadow:0 4px 15px rgba(34,197,94,0.35);"
                            onmouseover="this.style.transform='translateY(-1px)'"
                            onmouseout="this.style.transform='translateY(0)'">
                        <i class="fa-solid fa-hand" style="margin-right:0.4rem;"></i>Đã lấy hàng
                    </button>
                `;

                // Draw route: shipper → store
                const storeLat = data.storeLat || parseFloat(card.dataset.storeLat);
                const storeLng = data.storeLng || parseFloat(card.dataset.storeLng);

                if (storeLat && storeLng) {
                    await drawRoute(currentShipperLat, currentShipperLng, storeLat, storeLng, '#f97316', 'pickup');
                    document.getElementById('routeDestAddress').textContent = data.pickupAddress || card.querySelector('[style*="Lấy hàng"]')?.nextElementSibling?.nextElementSibling?.textContent || '';
                }

                // Disable other order cards
                document.querySelectorAll('.order-card').forEach(c => {
                    if (c.id !== 'card-' + orderCode) {
                        c.style.opacity = '0.4';
                        c.style.pointerEvents = 'none';
                    }
                });

            } else {
                alert('Lỗi: ' + data.message);
                btn.innerHTML = `<i class="fa-solid fa-check" style="margin-right:0.4rem;"></i>Nhận đơn`;
                btn.disabled = false;
            }
        } catch (e) {
            console.error(e);
            alert('Đã xảy ra lỗi kết nối.');
            btn.innerHTML = `<i class="fa-solid fa-check" style="margin-right:0.4rem;"></i>Nhận đơn`;
            btn.disabled = false;
        }
    }

    // --- Mark Picked Up ---
    async function markPickedUp(orderCode, btn) {
        btn.innerHTML = `<i class="fa-solid fa-spinner fa-spin" style="margin-right:0.4rem;"></i>Đang xử lý...`;
        btn.disabled = true;

        try {
            const res = await fetch('/Shipper/MarkPickedUp', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(orderCode)
            });
            const data = await res.json();

            if (data.success) {
                activePhase = 'deliver';

                // Update card state
                const card = document.getElementById('card-' + orderCode);
                card.classList.remove('accepted');
                card.classList.add('delivering');

                // Move shipper to store location
                const storeLat = data.storeLat || parseFloat(card.dataset.storeLat);
                const storeLng = data.storeLng || parseFloat(card.dataset.storeLng);
                moveShipperTo(storeLat, storeLng, 'deliver');

                // Remove store marker (shipper is there now)
                if (storeMarkers[orderCode]) {
                    map.removeLayer(storeMarkers[orderCode]);
                }

                // Add delivery marker
                const deliveryLat = data.deliveryLat || parseFloat(card.dataset.deliveryLat);
                const deliveryLng = data.deliveryLng || parseFloat(card.dataset.deliveryLng);
                const customerName = data.customerName || card.dataset.customer;
                addDeliveryMarker(orderCode, deliveryLat, deliveryLng, customerName);

                // Wait a bit for the shipper to move, then draw route to customer
                setTimeout(async () => {
                    await drawRoute(storeLat, storeLng, deliveryLat, deliveryLng, '#3b82f6', 'deliver');
                    document.getElementById('routeDestAddress').textContent = data.deliveryAddress || card.dataset.deliveryAddr;
                }, 1200);

                // Update buttons to "Complete"
                const actionsDiv = document.getElementById('actions-' + orderCode);
                actionsDiv.innerHTML = `
                    <button onclick="completeOrder('${orderCode}', this)"
                            style="flex:1; padding:0.7rem; background:linear-gradient(135deg, #3b82f6, #2563eb); border:none; border-radius:0.75rem; color:white; font-size:0.8rem; font-weight:900; cursor:pointer; transition:all 0.2s; box-shadow:0 4px 15px rgba(59,130,246,0.35);"
                            onmouseover="this.style.transform='translateY(-1px)'"
                            onmouseout="this.style.transform='translateY(0)'">
                        <i class="fa-solid fa-flag-checkered" style="margin-right:0.4rem;"></i>Đã giao hàng
                    </button>
                `;

            } else {
                alert('Lỗi: ' + data.message);
                btn.innerHTML = `<i class="fa-solid fa-hand" style="margin-right:0.4rem;"></i>Đã lấy hàng`;
                btn.disabled = false;
            }
        } catch (e) {
            console.error(e);
            alert('Đã xảy ra lỗi kết nối.');
            btn.innerHTML = `<i class="fa-solid fa-hand" style="margin-right:0.4rem;"></i>Đã lấy hàng`;
            btn.disabled = false;
        }
    }

    // --- Complete Order ---
    async function completeOrder(orderCode, btn) {
        btn.innerHTML = `<i class="fa-solid fa-spinner fa-spin" style="margin-right:0.4rem;"></i>Đang hoàn thành...`;
        btn.disabled = true;

        try {
            const res = await fetch('/Shipper/CompleteOrder', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(orderCode)
            });
            const data = await res.json();

            if (data.success) {
                const card = document.getElementById('card-' + orderCode);
                const actionsDiv = document.getElementById('actions-' + orderCode);
                actionsDiv.innerHTML = `
                    <div style="width:100%; padding:0.7rem; background:rgba(34,197,94,0.15); border:1px solid rgba(34,197,94,0.3); border-radius:0.75rem; text-align:center;">
                        <span style="color:#22c55e; font-weight:900; font-size:0.8rem;">
                            <i class="fa-solid fa-circle-check" style="margin-right:0.4rem;"></i>Giao thành công!
                        </span>
                    </div>
                `;
                card.classList.remove('delivering');
                card.style.borderColor = '#22c55e';
                card.style.boxShadow = '0 0 25px rgba(34,197,94,0.2)';

                // Hide route info
                document.getElementById('routeInfoPanel').classList.remove('visible');
                clearRoute();

                // Clean up markers
                if (deliveryMarkers[orderCode]) map.removeLayer(deliveryMarkers[orderCode]);

                // --- NEW: Shipper Ratings Popup ---
                Swal.fire({
                    title: 'Giao hàng thành công!',
                    text: 'Bạn thấy nhà hàng này phục vụ như thế nào?',
                    icon: 'success',
                    showCancelButton: true,
                    confirmButtonText: 'Đánh giá ngay',
                    cancelButtonText: 'Để sau',
                    background: '#0f172a',
                    color: '#fff',
                    confirmButtonColor: '#f97316',
                    reverseButtons: true
                }).then((result) => {
                    if (result.isConfirmed) {
                        showRatingModal(card.dataset.id, card.dataset.storeName);
                    } else {
                        window.location.reload();
                    }
                });
            } else {
                alert('Lỗi: ' + data.message);
                btn.innerHTML = `<i class="fa-solid fa-flag-checkered" style="margin-right:0.4rem;"></i>Đã giao hàng`;
                btn.disabled = false;
            }
        } catch (e) {
            console.error(e);
            alert('Đã xảy ra lỗi kết nối.');
            btn.innerHTML = `<i class="fa-solid fa-flag-checkered" style="margin-right:0.4rem;"></i>Đã giao hàng`;
            btn.disabled = false;
        }
    }

    function skipOrder(btn, code) {
        const card = document.getElementById('card-' + code);
        card.style.opacity = '0';
        card.style.transform = 'translateX(40px)';
        card.style.transition = 'all 0.3s ease';
        if (storeMarkers[code]) map.removeLayer(storeMarkers[code]);
        setTimeout(() => { card.remove(); updateCount(); }, 300);
    }

    function updateCount() {
        const remaining = document.querySelectorAll('.order-card').length;
        const badge = document.getElementById('orderCountBadge');
        if (badge) badge.textContent = remaining + ' đơn';
    }

    // --- Shipper Rating Modal ---
    function showRatingModal(orderId, storeName) {
        Swal.fire({
            title: `Đánh giá: ${storeName}`,
            html: `
                <div class="flex flex-col gap-4 py-4">
                    <p class="text-xs text-brand-gray">Nhà hàng chuẩn bị món có nhanh và đúng yêu cầu không?</p>
                    <div class="flex justify-center gap-2 text-2xl" id="ratingStars">
                        <i class="fa-solid fa-star cursor-pointer text-slate-600 hover:text-brand-orange transition-colors" data-value="1"></i>
                        <i class="fa-solid fa-star cursor-pointer text-slate-600 hover:text-brand-orange transition-colors" data-value="2"></i>
                        <i class="fa-solid fa-star cursor-pointer text-slate-600 hover:text-brand-orange transition-colors" data-value="3"></i>
                        <i class="fa-solid fa-star cursor-pointer text-slate-600 hover:text-brand-orange transition-colors" data-value="4"></i>
                        <i class="fa-solid fa-star cursor-pointer text-slate-600 hover:text-brand-orange transition-colors" data-value="5"></i>
                    </div>
                </div>
            `,
            background: '#0f172a',
            color: '#fff',
            confirmButtonText: 'Gửi đánh giá',
            confirmButtonColor: '#f97316',
            didOpen: () => {
                const stars = document.querySelectorAll('#ratingStars i');
                let currentRating = 5;
                stars.forEach(s => {
                    if(s.dataset.value <= 5) s.classList.replace('text-slate-600', 'text-brand-orange');
                    s.onclick = () => {
                        currentRating = parseInt(s.dataset.value);
                        stars.forEach(st => {
                            if(st.dataset.value <= currentRating) st.classList.replace('text-slate-600', 'text-brand-orange');
                            else st.classList.replace('text-brand-orange', 'text-slate-600');
                        });
                    };
                });
                window._currentReviewRating = currentRating;
            },
            preConfirm: () => {
                const stars = document.querySelectorAll('#ratingStars i');
                let val = 0;
                stars.forEach(s => { if(s.classList.contains('text-brand-orange')) val = Math.max(val, parseInt(s.dataset.value)); });
                return val;
            }
        }).then(async (result) => {
            if (result.isConfirmed) {
                const rating = result.value;
                try {
                    await fetch('/Home/SubmitReview', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            OrderId: parseInt(orderId),
                            RatingStoreByShipper: parseInt(rating),
                            Type: 1 // Shipper
                        })
                    });
                    Swal.fire({ title: 'Cảm ơn!', text: 'Đánh giá của bạn đã được ghi nhận.', icon: 'success', timer: 1500, showConfirmButton: false, background: '#0f172a', color: '#fff' })
                        .then(() => window.location.reload());
                } catch (e) {
                    window.location.reload();
                }
            } else {
                window.location.reload();
            }
        });
    }
</script>
}
