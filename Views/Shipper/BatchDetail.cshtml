@model BatchOrder
@{
    Layout = "~/Views/Shared/_ShipperLayout.cshtml";
    ViewData["Title"] = $"Batch {Model.BatchCode}";
    var shipperUser = ViewBag.ShipperUser as ApplicationUser;
    var sortedItems = Model.Items.OrderBy(i => i.Sequence).ToList();
    var allPickedUp = sortedItems.All(i => i.IsPickedUp);
    var isCompleted = Model.Status == BatchOrderStatus.Completed;
}

<style>
    .detail-page { margin: -2rem; height: calc(100vh - 80px); display: flex; overflow: hidden; }
    .map-panel { flex: 1; min-width: 0; position: relative; }
    .info-panel { width: 440px; flex-shrink: 0; background: #0f172a; border-left: 1px solid rgba(255,255,255,0.06); display: flex; flex-direction: column; overflow: hidden; }
    .info-scroll { flex: 1; overflow-y: auto; padding: 1.25rem; scrollbar-width: thin; }
    #detailMap { width: 100%; height: 100%; position: absolute; left: 0; top: 0; z-index: 10; min-height: 500px; }

    .timeline-item { display: flex; gap: 1rem; margin-bottom: 0; position: relative; }
    .timeline-dot { width: 40px; height: 40px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 900; font-size: 14px; flex-shrink: 0; z-index: 2; transition: all 0.3s; }
    .timeline-line { position: absolute; left: 20px; top: 40px; width: 2px; bottom: -12px; z-index: 1; }
    .timeline-content { flex: 1; padding-bottom: 1.25rem; min-width: 0; }

    .pickup-btn { background: rgba(168,85,247,0.15); border: 1px solid rgba(168,85,247,0.3); color: #a855f7; font-weight: 800; padding: 0.5rem 1rem; border-radius: 0.6rem; cursor: pointer; font-size: 0.7rem; transition: all 0.2s; }
    .pickup-btn:hover { background: #a855f7; color: white; }
    .pickup-btn.done { background: rgba(34,197,94,0.15); border-color: rgba(34,197,94,0.3); color: #22c55e; cursor: default; }

    .complete-batch-btn { background: linear-gradient(135deg, #22c55e, #16a34a); border: none; color: white; font-weight: 900; padding: 1rem; border-radius: 0.75rem; cursor: pointer; font-size: 0.9rem; width: 100%; transition: all 0.2s; box-shadow: 0 4px 20px rgba(34,197,94,0.3); }
    .complete-batch-btn:hover { transform: translateY(-1px); box-shadow: 0 6px 30px rgba(34,197,94,0.4); }
    .complete-batch-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

    .stat-box { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); border-radius: 1rem; padding: 1rem; text-align: center; }

    .status-badge { display: inline-flex; align-items: center; gap: 0.4rem; padding: 0.3rem 0.75rem; border-radius: 999px; font-size: 0.65rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.08em; }
</style>

<div class="detail-page">

    <!-- ===== MAP ===== -->
    <div class="map-panel">
        <div id="detailMap"></div>

        <!-- Floating info -->
        <div style="position:absolute; top:1rem; right:1rem; z-index:800; background:rgba(2,6,23,0.92); backdrop-filter:blur(10px); border:1px solid rgba(168,85,247,0.3); border-radius:1rem; padding:1rem 1.25rem;">
            <div style="display:flex; align-items:center; gap:0.75rem;">
                <div style="width:2.5rem; height:2.5rem; border-radius:0.75rem; background:rgba(168,85,247,0.2); border:1px solid rgba(168,85,247,0.3); display:flex; align-items:center; justify-content:center;">
                    <i class="fa-solid fa-route" style="color:#a855f7; font-size:1rem;"></i>
                </div>
                <div>
                    <p style="font-size:1.1rem; font-weight:900; color:white; margin:0;"><span id="displayDistanceFloat">@Model.TotalDistance</span> km</p>
                    <p style="font-size:0.6rem; color:#64748b; font-weight:700; margin:0;">~<span id="displayMinutesFloat">@Model.EstimatedMinutes</span> phút · @sortedItems.Count điểm dừng</p>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== INFO PANEL ===== -->
    <div class="info-panel">
        <!-- Header -->
        <div style="padding:1.5rem 1.25rem 1rem; border-bottom:1px solid rgba(255,255,255,0.06);">
            <div style="display:flex; justify-content:space-between; align-items:flex-start;">
                <div>
                    <div style="display:flex; align-items:center; gap:0.5rem; margin-bottom:0.25rem;">
                        <a href="/Shipper/BatchOrders" style="color:#64748b; font-size:0.75rem; text-decoration:none;">
                            <i class="fa-solid fa-arrow-left" style="margin-right:0.3rem;"></i>Gom đơn
                        </a>
                    </div>
                    <h2 style="font-size:1.4rem; font-weight:900; color:white; margin:0;">@Model.BatchCode</h2>
                    <p style="font-size:0.65rem; color:#64748b; margin:0.25rem 0 0;">@Model.CreatedAt.ToString("HH:mm - dd/MM/yyyy")</p>
                </div>
                @if (isCompleted)
                {
                    <span class="status-badge" style="background:rgba(34,197,94,0.15); border:1px solid rgba(34,197,94,0.3); color:#22c55e;">
                        <i class="fa-solid fa-check-circle"></i> Hoàn thành
                    </span>
                }
                else
                {
                    <span class="status-badge" style="background:rgba(168,85,247,0.15); border:1px solid rgba(168,85,247,0.3); color:#a855f7;">
                        <i class="fa-solid fa-spinner fa-pulse"></i> Đang giao
                    </span>
                }
            </div>

            <!-- Stats -->
            <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:0.75rem; margin-top:1rem;">
                <div class="stat-box">
                    <p style="font-size:1.1rem; font-weight:900; color:#a855f7; margin:0;">@Model.TotalDistance</p>
                    <p style="font-size:0.55rem; color:#64748b; font-weight:700; text-transform:uppercase; margin:0;">Km</p>
                </div>
                <div class="stat-box">
                    <p style="font-size:1.1rem; font-weight:900; color:#22c55e; margin:0;">@Model.EstimatedMinutes</p>
                    <p style="font-size:0.55rem; color:#64748b; font-weight:700; text-transform:uppercase; margin:0;">Phút</p>
                </div>
                <div class="stat-box">
                    <p style="font-size:1.1rem; font-weight:900; color:#f97316; margin:0;">@sortedItems.Count</p>
                    <p style="font-size:0.55rem; color:#64748b; font-weight:700; text-transform:uppercase; margin:0;">Đơn hàng</p>
                </div>
            </div>
        </div>

        <!-- Timeline -->
        <div class="info-scroll">
            <p style="font-size:0.6rem; font-weight:800; color:#a855f7; text-transform:uppercase; letter-spacing:0.15em; margin:0 0 1rem;">Lộ trình tối ưu</p>

            <!-- Start point -->
            <div class="timeline-item">
                <div>
                    <div class="timeline-dot" style="background:#22c55e; color:white; border:3px solid rgba(34,197,94,0.3);">
                        <i class="fa-solid fa-flag" style="font-size:12px;"></i>
                    </div>
                    <div class="timeline-line" style="background:linear-gradient(to bottom, #22c55e, #a855f7);"></div>
                </div>
                <div class="timeline-content">
                    <p style="font-size:0.8rem; font-weight:800; color:white; margin:0;">Xuất phát</p>
                    <p style="font-size:0.65rem; color:#64748b; margin:0;">Vị trí hiện tại của bạn</p>
                </div>
            </div>

            <!-- Pickup stops -->
            @foreach (var item in sortedItems)
            {
                var isLast = item == sortedItems.Last();
                var order = item.Order;
                var storeName = order?.Store?.Name ?? "Cửa hàng";
                var storeAddr = order?.PickupAddress ?? order?.Store?.Address ?? "";
                var totalItems = order?.OrderItems?.Sum(oi => oi.Quantity) ?? 0;

                <div class="timeline-item" id="timeline-@item.Id">
                    <div>
                        <div class="timeline-dot" style="background:@(item.IsPickedUp ? "#22c55e" : "#a855f7"); color:white; border:3px solid @(item.IsPickedUp ? "rgba(34,197,94,0.3)" : "rgba(168,85,247,0.3)");">
                            @if (item.IsPickedUp) {
                                <i class="fa-solid fa-check" style="font-size:14px;"></i>
                            } else {
                                @item.Sequence
                            }
                        </div>
                        @if (!isLast) {
                            <div class="timeline-line" style="background:linear-gradient(to bottom, @(item.IsPickedUp ? "#22c55e" : "#a855f7"), @(isLast ? "#3b82f6" : "#a855f7"));"></div>
                        } else {
                            <div class="timeline-line" style="background:linear-gradient(to bottom, @(item.IsPickedUp ? "#22c55e" : "#a855f7"), #3b82f6);"></div>
                        }
                    </div>
                    <div class="timeline-content">
                        <div style="display:flex; justify-content:space-between; align-items:flex-start;">
                            <div style="flex:1; min-width:0;">
                                <p style="font-size:0.8rem; font-weight:800; color:white; margin:0;">@storeName</p>
                                <p style="font-size:0.65rem; color:#64748b; margin:0.15rem 0;">@storeAddr</p>
                                <div style="display:flex; gap:0.3rem; margin-top:0.3rem;">
                                    <span style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.08); border-radius:0.4rem; padding:0.15rem 0.4rem; font-size:0.55rem; font-weight:700; color:#cbd5e1;">
                                        @order?.OrderCode
                                    </span>
                                    <span style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.08); border-radius:0.4rem; padding:0.15rem 0.4rem; font-size:0.55rem; font-weight:700; color:#cbd5e1;">
                                        @totalItems món
                                    </span>
                                </div>
                            </div>
                            @if (!isCompleted)
                            {
                                @if (item.IsPickedUp)
                                {
                                    <button class="pickup-btn done" disabled>
                                        <i class="fa-solid fa-check" style="margin-right:3px;"></i> Đã lấy
                                    </button>
                                }
                                else
                                {
                                    <button class="pickup-btn" onclick="pickupItem(@item.Id, this)" id="pickup-btn-@item.Id">
                                        <i class="fa-solid fa-hand" style="margin-right:3px;"></i> Lấy hàng
                                    </button>
                                }
                            }
                        </div>
                        @if (item.IsPickedUp && item.PickedUpAt.HasValue)
                        {
                            <p style="font-size:0.6rem; color:#22c55e; margin:0.3rem 0 0; font-weight:600;">
                                <i class="fa-solid fa-clock" style="margin-right:3px;"></i>@item.PickedUpAt.Value.ToString("HH:mm")
                            </p>
                        }
                    </div>
                </div>
            }

            <!-- Delivery point -->
            <div class="timeline-item">
                <div>
                    <div class="timeline-dot" style="background:#3b82f6; color:white; border:3px solid rgba(59,130,246,0.3);">
                        <i class="fa-solid fa-flag-checkered" style="font-size:12px;"></i>
                    </div>
                </div>
                <div class="timeline-content">
                    <p style="font-size:0.8rem; font-weight:800; color:white; margin:0;">Điểm giao hàng</p>
                    <p style="font-size:0.65rem; color:#64748b; margin:0;">@Model.DeliveryAddress</p>
                </div>
            </div>

            @if (!isCompleted)
            {
                <div style="margin-top:1.5rem;">
                    <button class="complete-batch-btn" id="completeBatchBtn" onclick="completeBatch(@Model.Id)"
                            @(allPickedUp ? "" : "disabled")>
                        <i class="fa-solid fa-check-double" style="margin-right:0.5rem;"></i>
                        @(allPickedUp ? "Hoàn thành tất cả đơn" : $"Đã lấy {sortedItems.Count(i => i.IsPickedUp)}/{sortedItems.Count} đơn")
                    </button>
                    @if (!allPickedUp)
                    {
                        <p style="font-size:0.6rem; color:#64748b; text-align:center; margin:0.5rem 0 0; font-style:italic;">Hãy lấy hàng tất cả các điểm dừng trước khi hoàn thành.</p>
                    }
                </div>
            }
            else if (Model.CompletedAt.HasValue)
            {
                <div style="margin-top:1.5rem; background:rgba(34,197,94,0.08); border:1px solid rgba(34,197,94,0.2); border-radius:1rem; padding:1rem; text-align:center;">
                    <i class="fa-solid fa-circle-check" style="font-size:2rem; color:#22c55e; margin-bottom:0.5rem;"></i>
                    <p style="font-size:0.85rem; font-weight:800; color:#22c55e; margin:0;">Batch đã hoàn thành</p>
                    <p style="font-size:0.65rem; color:#64748b; margin:0.25rem 0 0;">@Model.CompletedAt.Value.ToString("HH:mm - dd/MM/yyyy")</p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
<script>
    const shipperLat = @((shipperUser?.Latitude ?? 10.762622).ToString(System.Globalization.CultureInfo.InvariantCulture));
    const shipperLng = @((shipperUser?.Longitude ?? 106.660172).ToString(System.Globalization.CultureInfo.InvariantCulture));

    const map = L.map('detailMap', { zoomControl: true }).setView([shipperLat, shipperLng], 13);
    L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
        attribution: '&copy; CARTO', maxZoom: 20
    }).addTo(map);

    // Shipper marker
    const shipperIcon = L.divIcon({
        html: `<div style="width:44px;height:44px;background:#a855f7;border:3px solid white;border-radius:50%;display:flex;align-items:center;justify-content:center;color:white;font-size:18px;box-shadow:0 0 24px rgba(168,85,247,0.8);"><i class="fa-solid fa-motorcycle"></i></div>`,
        className: '', iconSize: [44, 44], iconAnchor: [22, 22]
    });
    L.marker([shipperLat, shipperLng], { icon: shipperIcon }).addTo(map);

    // Draw route from saved GeoJSON
    const geoJson = @Html.Raw(Model.RouteGeometry ?? "null");
    let routesLayers = [];
    if (geoJson) {
        try {
            if (geoJson.features) {
                geoJson.features.forEach((feature, idx) => {
                    const isPrimary = idx === 0;
                    const color = isPrimary ? '#a855f7' : '#64748b';
                    const weight = isPrimary ? 6 : 4;
                    const opacity = isPrimary ? 0.85 : 0.6;

                    const layer = L.geoJSON(feature, {
                        style: { color: color, weight: weight, opacity: opacity, lineCap: 'round', lineJoin: 'round' }
                    }).addTo(map);

                    // Click to switch alternative route
                    layer.on('click', function() {
                        routesLayers.forEach(r => r.setStyle({ color: '#64748b', weight: 4, opacity: 0.6 }));
                        this.setStyle({ color: '#a855f7', weight: 6, opacity: 0.85 });
                        this.bringToFront();

                        // Update floating UI
                        const summary = feature.properties?.summary;
                        if (summary) {
                            const dDist = (summary.distance / 1000).toFixed(1);
                            const dMin = Math.round(summary.duration / 60);
                            document.getElementById('displayDistanceFloat').innerText = dDist;
                            document.getElementById('displayMinutesFloat').innerText = dMin;
                        }
                    });
                    
                    if (!isPrimary) layer.bringToBack();
                    routesLayers.push(layer);
                });
                if (routesLayers.length > 0) map.fitBounds(routesLayers[0].getBounds(), { padding: [60, 60] });
            }
        } catch(e) { console.error('GeoJSON parse error:', e); }
    }

    setTimeout(() => map.invalidateSize(), 300);

    // Draw stop markers
    @foreach (var item in sortedItems)
    {
        var order = item.Order;
        var lat = (order?.Store?.Latitude ?? 0).ToString(System.Globalization.CultureInfo.InvariantCulture);
        var lng = (order?.Store?.Longitude ?? 0).ToString(System.Globalization.CultureInfo.InvariantCulture);
        var name = order?.Store?.Name ?? "Cửa hàng";
        var picked = item.IsPickedUp;

        if (order?.Store?.Latitude != null && order?.Store?.Latitude != 0)
        {
            <text>
            (function(){
                const bg = '@(picked ? "#22c55e" : "#a855f7")';
                const icon = L.divIcon({
                    html: `<div style="width:36px;height:36px;background:${bg};border:3px solid white;border-radius:50%;display:flex;align-items:center;justify-content:center;color:white;font-size:14px;font-weight:900;box-shadow:0 0 20px ${bg === '#22c55e' ? 'rgba(34,197,94,0.6)' : 'rgba(168,85,247,0.6)'};">@(picked ? "✓" : item.Sequence.ToString())</div>`,
                    className: '', iconSize: [36, 36], iconAnchor: [18, 18]
                });
                L.marker([@lat, @lng], { icon }).addTo(map)
                    .bindPopup(`<div style="font-weight:800;font-size:12px;"><span style="color:#a855f7;">Điểm @item.Sequence:</span> @name</div>`);
            })();
            </text>
        }
    }

    // Delivery marker
    @{
        var dLat = Model.DeliveryLatitude.ToString(System.Globalization.CultureInfo.InvariantCulture);
        var dLng = Model.DeliveryLongitude.ToString(System.Globalization.CultureInfo.InvariantCulture);
    }
    @if (Model.DeliveryLatitude != 0 && Model.DeliveryLongitude != 0)
    {
        <text>
        const deliveryIcon = L.divIcon({
            html: `<div style="width:36px;height:36px;background:#3b82f6;border:3px solid white;border-radius:50%;display:flex;align-items:center;justify-content:center;color:white;font-size:14px;font-weight:900;box-shadow:0 0 20px rgba(59,130,246,0.6);"><i class="fa-solid fa-flag-checkered"></i></div>`,
            className: '', iconSize: [36, 36], iconAnchor: [18, 18]
        });
        L.marker([@dLat, @dLng], { icon: deliveryIcon }).addTo(map)
            .bindPopup(`<div style="font-weight:800;font-size:12px;"><span style="color:#3b82f6;">Điểm giao</span></div>`);
        </text>
    }

    async function pickupItem(itemId, btn) {
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';
        btn.disabled = true;

        try {
            const res = await fetch('/Shipper/PickupBatchItem', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ itemId: itemId })
            });
            const data = await res.json();

            if (data.success) {
                btn.innerHTML = '<i class="fa-solid fa-check" style="margin-right:3px;"></i> Đã lấy';
                btn.classList.add('done');
                btn.style.background = 'rgba(34,197,94,0.15)';
                btn.style.borderColor = 'rgba(34,197,94,0.3)';
                btn.style.color = '#22c55e';

                // Update timeline dot
                const timeline = document.getElementById('timeline-' + itemId);
                if (timeline) {
                    const dot = timeline.querySelector('.timeline-dot');
                    if (dot) {
                        dot.style.background = '#22c55e';
                        dot.style.borderColor = 'rgba(34,197,94,0.3)';
                        dot.innerHTML = '<i class="fa-solid fa-check" style="font-size:14px;"></i>';
                    }
                }

                if (data.allPickedUp) {
                    const completeBtn = document.getElementById('completeBatchBtn');
                    if (completeBtn) {
                        completeBtn.disabled = false;
                        completeBtn.innerHTML = '<i class="fa-solid fa-check-double" style="margin-right:0.5rem;"></i> Hoàn thành tất cả đơn';
                    }
                }
            } else {
                alert('Lỗi: ' + data.message);
                btn.innerHTML = '<i class="fa-solid fa-hand" style="margin-right:3px;"></i> Lấy hàng';
                btn.disabled = false;
            }
        } catch(e) {
            console.error(e);
            alert('Lỗi kết nối.');
            btn.innerHTML = '<i class="fa-solid fa-hand" style="margin-right:3px;"></i> Lấy hàng';
            btn.disabled = false;
        }
    }

    async function completeBatch(batchId) {
        const btn = document.getElementById('completeBatchBtn');
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin" style="margin-right:0.5rem;"></i> Đang hoàn thành...';
        btn.disabled = true;

        try {
            const res = await fetch('/Shipper/CompleteBatch', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ batchId: batchId })
            });
            const data = await res.json();

            if (data.success) {
                btn.innerHTML = '<i class="fa-solid fa-check-double" style="margin-right:0.5rem;"></i> Đã hoàn thành!';
                btn.style.opacity = '1';
                setTimeout(() => { window.location.reload(); }, 1000);
            } else {
                alert('Lỗi: ' + data.message);
                btn.innerHTML = '<i class="fa-solid fa-check-double" style="margin-right:0.5rem;"></i> Hoàn thành tất cả đơn';
                btn.disabled = false;
            }
        } catch(e) {
            console.error(e);
            btn.innerHTML = '<i class="fa-solid fa-check-double" style="margin-right:0.5rem;"></i> Hoàn thành tất cả đơn';
            btn.disabled = false;
        }
    }
</script>
}
