@model IEnumerable<Order>
@{
    Layout = "~/Views/Shared/_ShipperLayout.cshtml";
    ViewData["Title"] = "Gom đơn";
    var shipperUser = ViewBag.ShipperUser as ApplicationUser;
    bool isOnline = (bool)(ViewBag.IsOnline ?? false);
    var activeBatches = ViewBag.ActiveBatches as List<BatchOrder> ?? new List<BatchOrder>();
}

<style>
    .batch-page { margin: -2rem; height: calc(100vh - 80px); display: flex; overflow: hidden; }
    .map-panel { flex: 1; min-width: 0; position: relative; }
    .orders-panel { width: 440px; flex-shrink: 0; background: #0f172a; border-left: 1px solid rgba(255,255,255,0.06); display: flex; flex-direction: column; overflow: hidden; }
    .orders-scroll { flex: 1; overflow-y: auto; padding: 1.25rem; scrollbar-width: thin; }
    #batchMap { width: 100%; height: 100%; position: absolute; left: 0; top: 0; z-index: 10; min-height: 500px; }

    .batch-order-card { background: #020617; border: 1px solid rgba(255,255,255,0.07); border-radius: 1.25rem; padding: 1rem 1.25rem; margin-bottom: 0.75rem; cursor: pointer; transition: all 0.25s; position: relative; }
    .batch-order-card:hover { border-color: rgba(168,85,247,0.4); box-shadow: 0 0 20px rgba(168,85,247,0.08); }
    .batch-order-card.selected { border-color: #a855f7; box-shadow: 0 0 25px rgba(168,85,247,0.2); background: rgba(168,85,247,0.05); }
    .batch-order-card.selected .check-circle { background: #a855f7; border-color: #a855f7; color: white; }

    .check-circle { width: 24px; height: 24px; border-radius: 50%; border: 2px solid #334155; display: flex; align-items: center; justify-content: center; font-size: 12px; color: transparent; transition: all 0.2s; flex-shrink: 0; }

    .route-info-panel { position: absolute; bottom: 1.5rem; left: 1.5rem; right: 1.5rem; z-index: 800; background: rgba(2,6,23,0.95); backdrop-filter: blur(12px); border: 1px solid rgba(168,85,247,0.3); border-radius: 1.25rem; padding: 1.5rem; display: none; max-height: 70vh; overflow-y: auto; }
    .route-info-panel.visible { display: block; animation: slideUp 0.4s cubic-bezier(0.175,0.885,0.32,1.275); }
    @@keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

    .optimize-btn { background: linear-gradient(135deg, #a855f7, #7c3aed); border: none; color: white; font-weight: 800; padding: 0.75rem 1.5rem; border-radius: 0.75rem; cursor: pointer; font-size: 0.85rem; width: 100%; transition: all 0.2s; box-shadow: 0 4px 15px rgba(168,85,247,0.3); }
    .optimize-btn:hover { transform: translateY(-1px); box-shadow: 0 6px 25px rgba(168,85,247,0.4); }
    .optimize-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }

    .confirm-btn { background: linear-gradient(135deg, #22c55e, #16a34a); border: none; color: white; font-weight: 800; padding: 0.75rem 1.5rem; border-radius: 0.75rem; cursor: pointer; font-size: 0.85rem; width: 100%; transition: all 0.2s; box-shadow: 0 4px 15px rgba(34,197,94,0.3); margin-top: 0.5rem; }
    .confirm-btn:hover { transform: translateY(-1px); box-shadow: 0 6px 25px rgba(34,197,94,0.4); }

    .stat-pill { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08); border-radius: 0.75rem; padding: 0.75rem 1rem; text-align: center; }

    .active-batch-card { background: rgba(168,85,247,0.08); border: 1px solid rgba(168,85,247,0.25); border-radius: 1rem; padding: 1rem; margin-bottom: 0.75rem; cursor: pointer; transition: all 0.2s; }
    .active-batch-card:hover { border-color: #a855f7; transform: translateY(-1px); }

    .map-overlay-badge { position: absolute; top: 1rem; right: 1rem; z-index: 800; background: rgba(2,6,23,0.9); backdrop-filter: blur(8px); border: 1px solid rgba(168,85,247,0.3); border-radius: 0.75rem; padding: 0.6rem 1rem; display: flex; align-items: center; gap: 0.5rem; }

    .route-step { display: flex; align-items: center; gap: 0.6rem; padding: 0.5rem 0; border-bottom: 1px solid rgba(255,255,255,0.04); position: relative; }
    .route-step:last-child { border-bottom: none; }
    .route-step-num { width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 900; font-size: 12px; flex-shrink: 0; }
    .route-step-dist { position: absolute; top: -6px; right: 0; background: rgba(168,85,247,0.15); border: 1px solid rgba(168,85,247,0.25); color: #a855f7; font-size: 0.55rem; font-weight: 800; padding: 0.1rem 0.4rem; border-radius: 999px; }

    .savings-badge { background: linear-gradient(135deg, rgba(34,197,94,0.15), rgba(16,163,74,0.1)); border: 1px solid rgba(34,197,94,0.3); border-radius: 0.75rem; padding: 0.5rem 0.75rem; display: flex; align-items: center; gap: 0.5rem; margin-top: 0.75rem; }
</style>

<div class="batch-page">

    <!-- ===== MAP PANEL ===== -->
    <div class="map-panel">
        <div id="batchMap"></div>

        <!-- Floating badge -->
        <div class="map-overlay-badge">
            <i class="fa-solid fa-layer-group" style="color:#a855f7; font-size:0.8rem;"></i>
            <span style="font-size:0.7rem; font-weight:800; color:#a855f7; text-transform:uppercase; letter-spacing:0.1em;">Gom đơn</span>
            <span style="font-size:0.7rem; color:#64748b; font-weight:600;" id="selectedCountBadge">| 0 đã chọn</span>
        </div>

        <!-- Route Info Panel (hiện sau khi optimize) -->
        <div class="route-info-panel" id="routeInfoPanel">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1rem;">
                <div style="display:flex; align-items:center; gap:0.75rem;">
                    <div style="width:2.5rem; height:2.5rem; border-radius:0.75rem; background:rgba(168,85,247,0.2); border:1px solid rgba(168,85,247,0.3); display:flex; align-items:center; justify-content:center;">
                        <i class="fa-solid fa-route" style="color:#a855f7;"></i>
                    </div>
                    <div>
                        <h3 style="font-size:1rem; font-weight:900; color:white; margin:0;">Lộ trình tối ưu</h3>
                        <p style="font-size:0.6rem; color:#64748b; font-weight:600; margin:0;">Quãng đường ngắn nhất (<span id="algorithmUsed">OpenRouteService</span>)</p>
                    </div>
                </div>
                <button onclick="closeRoutePanel()" style="width:2rem; height:2rem; border-radius:50%; background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.1); color:white; cursor:pointer; display:flex; align-items:center; justify-content:center; font-size:0.75rem;">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>

            <div style="display:grid; grid-template-columns:1fr 1fr 1fr; gap:0.75rem; margin-bottom:1rem;">
                <div class="stat-pill">
                    <p style="font-size:1.25rem; font-weight:900; color:#a855f7; margin:0;" id="routeDistance">--</p>
                    <p style="font-size:0.6rem; color:#64748b; font-weight:700; text-transform:uppercase; margin:0;">Km</p>
                </div>
                <div class="stat-pill">
                    <p style="font-size:1.25rem; font-weight:900; color:#22c55e; margin:0;" id="routeTime">--</p>
                    <p style="font-size:0.6rem; color:#64748b; font-weight:700; text-transform:uppercase; margin:0;">Phút</p>
                </div>
                <div class="stat-pill">
                    <p style="font-size:1.25rem; font-weight:900; color:#f97316; margin:0;" id="routeStops">--</p>
                    <p style="font-size:0.6rem; color:#64748b; font-weight:700; text-transform:uppercase; margin:0;">Điểm dừng</p>
                </div>
            </div>

            <!-- Savings badge -->
            <div class="savings-badge" id="savingsBadge" style="display:none;">
                <i class="fa-solid fa-leaf" style="color:#22c55e; font-size:0.8rem;"></i>
                <span style="font-size:0.7rem; color:#22c55e; font-weight:800;" id="savingsText">Tiết kiệm 2.3km so với đi tuần tự</span>
            </div>

            <!-- Route steps -->
            <div id="routeStepsList" style="max-height: 200px; overflow-y: auto; margin: 1rem 0;"></div>

            <button class="confirm-btn" id="confirmBatchBtn" onclick="confirmBatch()">
                <i class="fa-solid fa-check-double" style="margin-right:0.4rem;"></i> Xác nhận gom đơn
            </button>
        </div>
    </div>

    <!-- ===== ORDERS PANEL ===== -->
    <div class="orders-panel">
        <!-- Header -->
        <div style="padding:1.5rem 1.25rem 1rem; border-bottom:1px solid rgba(255,255,255,0.06);">
            <div style="display:flex; justify-content:space-between; align-items:center;">
                <div>
                    <h2 style="font-size:1.25rem; font-weight:900; color:white; margin:0;">
                        <i class="fa-solid fa-layer-group" style="color:#a855f7; margin-right:0.5rem;"></i>Gom Đơn
                    </h2>
                    <p style="font-size:0.65rem; color:#64748b; font-weight:700; text-transform:uppercase; letter-spacing:0.12em; margin:0.25rem 0 0;">Chọn nhiều đơn → tối ưu quãng đường ngắn nhất</p>
                </div>
                <div style="background:rgba(168,85,247,0.1); border:1px solid rgba(168,85,247,0.25); border-radius:999px; padding:0.4rem 1rem;">
                    <span style="font-size:0.85rem; font-weight:900; color:#a855f7;" id="totalOrdersCount">@Model.Count() đơn</span>
                </div>
            </div>
        </div>

        <!-- Active Batches -->
        @if (activeBatches.Any())
        {
            <div style="padding:1rem 1.25rem 0;">
                <p style="font-size:0.6rem; font-weight:800; color:#a855f7; text-transform:uppercase; letter-spacing:0.15em; margin:0 0 0.5rem;">Batch đang hoạt động</p>
                @foreach (var batch in activeBatches)
                {
                    <a href="/Shipper/BatchDetail/@batch.Id" class="active-batch-card" style="display:block; text-decoration:none; color:white;">
                        <div style="display:flex; justify-content:space-between; align-items:center;">
                            <div>
                                <p style="font-size:0.8rem; font-weight:900; color:#a855f7; margin:0;">@batch.BatchCode</p>
                                <p style="font-size:0.65rem; color:#64748b; margin:0;">@batch.Items.Count đơn · @batch.TotalDistance km · @batch.EstimatedMinutes phút</p>
                            </div>
                            <i class="fa-solid fa-chevron-right" style="color:#64748b; font-size:0.7rem;"></i>
                        </div>
                    </a>
                }
            </div>
        }

        <!-- Optimize Button -->
        <div style="padding:0.75rem 1.25rem;">
            <button class="optimize-btn" id="optimizeBtn" onclick="optimizeRoute()" disabled>
                <i class="fa-solid fa-wand-magic-sparkles" style="margin-right:0.4rem;"></i> Tối ưu lộ trình (<span id="selectedCount">0</span> đơn)
            </button>
        </div>

        <!-- Order List -->
        <div class="orders-scroll">
            @if (!isOnline)
            {
                <div style="display:flex; flex-direction:column; align-items:center; justify-content:center; height:100%; padding:3rem 1rem; text-align:center;">
                    <div style="width:5rem; height:5rem; border-radius:50%; background:rgba(239,68,68,0.1); border:1px solid rgba(239,68,68,0.2); display:flex; align-items:center; justify-content:center; margin-bottom:1rem;">
                        <i class="fa-solid fa-power-off" style="font-size:1.75rem; color:#ef4444;"></i>
                    </div>
                    <h4 style="font-size:1rem; font-weight:900; color:white; margin:0 0 0.5rem;">Bạn đang ngoại tuyến</h4>
                    <p style="font-size:0.75rem; color:#64748b;">Vui lòng bật trạng thái trực tuyến để xem đơn hàng.</p>
                </div>
            }
            else if (Model.Any())
            {
                @foreach (var order in Model)
                {
                    var sLat = (order.Store?.Latitude ?? 0).ToString(System.Globalization.CultureInfo.InvariantCulture);
                    var sLng = (order.Store?.Longitude ?? 0).ToString(System.Globalization.CultureInfo.InvariantCulture);
                    var itemCount = order.OrderItems?.Sum(oi => oi.Quantity) ?? 0;
                    <div class="batch-order-card" id="bcard-@order.OrderCode"
                         data-code="@order.OrderCode"
                         data-store-lat="@sLat"
                         data-store-lng="@sLng"
                         data-store-name="@(order.Store?.Name ?? "Cửa hàng")"
                         data-delivery-addr="@order.DeliveryAddress"
                         data-delivery-lat="@order.DeliveryLatitude.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                         data-delivery-lng="@order.DeliveryLongitude.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                         onclick="toggleSelect(this)">

                        <div style="display:flex; align-items:flex-start; gap:0.75rem;">
                            <div class="check-circle">
                                <i class="fa-solid fa-check"></i>
                            </div>
                            <div style="flex:1; min-width:0;">
                                <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:0.5rem;">
                                    <p style="font-size:0.8rem; font-weight:900; color:#a855f7; margin:0;">@order.OrderCode</p>
                                    <p style="font-size:0.9rem; font-weight:900; color:white; margin:0;">@string.Format("{0:N0}", order.ShipperIncome) <span style="font-size:0.6rem; color:#64748b;">VND</span></p>
                                </div>

                                <div style="display:flex; align-items:center; gap:0.4rem; margin-bottom:0.3rem;">
                                    <div style="width:8px; height:8px; border-radius:50%; background:#f97316; flex-shrink:0;"></div>
                                    <p style="font-size:0.7rem; font-weight:700; color:white; margin:0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">@(order.Store?.Name ?? "Cửa hàng")</p>
                                </div>
                                <div style="display:flex; align-items:center; gap:0.4rem;">
                                    <div style="width:8px; height:8px; border-radius:50%; background:#3b82f6; flex-shrink:0;"></div>
                                    <p style="font-size:0.65rem; color:#64748b; margin:0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">@order.DeliveryAddress</p>
                                </div>

                                <div style="display:flex; gap:0.3rem; margin-top:0.5rem; flex-wrap:wrap;">
                                    <span style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.08); border-radius:0.4rem; padding:0.2rem 0.5rem; font-size:0.6rem; font-weight:700; color:#cbd5e1;">
                                        <i class="fa-solid fa-route" style="color:#a855f7; margin-right:3px;"></i>@(order.Distance > 0 ? $"{order.Distance:F1}km" : "~1km")
                                    </span>
                                    <span style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.08); border-radius:0.4rem; padding:0.2rem 0.5rem; font-size:0.6rem; font-weight:700; color:#cbd5e1;">
                                        <i class="fa-solid fa-box" style="color:#a855f7; margin-right:3px;"></i>@itemCount món
                                    </span>
                                    <span style="background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.08); border-radius:0.4rem; padding:0.2rem 0.5rem; font-size:0.6rem; font-weight:700; color:#cbd5e1;">
                                        <i class="fa-solid fa-money-bill" style="color:#22c55e; margin-right:3px;"></i>@string.Format("{0:N0}đ", order.ShippingFee) phí ship
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div style="display:flex; flex-direction:column; align-items:center; justify-content:center; height:100%; padding:3rem 1rem; text-align:center;">
                    <div style="width:5rem; height:5rem; border-radius:50%; background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08); display:flex; align-items:center; justify-content:center; margin-bottom:1rem;">
                        <i class="fa-solid fa-satellite-dish" style="font-size:1.75rem; color:#334155;"></i>
                    </div>
                    <h4 style="font-size:1rem; font-weight:900; color:white; margin:0 0 0.5rem;">Chưa có đơn</h4>
                    <p style="font-size:0.75rem; color:#64748b;">Chưa có đơn hàng nào đang chờ.</p>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
<script>
    const shipperLat = @((shipperUser?.Latitude ?? 10.762622).ToString(System.Globalization.CultureInfo.InvariantCulture));
    const shipperLng = @((shipperUser?.Longitude ?? 106.660172).ToString(System.Globalization.CultureInfo.InvariantCulture));

    // --- Map Init ---
    const map = L.map('batchMap', { zoomControl: true }).setView([shipperLat, shipperLng], 13);

    L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
        attribution: '&copy; <a href="https://carto.com/">CARTO</a>',
        maxZoom: 20
    }).addTo(map);

    // Shipper marker
    const shipperIcon = L.divIcon({
        html: `<div style="width:44px;height:44px;background:#a855f7;border:3px solid white;border-radius:50%;display:flex;align-items:center;justify-content:center;color:white;font-size:18px;box-shadow:0 0 24px rgba(168,85,247,0.8);"><i class="fa-solid fa-motorcycle"></i></div>`,
        className: '', iconSize: [44, 44], iconAnchor: [22, 22]
    });
    L.marker([shipperLat, shipperLng], { icon: shipperIcon })
        .addTo(map)
        .bindPopup(`<div style="font-weight:800;color:#a855f7;font-size:13px;">📍 Vị trí của bạn</div>`)
        .openPopup();

    // State
    const selectedOrders = new Set();
    const storeMarkers = {};
    let routeLayer = null;
    let sequenceMarkers = [];
    let currentBatchData = null;

    // Add store markers for all orders
    document.querySelectorAll('.batch-order-card').forEach(card => {
        const code = card.dataset.code;
        const lat = parseFloat(card.dataset.storeLat);
        const lng = parseFloat(card.dataset.storeLng);
        const name = card.dataset.storeName;
        if (lat && lng) {
            addStoreMarker(code, lat, lng, name, false);
        }
    });

    function addStoreMarker(code, lat, lng, name, isSelected) {
        if (storeMarkers[code]) map.removeLayer(storeMarkers[code]);
        const bg = isSelected ? '#a855f7' : '#334155';
        const shadow = isSelected ? 'rgba(168,85,247,0.6)' : 'transparent';
        const icon = L.divIcon({
            html: `<div style="width:32px;height:32px;background:${bg};border:2px solid white;border-radius:50%;display:flex;align-items:center;justify-content:center;color:white;font-size:12px;box-shadow:0 0 12px ${shadow};transition:all 0.3s;"><i class="fa-solid fa-store"></i></div>`,
            className: '', iconSize: [32, 32], iconAnchor: [16, 16]
        });
        storeMarkers[code] = L.marker([lat, lng], { icon }).addTo(map)
            .bindPopup(`<div style="font-weight:800;font-size:12px;">${name}</div>`);
    }

    function toggleSelect(card) {
        const code = card.dataset.code;
        const lat = parseFloat(card.dataset.storeLat);
        const lng = parseFloat(card.dataset.storeLng);
        const name = card.dataset.storeName;

        if (selectedOrders.has(code)) {
            selectedOrders.delete(code);
            card.classList.remove('selected');
            addStoreMarker(code, lat, lng, name, false);
        } else {
            selectedOrders.add(code);
            card.classList.add('selected');
            addStoreMarker(code, lat, lng, name, true);
        }

        updateSelectedCount();
        clearRoute();
    }

    function updateSelectedCount() {
        const count = selectedOrders.size;
        document.getElementById('selectedCount').textContent = count;
        document.getElementById('selectedCountBadge').textContent = `| ${count} đã chọn`;
        document.getElementById('optimizeBtn').disabled = count < 2;
    }

    function clearRoute() {
        if (routeLayer) { map.removeLayer(routeLayer); routeLayer = null; }
        sequenceMarkers.forEach(m => map.removeLayer(m));
        sequenceMarkers = [];
        document.getElementById('routeInfoPanel').classList.remove('visible');
        currentBatchData = null;
    }

    function closeRoutePanel() {
        document.getElementById('routeInfoPanel').classList.remove('visible');
    }

    // Tính tổng khoảng cách nếu đi tuần tự (không tối ưu)
    function calcNaiveTotalDistance(stops) {
        let total = 0;
        let pLat = shipperLat, pLng = shipperLng;
        // Đi theo thứ tự gốc (không tối ưu)
        const orderCards = Array.from(document.querySelectorAll('.batch-order-card.selected'));
        orderCards.forEach(card => {
            const lat = parseFloat(card.dataset.storeLat);
            const lng = parseFloat(card.dataset.storeLng);
            total += haversine(pLat, pLng, lat, lng);
            pLat = lat; pLng = lng;
        });
        // + delivery
        if (stops.length > 0) {
            const last = stops[stops.length - 1];
            total += haversine(last.lat, last.lng, parseFloat(orderCards[0]?.dataset.deliveryLat || 0), parseFloat(orderCards[0]?.dataset.deliveryLng || 0));
        }
        return total;
    }

    function haversine(lat1, lon1, lat2, lon2) {
        const R = 6371;
        const dLat = (lat2 - lat1) * Math.PI / 180;
        const dLon = (lon2 - lon1) * Math.PI / 180;
        const a = Math.sin(dLat/2)**2 + Math.cos(lat1*Math.PI/180)*Math.cos(lat2*Math.PI/180)*Math.sin(dLon/2)**2;
        return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
    }

    async function optimizeRoute() {
        const btn = document.getElementById('optimizeBtn');
        btn.disabled = true;
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin" style="margin-right:0.4rem;"></i> Đang tối ưu quãng đường...';

        const orderCodes = Array.from(selectedOrders);

        try {
            const res = await fetch('/Shipper/CreateBatch', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    orderCodes: orderCodes,
                    deliveryAddress: '',
                    deliveryLat: 0,
                    deliveryLng: 0
                })
            });

            const data = await res.json();

            if (!data.success) {
                alert('Lỗi: ' + data.message);
                btn.disabled = false;
                btn.innerHTML = '<i class="fa-solid fa-wand-magic-sparkles" style="margin-right:0.4rem;"></i> Tối ưu lộ trình (<span id="selectedCount">' + selectedOrders.size + '</span> đơn)';
                return;
            }

            currentBatchData = data;

            // Draw route on map
            clearRoute();

            if (data.routeGeoJson) {
                try {
                    const geoJson = typeof data.routeGeoJson === 'string' ? JSON.parse(data.routeGeoJson) : data.routeGeoJson;
                    if (!routeLayer) routeLayer = L.layerGroup().addTo(map);

                    if (geoJson.features) {
                        geoJson.features.forEach((feature, idx) => {
                            const isPrimary = idx === 0;
                            const color = isPrimary ? '#a855f7' : '#64748b';
                            const weight = isPrimary ? 6 : 4;
                            const opacity = isPrimary ? 0.85 : 0.5;

                            const layer = L.geoJSON(feature, {
                                style: { color: color, weight: weight, opacity: opacity, lineCap: 'round', lineJoin: 'round' }
                            }).addTo(routeLayer);

                            layer.on('click', function() {
                                routeLayer.eachLayer(l => l.setStyle({ color: '#64748b', weight: 4, opacity: 0.5 }));
                                this.setStyle({ color: '#a855f7', weight: 6, opacity: 0.85 });
                                this.bringToFront();

                                const summary = feature.properties?.summary;
                                if (summary) {
                                    document.getElementById('routeDistance').textContent = (summary.distance / 1000).toFixed(1);
                                    document.getElementById('routeTime').textContent = Math.round(summary.duration / 60);
                                }
                            });
                            
                            if (!isPrimary) layer.bringToBack();
                        });
                        
                        if (routeLayer.getLayers().length > 0) {
                            map.fitBounds(L.featureGroup(routeLayer.getLayers()).getBounds(), { padding: [60, 60] });
                        }
                    }
                } catch(e) { console.error('GeoJSON error:', e); }
            }

            // Add sequence markers with animated appearance
            const stops = data.stops;
            stops.sort((a, b) => a.sequence - b.sequence);

            stops.forEach((stop, i) => {
                setTimeout(() => {
                    const seqIcon = L.divIcon({
                        html: `<div style="width:38px;height:38px;background:linear-gradient(135deg,#a855f7,#7c3aed);border:3px solid white;border-radius:50%;display:flex;align-items:center;justify-content:center;color:white;font-size:14px;font-weight:900;box-shadow:0 0 20px rgba(168,85,247,0.6);animation:popIn 0.3s cubic-bezier(0.175,0.885,0.32,1.275);">${stop.sequence}</div>`,
                        className: '', iconSize: [38, 38], iconAnchor: [19, 19]
                    });
                    const marker = L.marker([stop.lat, stop.lng], { icon: seqIcon })
                        .addTo(map)
                        .bindPopup(`<div style="font-weight:800;font-size:12px;"><span style="color:#a855f7;">Điểm ${stop.sequence}:</span> ${stop.storeName}${stop.distanceFromPrev ? '<br><span style="color:#64748b;font-size:11px;">+' + stop.distanceFromPrev.toFixed(1) + 'km từ điểm trước</span>' : ''}</div>`);
                    sequenceMarkers.push(marker);
                }, i * 150);
            });

            // Update info panel
            document.getElementById('routeDistance').textContent = data.totalDistance;
            document.getElementById('routeTime').textContent = Math.round(data.estimatedMinutes);
            document.getElementById('routeStops').textContent = stops.length;

            // Tính savings so với đi tuần tự
            const naiveDist = calcNaiveTotalDistance(stops);
            if (naiveDist > 0 && naiveDist > data.totalDistance) {
                const saved = (naiveDist - data.totalDistance).toFixed(1);
                document.getElementById('savingsText').textContent = `Tiết kiệm ${saved}km so với đi tuần tự`;
                document.getElementById('savingsBadge').style.display = 'flex';
            } else {
                document.getElementById('savingsBadge').style.display = 'none';
            }

            // Build steps list with distance per segment
            let stepsHtml = '';
            stepsHtml += `<div class="route-step">
                <div class="route-step-num" style="background:#22c55e; color:white;"><i class="fa-solid fa-flag" style="font-size:10px;"></i></div>
                <div style="flex:1;min-width:0;">
                    <p style="font-size:0.75rem; font-weight:700; color:white; margin:0;">Vị trí hiện tại (Xuất phát)</p>
                    <p style="font-size:0.6rem; color:#64748b; margin:0;">Bắt đầu lộ trình</p>
                </div>
            </div>`;

            stops.forEach(stop => {
                stepsHtml += `<div class="route-step">
                    <div class="route-step-num" style="background:linear-gradient(135deg,#a855f7,#7c3aed); color:white;">${stop.sequence}</div>
                    <div style="flex:1;min-width:0;">
                        <p style="font-size:0.75rem; font-weight:700; color:white; margin:0; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;">${stop.storeName}</p>
                        <p style="font-size:0.6rem; color:#64748b; margin:0;">Lấy hàng</p>
                    </div>
                    ${stop.distanceFromPrev ? `<span class="route-step-dist">+${stop.distanceFromPrev.toFixed(1)}km</span>` : ''}
                </div>`;
            });

            stepsHtml += `<div class="route-step">
                <div class="route-step-num" style="background:#3b82f6; color:white;"><i class="fa-solid fa-flag-checkered" style="font-size:10px;"></i></div>
                <div style="flex:1;min-width:0;">
                    <p style="font-size:0.75rem; font-weight:700; color:white; margin:0;">Điểm giao hàng</p>
                    <p style="font-size:0.6rem; color:#64748b; margin:0;">Hoàn thành giao hàng</p>
                </div>
            </div>`;

            document.getElementById('routeStepsList').innerHTML = stepsHtml;
            document.getElementById('routeInfoPanel').classList.add('visible');

            // Success button
            btn.innerHTML = '<i class="fa-solid fa-check" style="margin-right:0.4rem;"></i> Đã tạo batch thành công!';
            btn.style.background = 'linear-gradient(135deg, #22c55e, #16a34a)';

        } catch (e) {
            console.error(e);
            alert('Đã xảy ra lỗi. Vui lòng thử lại.');
            btn.disabled = false;
            btn.innerHTML = '<i class="fa-solid fa-wand-magic-sparkles" style="margin-right:0.4rem;"></i> Tối ưu lộ trình (<span id="selectedCount">' + selectedOrders.size + '</span> đơn)';
        }
    }

    function confirmBatch() {
        if (currentBatchData && currentBatchData.batchId) {
            window.location.href = '/Shipper/BatchDetail/' + currentBatchData.batchId;
        }
    }

    // Add CSS animation for markers
    const style = document.createElement('style');
    style.textContent = '@@keyframes popIn { from { transform: scale(0); opacity: 0; } to { transform: scale(1); opacity: 1; } }';
    document.head.appendChild(style);
</script>
}
