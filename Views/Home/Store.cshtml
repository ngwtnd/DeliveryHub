@model DeliveryHubWeb.Models.Store

@{
    ViewData["Title"] = Model.Name;
    var totalSoldDict = ViewBag.ItemSoldDict as Dictionary<int, int> ?? new Dictionary<int, int>();
    var itemRatingsDict = ViewBag.ItemRatingsDict as Dictionary<int, double> ?? new Dictionary<int, double>();

    var productsList = Model.MenuItems.Where(m => m.IsAvailable).Select(m => new {
        id = m.Id,
        categoryId = m.Category?.ToLower() ?? "other",
        name = m.Name,
        price = m.Price,
        description = m.Description,
        image = string.IsNullOrEmpty(m.ImageUrl) ? "https://images.unsplash.com/photo-1568901346375-23c9450c58cd?q=80&w=600&auto=format&fit=crop" : m.ImageUrl,
        rating = itemRatingsDict.ContainsKey(m.Id) ? itemRatingsDict[m.Id] : 5.0,
        totalSold = totalSoldDict.ContainsKey(m.Id) ? totalSoldDict[m.Id] : 0
    }).ToList();

    var productsJson = System.Text.Json.JsonSerializer.Serialize(productsList);
}

<!-- Store Hero Section -->
<section class="pt-32 pb-16 px-6 md:px-12 bg-brand-black relative">
    <div class="max-w-[1440px] mx-auto relative z-10">
        <div class="h-[300px] md:h-[400px] w-full rounded-[3rem] overflow-hidden relative shadow-2xl border border-gray-800">
            <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-black/10 z-10"></div>
            <img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? "https://images.unsplash.com/photo-1555396273-367ea4eb4db5?q=80&w=1200&auto=format&fit=crop" : Model.ImageUrl)" 
                 alt="@Model.Name" 
                 class="w-full h-full object-cover">
            
            <div class="absolute bottom-0 left-0 right-0 p-8 md:p-12 z-20 flex flex-col md:flex-row justify-between items-end gap-6">
                <div>
                    <h1 class="text-4xl md:text-6xl font-black text-white mb-4">@Model.Name</h1>
                    <p class="text-xl text-brand-gray flex items-center gap-2">
                        <i class="fa-solid fa-location-dot text-brand-orange"></i> @(Model.Address ?? "TP. Hồ Chí Minh")
                    </p>
                </div>
                
                <div class="flex gap-4">
                    <div class="bg-gray-900/80 backdrop-blur-md rounded-2xl p-4 border border-white/10 text-center min-w-[100px]">
                        <div class="text-brand-orange text-2xl font-black mb-1"><i class="fa-solid fa-star"></i> @ViewBag.RealRating</div>
                        <div class="text-[10px] uppercase tracking-widest text-brand-gray font-bold">@ViewBag.ReviewCount Đánh giá</div>
                    </div>
                    <div class="bg-gray-900/80 backdrop-blur-md rounded-2xl p-4 border border-white/10 text-center min-w-[100px]">
                        <div class="text-white text-2xl font-black mb-1"><i class="fa-solid fa-fire text-brand-orange"></i> @ViewBag.TotalSold</div>
                        <div class="text-[10px] uppercase tracking-widest text-brand-gray font-bold">Đã bán</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Menu Section -->
<section id="menu" class="py-16 px-6 md:px-12 bg-brand-dark z-10 relative">
    <div class="max-w-[1440px] mx-auto">
        <div class="flex flex-col md:flex-row md:items-end justify-between mb-10 border-b border-gray-800 pb-4 gap-6">
            <h2 class="text-3xl md:text-4xl font-bold">Thực đơn <span class="text-brand-orange">của quán</span></h2>
            
            <!-- Category Filter / Navigation -->
            @{
                var allCategories = new List<string>();
                if (!string.IsNullOrEmpty(Model.CustomCategories))
                {
                    allCategories = Model.CustomCategories.Split(',', StringSplitOptions.RemoveEmptyEntries)
                                                          .Select(c => c.Trim()).ToList();
                }
                var menuCategories = Model.MenuItems.Where(m => m.IsAvailable).Select(m => m.Category ?? "Khác").Distinct().ToList();
                allCategories = allCategories.Union(menuCategories).Where(c => !string.IsNullOrEmpty(c)).ToList();
            }

            @if (allCategories.Any())
            {
                <div class="flex overflow-x-auto gap-2 pb-2 custom-scrollbar snap-x">
                    @foreach (var cat in allCategories)
                    {
                        var itemsCount = Model.MenuItems.Count(m => m.Category == cat && m.IsAvailable);
                        if (itemsCount > 0)
                        {
                            <a href="#cat-@cat.Replace(" ", "-")" class="snap-start flex-shrink-0 px-5 py-2.5 rounded-full bg-gray-900 border border-gray-800 text-sm font-bold text-white hover:border-brand-orange hover:text-brand-orange transition-all">
                                @cat
                            </a>
                        }
                    }
                </div>
            }
        </div>

        @foreach (var cat in allCategories)
        {
            var itemsInCat = Model.MenuItems.Where(m => m.Category == cat && m.IsAvailable).ToList();
            if (itemsInCat.Any())
            {
                <div id="cat-@cat.Replace(" ", "-")" class="mb-14 pt-4">
                    <div class="flex items-center mb-6">
                        <h4 class="text-xl font-black text-white uppercase tracking-wider mr-4">@cat</h4>
                        <div class="h-px flex-1 bg-gradient-to-r from-gray-800 to-transparent"></div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                        @foreach (var item in itemsInCat)
                        {
                            var priceFormatted = item.Price.ToString("N0") + " đ";
                            var rating = itemRatingsDict.ContainsKey(item.Id) ? itemRatingsDict[item.Id] : 5.0;
                            var sold = totalSoldDict.ContainsKey(item.Id) ? totalSoldDict[item.Id] : 0;
                            var imgUrl = string.IsNullOrEmpty(item.ImageUrl) ? "https://images.unsplash.com/photo-1568901346375-23c9450c58cd?q=80&w=600&auto=format&fit=crop" : item.ImageUrl;
                            var jsonProduct = System.Text.Json.JsonSerializer.Serialize(new { 
                                id = item.Id, name = item.Name, price = item.Price, image = imgUrl 
                            });

                            <div class="product-card-container section-title">
                                <div class="product-card bg-brand-black rounded-2xl p-4 h-full flex flex-col border border-gray-800 relative z-10 overflow-visible transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_15px_30px_rgba(0,0,0,0.6)] hover:border-gray-600">
                                    <div class="flex-1 min-h-[12rem] w-full mb-4 rounded-xl overflow-hidden relative">
                                        <div class="absolute top-2 right-2 bg-black/60 backdrop-blur-md text-white text-xs font-bold px-2 py-1 rounded-md z-40 flex items-center gap-1 border border-white/10">
                                            <i class="fa-solid fa-star text-brand-orange text-[10px]"></i> @rating.ToString("0.0")
                                        </div>
                                        <img src="@imgUrl" alt="@item.Name" class="absolute inset-0 w-full h-full object-cover opacity-90 transition-transform duration-500 hover:scale-105">
                                    </div>
                                    <div class="px-2 pb-2 mt-auto">
                                        <h3 class="font-bold text-xl mb-1 truncate text-white">@item.Name</h3>
                                        <p class="text-brand-gray text-xs mb-4 line-clamp-2">@item.Description</p>
                                        
                                        <div class="flex items-center justify-between pt-4 border-t border-gray-800/80">
                                            <div>
                                                <span class="text-brand-orange font-black text-xl tracking-tight">@priceFormatted</span>
                                                <div class="text-[10px] text-brand-gray font-bold line-clamp-1 mt-0.5"><i class="fa-solid fa-fire text-brand-orange/70"></i> Đã mua: @sold</div>
                                            </div>
                                            <!-- Setup item tracking to global products array for add to cart feature -->
                                            <button onclick='window.products = window.products || []; if(!window.products.find(p => p.id == @item.Id)) window.products.push(@Html.Raw(jsonProduct)); addToCart(@item.Id)' class="w-10 h-10 rounded-full bg-brand-orange text-black flex items-center justify-center hover:bg-brand-orange min-w-[40px] hover:shadow-[0_0_15px_rgba(255,107,0,0.5)] transition-all shrink-0">
                                                <i class="fa-solid fa-plus font-black"></i>
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        }
    </div>
</section>

@section Scripts {
    <script>
        // Smooth scroll for category anchors
        document.querySelectorAll('a[href^="#cat-"]').forEach(anchor => {
            anchor.addEventListener('click', function (e) {
                e.preventDefault();
                const target = document.querySelector(this.getAttribute('href'));
                if (target) {
                    const offset = 100; // Account for sticky header
                    const elementPosition = target.getBoundingClientRect().top;
                    const offsetPosition = elementPosition + window.pageYOffset - offset;
                    window.scrollTo({
                        top: offsetPosition,
                        behavior: 'smooth'
                    });
                }
            });
        });
    </script>
}
