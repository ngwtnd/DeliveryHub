@{
    ViewData["Title"] = "Giao ngay, ngon tức khắc";
}

<!-- Hero Section -->
<section id="hero" class="relative min-h-screen flex items-center pt-32 pb-20 px-6 md:px-12 overflow-hidden">
    <div class="relative z-10 w-full max-w-[1440px] mx-auto flex flex-col md:flex-row items-center gap-12">
        <div class="md:w-1/2 flex flex-col gap-6" id="hero-content">
            <h1 class="text-5xl md:text-7xl font-extrabold leading-tight">
                Giao ngay <br>
                <span class="text-transparent bg-clip-text bg-gradient-to-r from-brand-orange to-yellow-400">Ngon
                    tức khắc</span>
            </h1>
            <p class="text-brand-gray text-lg md:text-xl max-w-md">
                Thưởng thức những món ăn tuyệt hảo nhất được giao tận cửa nhà bạn chỉ trong tích tắc. Trải nghiệm
                dịch vụ đẳng cấp ngay hôm nay!
            </p>

            <!-- Search box -->
            <div class="relative mt-4 max-w-sm">
                <input type="text" id="searchInput" placeholder="Tìm món ăn..."
                    class="w-full bg-brand-dark border border-gray-700 text-white rounded-full py-3 px-6 pr-12 focus:outline-none focus:border-brand-orange transition-colors">
                <button class="absolute right-4 top-1/2 -translate-y-1/2 text-brand-orange">
                    <i class="fa-solid fa-search"></i>
                </button>
            </div>

            <div class="flex gap-4 mt-4">
                <a href="#menu"
                    class="px-8 py-3 bg-brand-orange text-black font-bold rounded-full hover:shadow-[0_0_20px_rgba(255,107,0,0.6)] transition-all inline-block w-max text-decoration-none">Đặt
                    ngay</a>
                <a href="#categories"
                    class="px-8 py-3 border border-white text-white font-bold rounded-full hover:bg-white hover:text-black transition-all inline-block w-max text-decoration-none">Xem
                    thực đơn</a>
            </div>
        </div>

        <div class="md:w-1/2 relative flex justify-center items-center" id="hero-image-wrapper">
            <div class="w-full h-[400px] md:h-[600px] relative floating-element flex items-center justify-center rounded-[3rem] overflow-hidden">
                <img src="~/images/hero/burger-1.jpg" alt="Hero Burger" class="w-full h-full object-cover burger-glow">
            </div>
        </div>
    </div>
</section>

<!-- Top Branches Section -->
<section id="top-branches" class="py-24 px-6 md:px-12 bg-brand-dark z-10 relative border-t border-gray-900 border-b">
    <div class="max-w-[1440px] mx-auto">
        <div class="relative z-50 flex flex-col md:flex-row justify-between items-end mb-12 section-title">
            <div>
                <h2 class="text-4xl md:text-5xl font-bold mb-3">Top <span class="text-brand-orange">Quán ăn</span> bán chạy nhất</h2>
                <p class="text-brand-gray text-xl">Top 5 quán ăn có lượng đặt hàng bán ra nhiều nhất</p>
            </div>
            <div class="flex gap-2 mt-4 md:mt-0 pb-2 w-full md:w-auto items-center relative z-20" id="branch-filter-container">
                <div class="group relative w-full md:w-auto min-w-[220px]">
                    <div class="bg-gray-900 border border-gray-700 text-white px-5 py-2.5 rounded-full font-bold hover:border-brand-orange transition-colors cursor-pointer flex items-center justify-between gap-4 select-none">
                        <span>🔥 Bán chạy nhất</span>
                        <i class="fa-solid fa-chevron-down text-brand-orange text-sm transition-transform duration-300 group-hover:rotate-180"></i>
                    </div>
                    <!-- Dropdown Content -->
                    <div class="absolute top-full right-0 left-0 mt-2 bg-gray-900 border border-gray-700 rounded-2xl shadow-[0_10px_40px_rgba(0,0,0,0.8)] overflow-hidden opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform origin-top group-hover:translate-y-0 -translate-y-2">
                        <div class="flex flex-col text-left">
                            <div class="px-5 py-3.5 hover:bg-gray-800 cursor-pointer font-bold border-b border-gray-800 text-brand-orange transition-colors">
                                🔥 Bán chạy nhất
                            </div>
                            <div class="px-5 py-3.5 hover:bg-gray-800 cursor-pointer font-bold border-b border-gray-800 text-brand-gray hover:text-white transition-colors">
                                ⭐ Yêu thích nhất
                            </div>
                            <div class="px-5 py-3.5 hover:bg-gray-800 cursor-pointer font-bold text-brand-gray hover:text-white transition-colors">
                                📍 Gần nhất
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="flex flex-nowrap overflow-x-auto gap-6 pb-6 custom-scrollbar" id="top-branches-list">
            <!-- Sẽ được render qua JS -->
        </div>
    </div>
</section>

<!-- Featured Menu Section -->
<section id="menu" class="py-24 px-6 md:px-12 z-10 relative">
    <div class="max-w-[1440px] mx-auto">
        <div class="relative z-50 flex flex-col md:flex-row justify-between items-end mb-12 section-title">
            <div>
                <h2 class="text-4xl md:text-5xl font-bold text-white mb-3">Được yêu thích <span
                        class="text-brand-orange">Nhất</span></h2>
                <p class="text-brand-gray text-xl">Những món ăn bán chạy nhất tại Delivery hub</p>
            </div>
            <div class="flex gap-2 mt-4 md:mt-0 pb-2 w-full md:w-auto items-center relative z-20" id="filter-container">
                <div class="group relative w-full md:w-auto min-w-[220px]">
                    <div class="bg-gray-900 border border-gray-700 text-white px-5 py-2.5 rounded-full font-bold hover:border-brand-orange transition-colors cursor-pointer flex items-center justify-between gap-4 select-none">
                        <span>🔥 Bán chạy nhất</span>
                        <i class="fa-solid fa-chevron-down text-brand-orange text-sm transition-transform duration-300 group-hover:rotate-180"></i>
                    </div>
                    <!-- Dropdown Content (Bo góc) -->
                    <div class="absolute top-full right-0 left-0 mt-2 bg-gray-900 border border-gray-700 rounded-2xl shadow-[0_10px_40px_rgba(0,0,0,0.8)] overflow-hidden opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform origin-top group-hover:translate-y-0 -translate-y-2">
                        <div class="flex flex-col text-left">
                            <div class="px-5 py-3.5 hover:bg-gray-800 cursor-pointer font-bold border-b border-gray-800 text-brand-orange transition-colors">
                                🔥 Bán chạy nhất
                            </div>
                            <div class="px-5 py-3.5 hover:bg-gray-800 cursor-pointer font-bold border-b border-gray-800 text-brand-gray hover:text-white transition-colors">
                                ⭐ Yêu thích nhất
                            </div>
                            <div class="px-5 py-3.5 hover:bg-gray-800 cursor-pointer font-bold text-brand-gray hover:text-white transition-colors">
                                📍 Gần nhất
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="product-list">
            <!-- Products will be generated here by JS -->
        </div>
    </div>
</section>

<!-- Testimonials Section -->
<section id="testimonials" class="py-24 px-6 md:px-12 bg-brand-dark z-10 relative overflow-hidden border-t border-gray-900">
    <div class="max-w-[1440px] mx-auto">
        <h2 class="text-4xl md:text-5xl font-bold mb-16 text-center section-title">Khách hàng <span
                class="text-brand-orange">Nói gì?</span></h2>

        <div class="flex flex-nowrap overflow-x-auto gap-6 pb-8 hide-scrollbar snap-x snap-mandatory" id="testimonial-slider">
            <!-- Testimonials generated by JS -->
        </div>
    </div>
</section>

@section Scripts {
    @if (ViewBag.TopProductsJson != null)
    {
        <script>
            // Ghi đè products bằng dữ liệu thực tế từ DB
            products = @Html.Raw(ViewBag.TopProductsJson);
            // Render lại danh sách
            if (typeof renderProducts === 'function') {
                renderProductsList(products);
            }
        </script>
    }
    @if (ViewBag.TopBranchesJson != null)
    {
        <script>
            let topBranches = @Html.Raw(ViewBag.TopBranchesJson);
            if (typeof renderTopBranches === 'function') {
                renderTopBranches(topBranches);
            }
        </script>
    }
}
