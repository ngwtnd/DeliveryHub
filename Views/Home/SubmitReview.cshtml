@model Order
@{
    ViewData["Title"] = "Đánh giá đơn hàng";
}

<section class="min-h-screen flex items-center justify-center pt-24 pb-12 px-6">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px] bg-brand-orange/10 rounded-full blur-[120px] pointer-events-none"></div>

    <div class="relative w-full max-w-lg">
        <div class="bg-brand-dark/80 backdrop-blur-xl border border-white/10 rounded-[2.5rem] p-8 shadow-2xl">
            
            <!-- Header -->
            <div class="text-center mb-6">
                <div class="w-16 h-16 rounded-full bg-brand-orange/20 border border-brand-orange/30 flex items-center justify-center mx-auto mb-4">
                    <i class="fa-solid fa-star text-brand-orange text-2xl"></i>
                </div>
                <h2 class="text-2xl font-extrabold text-white mb-1">Đánh giá đơn hàng</h2>
                <p class="text-brand-gray text-sm">Đơn <span class="text-brand-orange font-bold">@Model.OrderCode</span></p>
            </div>

            <!-- Order Info -->
            <div class="bg-white/5 border border-white/8 rounded-2xl p-4 mb-6">
                <div class="flex items-center gap-3 mb-2">
                    <div class="w-10 h-10 rounded-xl bg-brand-orange/15 flex items-center justify-center">
                        <i class="fa-solid fa-store text-brand-orange text-sm"></i>
                    </div>
                    <div>
                        <p class="text-white text-sm font-bold">@(Model.Store?.Name ?? "Cửa hàng")</p>
                        <p class="text-gray-500 text-xs">@Model.OrderItems.Sum(oi => oi.Quantity) món · @string.Format("{0:N0}đ", Model.TotalPrice + Model.ShippingFee)</p>
                    </div>
                </div>
                @if (Model.Shipper != null)
                {
                    <div class="flex items-center gap-3 mt-3 pt-3 border-t border-white/5">
                        <div class="w-10 h-10 rounded-xl bg-green-500/15 flex items-center justify-center">
                            <i class="fa-solid fa-motorcycle text-green-400 text-sm"></i>
                        </div>
                        <div>
                            <p class="text-white text-sm font-bold">@Model.Shipper.FullName</p>
                            <p class="text-gray-500 text-xs">Shipper giao hàng</p>
                        </div>
                    </div>
                }
            </div>

            <!-- Rating Form -->
            <div class="space-y-6">
                <!-- Rating Đồ Ăn -->
                <div>
                    <label class="text-sm font-bold text-white mb-3 block">
                        <i class="fa-solid fa-utensils text-brand-orange mr-2"></i>Đánh giá đồ ăn
                    </label>
                    <div class="flex justify-center gap-3" id="menuStars">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <button type="button" onclick="setRating('menu', @i)" 
                                    class="star-btn w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-gray-500 hover:text-yellow-400 hover:border-yellow-400/30 hover:bg-yellow-400/10 transition-all"
                                    data-value="@i">
                                <i class="fa-solid fa-star text-lg"></i>
                            </button>
                        }
                    </div>
                    <input type="hidden" id="ratingMenu" value="5">
                </div>

                <!-- Rating Shipper -->
                <div>
                    <label class="text-sm font-bold text-white mb-3 block">
                        <i class="fa-solid fa-motorcycle text-green-400 mr-2"></i>Đánh giá Shipper
                    </label>
                    <div class="flex justify-center gap-3" id="shipperStars">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <button type="button" onclick="setRating('shipper', @i)"
                                    class="star-btn w-12 h-12 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-gray-500 hover:text-yellow-400 hover:border-yellow-400/30 hover:bg-yellow-400/10 transition-all"
                                    data-value="@i">
                                <i class="fa-solid fa-star text-lg"></i>
                            </button>
                        }
                    </div>
                    <input type="hidden" id="ratingShipper" value="5">
                </div>

                <!-- Comment đồ ăn -->
                <div>
                    <label class="text-xs font-bold text-brand-gray uppercase tracking-wider mb-2 block">Nhận xét về đồ ăn</label>
                    <textarea id="commentMenu" rows="2"
                              class="w-full bg-black/50 border border-white/10 text-white py-3 px-4 rounded-2xl focus:outline-none focus:border-brand-orange transition-all placeholder:text-gray-600 text-sm"
                              placeholder="Đồ ăn ngon, đóng gói cẩn thận..."></textarea>
                </div>

                <!-- Comment shipper -->
                <div>
                    <label class="text-xs font-bold text-brand-gray uppercase tracking-wider mb-2 block">Nhận xét về Shipper</label>
                    <textarea id="commentShipper" rows="2"
                              class="w-full bg-black/50 border border-white/10 text-white py-3 px-4 rounded-2xl focus:outline-none focus:border-brand-orange transition-all placeholder:text-gray-600 text-sm"
                              placeholder="Giao hàng nhanh, thân thiện..."></textarea>
                </div>

                <!-- Submit Button -->
                <button onclick="submitReview(@Model.Id)" id="submitBtn"
                        class="w-full bg-brand-orange text-black font-extrabold py-4 rounded-2xl text-lg hover:shadow-[0_0_20px_rgba(255,107,0,0.4)] hover:scale-[1.02] active:scale-[0.98] transition-all">
                    <i class="fa-solid fa-paper-plane mr-2"></i> Gửi đánh giá
                </button>
            </div>

            <!-- Success State (hidden) -->
            <div id="successState" class="hidden text-center py-6">
                <div class="w-20 h-20 rounded-full bg-green-500/20 border border-green-500/30 flex items-center justify-center mx-auto mb-4 animate-bounce">
                    <i class="fa-solid fa-check-circle text-green-400 text-3xl"></i>
                </div>
                <h3 class="text-xl font-extrabold text-white mb-2">Cảm ơn bạn!</h3>
                <p class="text-brand-gray text-sm">Đánh giá của bạn đã được ghi nhận</p>
                <a href="/" class="inline-block mt-4 bg-brand-orange/10 text-brand-orange font-bold px-6 py-3 rounded-xl hover:bg-brand-orange/20 transition-all text-sm">
                    <i class="fa-solid fa-home mr-1"></i> Về trang chủ
                </a>
            </div>
        </div>
    </div>
</section>

<script>
    let ratings = { menu: 5, shipper: 5 };

    function setRating(type, value) {
        ratings[type] = value;
        document.getElementById(type === 'menu' ? 'ratingMenu' : 'ratingShipper').value = value;

        const container = document.getElementById(type === 'menu' ? 'menuStars' : 'shipperStars');
        container.querySelectorAll('.star-btn').forEach(btn => {
            const v = parseInt(btn.dataset.value);
            if (v <= value) {
                btn.classList.add('text-yellow-400', 'border-yellow-400/30', 'bg-yellow-400/10');
                btn.classList.remove('text-gray-500', 'border-white/10', 'bg-white/5');
            } else {
                btn.classList.remove('text-yellow-400', 'border-yellow-400/30', 'bg-yellow-400/10');
                btn.classList.add('text-gray-500', 'border-white/10', 'bg-white/5');
            }
        });
    }

    // Default: 5 stars
    setRating('menu', 5);
    setRating('shipper', 5);

    async function submitReview(orderId) {
        const btn = document.getElementById('submitBtn');
        btn.disabled = true;
        btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin mr-2"></i> Đang gửi...';

        try {
            const res = await fetch('/Home/SubmitReview', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    orderId: orderId,
                    ratingMenu: ratings.menu,
                    ratingShipper: ratings.shipper,
                    comment: document.getElementById('commentMenu').value,
                    commentForShipper: document.getElementById('commentShipper').value
                })
            });

            const data = await res.json();
            if (data.success) {
                document.querySelector('.space-y-6').classList.add('hidden');
                document.getElementById('successState').classList.remove('hidden');
            } else {
                alert(data.message || 'Lỗi khi gửi đánh giá.');
                btn.disabled = false;
                btn.innerHTML = '<i class="fa-solid fa-paper-plane mr-2"></i> Gửi đánh giá';
            }
        } catch (e) {
            console.error(e);
            alert('Lỗi kết nối.');
            btn.disabled = false;
            btn.innerHTML = '<i class="fa-solid fa-paper-plane mr-2"></i> Gửi đánh giá';
        }
    }
</script>
