@model IEnumerable<DeliveryHubWeb.Models.Store>
@{
    ViewData["Title"] = "Quản lý Chi nhánh";
    Layout = "~/Views/Shared/_PartnerLayout.cshtml";
    var searchTerm = ViewBag.SearchTerm as string;
    var currentPage = (int)(ViewBag.CurrentPage ?? 1);
    var totalPages = (int)(ViewBag.TotalPages ?? 1);
}

<div class="mb-12 mt-4 p-8 bg-white/[0.03] border border-white/5 rounded-[40px] flex flex-col md:flex-row justify-between items-start md:items-center gap-6 fade-in relative z-10 backdrop-blur-xl shadow-2xl">
    <div class="space-y-1">
        <h2 class="text-4xl font-black text-white tracking-tighter">
            <span class="text-brand-orange">Danh sách</span> Chi nhánh
        </h2>
        <div class="flex items-center gap-3">
            <span class="px-2 py-0.5 bg-brand-orange/10 border border-brand-orange/20 rounded text-[10px] font-bold text-brand-orange uppercase tracking-wider">Dashboard</span>
            <p class="text-brand-gray text-[10px] font-bold uppercase tracking-widest mt-1">Quản lý cửa hàng, thực đơn và hoạt động của từng chi nhánh</p>
        </div>
    </div>

    <!-- Actions -->
    <div class="flex flex-col md:flex-row items-center gap-4 w-full md:w-auto">
        <form method="get" class="relative group w-full md:w-64">
            <input type="text" name="search" value="@searchTerm" placeholder="Tìm kiếm chi nhánh..." class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-3 text-xs font-bold text-white placeholder-brand-gray focus:border-brand-orange outline-none transition-all pl-12" />
            <i class="fa-solid fa-search absolute left-5 top-1/2 -translate-y-1/2 text-brand-gray group-focus-within:text-brand-orange transition-colors text-sm"></i>
        </form>
        <button onclick="openAddBranchModal()" class="bg-brand-orange text-black font-extrabold px-6 py-3 rounded-2xl hover:bg-white transition-all shadow-[0_0_15px_rgba(255,107,0,0.2)] shrink-0 flex items-center gap-2">
            <i class="fa-solid fa-plus"></i> <span class="text-xs uppercase tracking-widest">Thêm mới</span>
        </button>
    </div>
</div>

<!-- Branches Grid -->
<div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8 fade-in" style="animation-delay: 0.1s;">
    @if(Model != null && Model.Any()) {
        foreach(var store in Model) {
            <a href="/Partner/StoreDetail/@store.Id" class="bg-brand-dark border border-white/5 rounded-[2.5rem] overflow-hidden hover:border-brand-orange/50 transition-all group flex flex-col shadow-2xl backdrop-blur-xl">
                <div class="relative h-48 overflow-hidden shrink-0">
                    <img src="@(!string.IsNullOrEmpty(store.ImageUrl) ? store.ImageUrl : "https://images.unsplash.com/photo-1555396273-367ea4eb4db5?q=80&w=1000&auto=format&fit=crop")" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" alt="@store.Name" />
                    <div class="absolute inset-0 bg-gradient-to-t from-brand-dark via-transparent to-transparent"></div>
                    
                    @{
                        var pendingIds = ViewBag.PendingStoreIds as List<string> ?? new List<string>();
                        bool isPending = pendingIds.Contains(store.Id.ToString());
                        bool isPartnerActive = ViewBag.IsPartnerActive != null ? ViewBag.IsPartnerActive : true;
                    }
                    
                    @if(isPending) {
                        <div class="absolute top-4 left-4 bg-orange-500/90 backdrop-blur text-white text-[10px] font-black px-2.5 py-1 rounded-md uppercase tracking-wider shadow-lg flex items-center gap-1.5 border border-orange-500/50">
                            <i class="fa-solid fa-clock text-white text-[8px]"></i> Chờ duyệt
                        </div>
                    } else if(store.ActivityState != DeliveryHubWeb.Models.StoreActivityState.Active || !isPartnerActive) {
                        <div class="absolute top-4 left-4 bg-black/80 backdrop-blur text-white text-[10px] font-black px-2.5 py-1 rounded-md uppercase tracking-wider shadow-lg flex items-center gap-1.5 border border-red-500/50">
                            <i class="fa-solid fa-lock text-red-500 text-[8px]"></i> Bị Admin khóa
                        </div>
                    } else if(store.IsOpen) {
                        <div class="absolute top-4 left-4 bg-green-500/90 backdrop-blur text-white text-[10px] font-black px-2.5 py-1 rounded-md uppercase tracking-wider shadow-lg flex items-center gap-1.5">
                            <span class="w-1.5 h-1.5 bg-white rounded-full animate-pulse"></span> Mở cửa
                        </div>
                    } else {
                        <div class="absolute top-4 left-4 bg-red-500/90 backdrop-blur text-white text-[10px] font-black px-2.5 py-1 rounded-md uppercase tracking-wider shadow-lg flex items-center gap-1.5">
                            <span class="w-1.5 h-1.5 bg-white rounded-full"></span> Đóng cửa
                        </div>
                    }

                    <div class="absolute top-4 right-4 bg-brand-orange text-black font-black text-xs px-2.5 py-1 rounded-lg flex items-center gap-1 shadow-lg">
                        @store.Rating.ToString("0.0") <i class="fa-solid fa-star text-[10px]"></i>
                    </div>
                </div>
                <div class="p-6 flex-1 flex flex-col">
                    <h4 class="text-white font-bold text-xl mb-1 line-clamp-1 group-hover:text-brand-orange transition-colors">@store.Name</h4>
                    <p class="text-brand-gray text-xs mb-4 flex items-start gap-1.5 h-8 line-clamp-2">
                        <i class="fa-solid fa-location-dot mt-0.5 text-white/30 shrink-0"></i>
                        @(string.IsNullOrEmpty(store.Address) ? "Chưa cập nhật địa chỉ" : store.Address)
                    </p>
                    
                    <div class="mt-auto flex justify-between items-center border-t border-white/5 pt-4">
                        <div class="text-center">
                            <div class="text-xs font-bold text-brand-gray tracking-wider uppercase mb-0.5">Thực đơn</div>
                            <div class="text-lg font-black text-white">@(store.MenuItems?.Count ?? 0) <span class="text-xs text-brand-gray font-normal">món</span></div>
                        </div>
                        <span class="w-[1px] h-8 bg-white/5"></span>
                        <div class="text-center">
                            <button class="bg-white/5 hover:bg-brand-orange hover:text-black transition-colors rounded-xl px-4 py-2 text-xs font-bold flex items-center gap-2">
                                Quản lý <i class="fa-solid fa-arrow-right"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </a>
        }
    } else {
        <div class="col-span-full py-16 text-center border-2 border-dashed border-white/10 rounded-3xl bg-black/20">
            <div class="w-20 h-20 mx-auto bg-white/5 rounded-full flex items-center justify-center mb-4 border border-white/10">
                <i class="fa-solid fa-store-slash text-3xl text-brand-gray/50"></i>
            </div>
            <h3 class="text-xl font-bold text-white mb-2">Không tìm thấy chi nhánh nào</h3>
            <p class="text-brand-gray text-sm">Hãy thử thay đổi từ khóa tìm kiếm hoặc thêm mới.</p>
        </div>
    }
</div>

@if(totalPages > 1) {
    <!-- Pagination -->
    <div class="mt-8 flex justify-center fade-in" style="animation-delay: 0.2s;">
        <div class="flex gap-2 bg-black/50 p-2 rounded-2xl border border-white/5">
            @for(var i = 1; i <= totalPages; i++) {
                <a href="?page=@i&search=@searchTerm" class="w-10 h-10 flex items-center justify-center rounded-xl font-bold text-sm transition-all @(i == currentPage ? "bg-brand-orange text-black" : "text-brand-gray hover:bg-white/10 hover:text-white")">
                    @i
                </a>
            }
        </div>
    </div>
}

<!-- Add Branch Modal -->
<div id="addBranchModal" class="fixed inset-0 z-[1000] hidden flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-brand-black/80 backdrop-blur-md transition-opacity" onclick="closeAddBranchModal()"></div>
    <div id="addBranchModalContent" class="bg-brand-dark border border-brand-orange/20 rounded-[2.5rem] w-full max-w-xl overflow-hidden flex flex-col shadow-[0_0_80px_rgba(255,107,0,0.15)] relative z-10">
        <div class="px-10 py-7 border-b border-white/5 bg-white/5 flex justify-between items-center">
            <h2 class="text-2xl font-black text-white tracking-tight flex items-center gap-3">
                <i class="fa-solid fa-store text-brand-orange"></i> Thêm chi nhánh mới
            </h2>
            <button type="button" onclick="closeAddBranchModal()" class="w-10 h-10 rounded-full bg-white/5 hover:bg-red-500/20 text-brand-gray hover:text-white flex items-center justify-center transition-all">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>
        
        <form id="addBranchForm" class="p-10 space-y-6 overflow-y-auto custom-scrollbar" style="max-h-[60vh];">
            <div class="space-y-2">
                <label class="text-[10px] font-black text-brand-gray uppercase tracking-widest">Tên chi nhánh <span class="text-red-500">*</span></label>
                <input type="text" name="name" id="branchName" required placeholder="VD: Bún Đậu Mắm Tôm CN2" class="w-full bg-white/5 border border-white/5 rounded-2xl px-5 py-4 text-sm font-bold text-white focus:border-brand-orange outline-none transition-all" />
            </div>

            <div class="space-y-2">
                <label class="text-[10px] font-black text-brand-gray uppercase tracking-widest">Địa chỉ <span class="text-red-500">*</span></label>
                <input type="text" name="address" id="branchAddress" required placeholder="Số nhà, Tên đường, Quận, Thành phố..." class="w-full bg-white/5 border border-white/5 rounded-2xl px-5 py-4 text-sm font-bold text-white focus:border-brand-orange outline-none transition-all" />
            </div>

            <div class="space-y-2">
                <label class="text-[10px] font-black text-brand-gray uppercase tracking-widest">Mô tả giới thiệu</label>
                <textarea name="description" id="branchDesc" rows="2" placeholder="Chi nhánh mới với không gian sang trọng..." class="w-full bg-white/5 border border-white/5 rounded-2xl px-5 py-4 text-sm font-bold text-white focus:border-brand-orange outline-none transition-all resize-none"></textarea>
            </div>

            <div class="space-y-2">
                <label class="text-[10px] font-black text-brand-gray uppercase tracking-widest">Link Hình Ảnh Cửa Hàng</label>
                <input type="url" name="imageUrl" id="branchImgUrl" placeholder="https://..." class="w-full bg-white/5 border border-white/5 rounded-2xl px-5 py-4 text-sm font-bold text-brand-orange placeholder-brand-gray/50 focus:border-brand-orange outline-none transition-all" />
            </div>
            
            <div class="pt-4 flex items-center justify-end gap-3 border-t border-white/5 font-plus mt-8">
                <button type="button" onclick="closeAddBranchModal()" class="px-8 py-4 rounded-2xl bg-white/5 border border-white/10 text-white font-black hover:bg-white/10 transition-all">Đóng</button>
                <button type="button" onclick="submitAddBranch()" class="px-8 py-4 rounded-2xl bg-brand-orange text-black shadow-[0_0_20px_rgba(255,107,0,0.4)] font-black hover:bg-white hover:scale-105 active:scale-95 transition-all flex items-center gap-2">
                    Lưu chi nhánh
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script>
        function openAddBranchModal() {
            const modal = document.getElementById('addBranchModal');
            const content = document.getElementById('addBranchModalContent');
            document.getElementById('addBranchForm').reset();
            modal.classList.remove('hidden');
            gsap.fromTo(content, { opacity: 0, scale: 0.9, y: 20 }, { duration: 0.4, opacity: 1, scale: 1, y: 0, ease: "back.out(1.5)" });
        }

        function closeAddBranchModal() {
            const modal = document.getElementById('addBranchModal');
            const content = document.getElementById('addBranchModalContent');
            gsap.to(content, { duration: 0.3, opacity: 0, scale: 0.9, y: 20, ease: "power2.in", onComplete: () => {
                modal.classList.add('hidden');
            }});
        }

        async function submitAddBranch() {
            const form = document.getElementById('addBranchForm');
            if(!form.checkValidity()) {
                form.reportValidity();
                return;
            }
            const formData = new FormData(form);
            const btn = document.querySelector('[onclick="submitAddBranch()"]');
            const originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';
            btn.disabled = true;

            try {
                const response = await fetch('/Partner/AddBranch', {
                    method: 'POST',
                    body: formData
                });
                const result = await response.json();
                if(result.success) {
                    location.reload();
                } else {
                    showNotification(result.message || "Đã xảy ra lỗi.", "error");
                    btn.innerHTML = originalText;
                    btn.disabled = false;
                }
            } catch(e) {
                showNotification("Lỗi kết nối hệ thống.", "error");
                btn.innerHTML = originalText;
                btn.disabled = false;
            }
        }
        
        function showNotification(message, type = 'success') {
            const existing = document.getElementById('notification-toast');
            if (existing) existing.remove();

            const toast = document.createElement('div');
            toast.id = 'notification-toast';
            toast.className = `fixed bottom-8 right-8 px-6 py-4 rounded-xl flex items-center gap-3 shadow-2xl z-[9999] transform translate-y-20 opacity-0 font-bold text-sm ${type === 'success' ? 'bg-green-500 text-white' : 'bg-red-500 text-white'}`;
            toast.innerHTML = `<i class="fa-solid ${type === 'success' ? 'fa-check-circle' : 'fa-triangle-exclamation'} text-lg"></i><span>${message}</span>`;
            
            document.body.appendChild(toast);
            
            gsap.to(toast, { y: 0, opacity: 1, duration: 0.4, ease: "back.out(1.5)" });
            
            setTimeout(() => {
                gsap.to(toast, { y: 20, opacity: 0, duration: 0.3, ease: "power2.in", onComplete: () => toast.remove() });
            }, 3000);
        }
    </script>
}
