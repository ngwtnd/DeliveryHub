    <div id="categoryModalContent" class="relative bg-brand-dark border border-brand-orange/20 rounded-[2.5rem] w-full max-w-md shadow-[0_0_80px_rgba(255,107,0,0.15)] overflow-hidden z-10">
        <div class="px-8 py-6 border-b border-white/5 bg-white/5 flex items-center justify-between">
            <h2 class="text-xl font-black text-white flex items-center gap-3">
                <i class="fa-solid fa-tags text-brand-orange"></i> Quản lý Danh mục
