            </div>

            <div class="space-y-4">
                <label class="text-xs font-black text-brand-gray uppercase tracking-widest block">Hình ảnh chi nhánh</label>
                
                <!-- URL Option -->
                <div class="space-y-2">
                    <span class="text-[10px] text-brand-gray font-bold uppercase italic">Cách 1: Nhập trực tiếp URL ảnh</span>
                    <input type="text" id="imgUrlInput" name="imageUrl" value="@Model.ImageUrl" placeholder="https://..." class="w-full bg-white/5 border border-white/10 rounded-2xl px-6 py-3 text-xs text-white placeholder-white/20 outline-none focus:border-brand-orange transition-all" />
                </div>

                <div class="flex items-center gap-4 py-2">
