        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script>
        // --- GLOBAL TOAST SYSTEM ---
        function showNotification(msg, type) {
            const toast = document.createElement('div');
            toast.className = `fixed top-24 right-8 z-[5000] px-8 py-4 rounded-2xl shadow-2xl border font-bold text-sm flex items-center gap-4 transition-all opacity-0 translate-x-10 backdrop-blur-xl ${type === 'error' ? 'bg-red-500/90 text-white border-red-500' : 'bg-green-500/90 text-white border-green-500'}`;
            toast.innerHTML = `<i class="fa-solid ${type === 'error' ? 'fa-circle-exclamation' : 'fa-circle-check'} text-xl"></i> <div>${msg}</div>`;
            document.body.appendChild(toast);

            gsap.to(toast, { duration: 0.5, opacity: 1, x: 0, ease: "power2.out" });
            setTimeout(() => {
                gsap.to(toast, { duration: 0.4, opacity: 0, x: 50, ease: "power2.in", onComplete: () => toast.remove() });
            }, 4000);
        }

        // --- BRANCH STORE LOGIC ---
        function openEditModal() {
            const modal = document.getElementById('editStoreModal');
            const content = document.getElementById('editModalContent');
            modal.classList.remove('hidden');
            gsap.fromTo(content, { opacity: 0, scale: 0.9, y: 20 }, { duration: 0.5, opacity: 1, scale: 1, y: 0, ease: "back.out(1.5)" });
        }

        function closeEditModal() {
            const modal = document.getElementById('editStoreModal');
            const content = document.getElementById('editModalContent');
            gsap.to(content, { duration: 0.3, opacity: 0, scale: 0.9, y: 20, ease: "power2.in", onComplete: () => modal.classList.add('hidden') });
        }

        function previewFile(input) {
            const label = document.getElementById('fileName');
            if (input.files && input.files[0]) {
                label.innerText = input.files[0].name;
                label.classList.add('text-brand-orange');
            }
        }

        document.getElementById('editStoreForm').addEventListener('submit', async (e) => {
            e.preventDefault();
            const btn = e.target.querySelector('button[type="submit"]');
            const originalText = btn.innerHTML;
            btn.innerHTML = '<i class="fa-solid fa-circle-notch fa-spin"></i> Đang lưu...';
            btn.disabled = true;

            const formData = new FormData(e.target);
            try {
                const response = await fetch('/Partner/UpdateStore', { method: 'POST', body: formData });
                const result = await response.json();
                if (result.success) {
                    showNotification("Đã cập nhật thông tin chi nhánh!", "success");
                    setTimeout(() => location.reload(), 800);
                } else {
                    showNotification(result.message, "error");
                }
            } finally {
                btn.innerHTML = originalText;
                btn.disabled = false;
            }
        });

        // --- BRANCH STATUS TOGGLE ---
        let currentIsOpen = @(Model.IsOpen.ToString().ToLower());
        function updatePillStyles(isOpen) {
            const btnOn = document.getElementById('btn-status-on');
            const btnOff = document.getElementById('btn-status-off');
            const pill = document.getElementById('statusPill');
            const targetBtn = isOpen ? btnOn : btnOff;
            if (!pill || !targetBtn) return;
            gsap.to(pill, { duration: 0.4, left: targetBtn.offsetLeft + 'px', width: targetBtn.offsetWidth + 'px', ease: "power2.inOut" });
            if (isOpen) {
                pill.className = "absolute top-1.5 bottom-1.5 rounded-xl z-0 bg-green-50 border border-green-200 shadow-sm";
                btnOn.className = "relative z-10 px-6 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest text-green-600 transition-colors duration-500";
                btnOff.className = "relative z-10 px-6 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest text-brand-gray/60 hover:text-brand-black transition-colors duration-500";
            } else {
                pill.className = "absolute top-1.5 bottom-1.5 rounded-xl z-0 bg-red-50 border border-red-200 shadow-sm";
                btnOff.className = "relative z-10 px-6 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest text-red-500 transition-colors duration-500";
                btnOn.className = "relative z-10 px-6 py-2 rounded-xl text-[10px] font-black uppercase tracking-widest text-brand-gray/60 hover:text-brand-black transition-colors duration-500";
            }
        }
        window.addEventListener('load', () => updatePillStyles(currentIsOpen));

        async function changeStoreStatus(targetIsOpen) {
            if (targetIsOpen === currentIsOpen) return;
            try {
                const response = await fetch('/Partner/ToggleStoreStatus/@Model.Id', { method: 'POST' });
                const result = await response.json();
                if (result.success) {
                    currentIsOpen = result.isOpen;
                    updatePillStyles(currentIsOpen);
                    showNotification(currentIsOpen ? "Chi nhánh đã mở cửa!" : "Chi nhánh đã đóng cửa!", "success");
                } else {
                    showNotification(result.message, "error");
                }
            } catch (err) { showNotification("Lỗi kết nối server.", "error"); }
        }

        async function lockBranchByPartner() {
            if(!confirm("Bạn có chắc chắn muốn khóa chi nhánh này?")) return;
            try {
                const response = await fetch('/Partner/LockStoreByPartner/@Model.Id', { method: 'POST' });
                const result = await response.json();
                if (result.success) {
                    showNotification("Đã khóa chi nhánh thành công!", "success");
                    setTimeout(() => location.reload(), 1000);
                } else {
                    showNotification(result.message, "error");
                }
            } catch (err) { showNotification("Lỗi kết nối server.", "error"); }
        }

        async function unlockBranchByPartner() {
            if(!confirm("Bạn có chắc chắn muốn mở khóa chi nhánh này?")) return;
            try {
                const response = await fetch('/Partner/UnlockStoreByPartner/@Model.Id', { method: 'POST' });
                const result = await response.json();
                if (result.success) {
                    showNotification("Mở khóa thành công!", "success");
                    setTimeout(() => location.reload(), 1000);
                } else {
                    showNotification(result.message, "error");
                }
            } catch (err) { showNotification("Lỗi kết nối server.", "error"); }
        }

        // --- MENU ITEM LOGIC ---
        function switchImageSource(type) {
            const btnUrl = document.getElementById('imgSourceUrl');
            const btnFile = document.getElementById('imgSourceFile');
            const urlCont = document.getElementById('urlInputContainer');
            const fileCont = document.getElementById('fileInputContainer');

            if (type === 'url') {
                btnUrl.className = "px-3 py-1 text-[9px] font-black uppercase tracking-tighter rounded-md bg-white/10 text-white";
                btnFile.className = "px-3 py-1 text-[9px] font-black uppercase tracking-tighter rounded-md text-brand-gray hover:text-white";
                urlCont.classList.replace('hidden', 'block');
                fileCont.classList.replace('block', 'hidden');
            } else {
                btnFile.className = "px-3 py-1 text-[9px] font-black uppercase tracking-tighter rounded-md bg-white/10 text-white";
                btnUrl.className = "px-3 py-1 text-[9px] font-black uppercase tracking-tighter rounded-md text-brand-gray hover:text-white";
                fileCont.classList.replace('hidden', 'block');
                urlCont.classList.replace('block', 'hidden');
            }
        }

        function toggleItemAvailable(val) {
            document.getElementById('menuItemIsAvailable').value = val;
            const btnOn = document.getElementById('btn-avail-on');
            const btnOff = document.getElementById('btn-avail-off');
            if(val) {
                btnOn.className = "flex-1 rounded-xl border border-green-500/30 bg-green-500/10 text-green-500 text-[10px] font-black uppercase tracking-widest h-full";
                btnOff.className = "flex-1 rounded-xl border border-white/5 bg-white/5 text-brand-gray text-[10px] font-black uppercase tracking-widest h-full hover:bg-white/10 hover:text-white transition-all";
            } else {
                btnOff.className = "flex-1 rounded-xl border border-red-500/30 bg-red-500/10 text-red-500 text-[10px] font-black uppercase tracking-widest h-full";
                btnOn.className = "flex-1 rounded-xl border border-white/5 bg-white/5 text-brand-gray text-[10px] font-black uppercase tracking-widest h-full hover:bg-white/10 hover:text-white transition-all";
            }
        }

        function previewItemUrl(url) {
            const container = document.getElementById('urlPreviewContainer');
            const img = document.getElementById('urlPreviewImg');
            if (url && url.trim() !== '') {
                img.src = url;
                container.classList.remove('hidden');
                
                // If the user pastes an invalid URL, the image error event will hide it
                img.onerror = () => container.classList.add('hidden');
                img.onload = () => container.classList.remove('hidden');
            } else {
                container.classList.add('hidden');
            }
        }

        function previewItemFile(input) {
            const label = document.getElementById('itemFileName');
            if (input.files && input.files[0]) {
                label.innerText = input.files[0].name;
                label.classList.add('text-brand-orange');
            }
        }

        function openMenuModal(data = null) {
            const modal = document.getElementById('menuItemModal');
            const content = document.getElementById('menuModalContent');
            const form = document.getElementById('menuItemForm');
            const title = document.getElementById('menuModalTitle');
            
            form.reset();
            document.getElementById('menuItemId').value = "0";
            document.getElementById('itemFileName').innerText = "Chọn ảnh từ thiết bị...";
            document.getElementById('itemFileName').classList.remove('text-brand-orange');
            switchImageSource('url');
            toggleItemAvailable(true);

            if(data && data.id) {
                title.innerHTML = `<i class="fa-solid fa-pen-to-square text-brand-orange"></i> Chỉnh sửa món ăn`;
                document.getElementById('menuItemId').value = data.id;
                document.getElementById('menuItemName').value = data.name || "";
                document.getElementById('menuItemDesc').value = data.description || "";
                document.getElementById('menuItemPrice').value = data.price || "";
                document.getElementById('menuItemImgUrl').value = data.imageUrl || "";
                previewItemUrl(data.imageUrl || "");
                toggleItemAvailable(data.isAvailable !== undefined ? data.isAvailable : true);
            } else {
                title.innerHTML = `<i class="fa-solid fa-bowl-food text-brand-orange"></i> Thêm món ăn mới`;
                previewItemUrl("");
            }

            modal.classList.remove('hidden');
            gsap.fromTo(content, { opacity: 0, scale: 0.9, y: 20 }, { duration: 0.4, opacity: 1, scale: 1, y: 0, ease: "back.out(1.5)" });
        }

        function closeMenuModal() {
            const modal = document.getElementById('menuItemModal');
            const content = document.getElementById('menuModalContent');
            gsap.to(content, { duration: 0.3, opacity: 0, scale: 0.9, y: 20, ease: "power2.in", onComplete: () => modal.classList.add('hidden') });
        }

        async function saveMenuItem() {
            const form = document.getElementById('menuItemForm');
            const formData = new FormData(form);
            const btn = document.querySelector('[onclick="saveMenuItem()"]');
            const originalText = btn.innerHTML;
            
            btn.innerHTML = '<i class="fa-solid fa-save fa-spin"></i>';
            btn.disabled = true;

            try {
                const response = await fetch('/Partner/SaveMenuItem', { method: 'POST', body: formData });
                const result = await response.json();
                if(result.success) {
                    showNotification(formData.get('id') === "0" ? "Đã thêm món mới!" : "Đã cập nhật món ăn!", "success");
                    location.reload();
                } else {
                    showNotification(result.message, "error");
                    btn.innerHTML = originalText;
                    btn.disabled = false;
                }
            } catch (err) {
                showNotification("Lỗi kết nối mạng.", "error");
                btn.innerHTML = originalText;
                btn.disabled = false;
            }
        }

        // --- DELETE LOGIC ---
        function openDeleteModal() {
            const modal = document.getElementById('deleteMenuModal');
            const backdrop = modal.querySelector('.delete-backdrop');
            const content = modal.querySelector('.delete-content');
            modal.classList.remove('hidden');
            gsap.fromTo(backdrop, { opacity: 0 }, { duration: 0.3, opacity: 1 });
            gsap.fromTo(content, { scale: 0.7, opacity: 0 }, { duration: 0.4, scale: 1, opacity: 1, ease: "back.out(1.5)" });
        }

        function closeDeleteMenuModal() {
            const modal = document.getElementById('deleteMenuModal');
            const backdrop = modal.querySelector('.delete-backdrop');
            const content = modal.querySelector('.delete-content');
            gsap.to(content, { duration: 0.3, scale: 0.7, opacity: 0, ease: "power2.in" });
            gsap.to(backdrop, { duration: 0.3, opacity: 0, onComplete: () => {
                modal.classList.add('hidden');
                deleteItemId = 0;
            }});
        }

        let deleteItemId = 0;
        function confirmDeleteMenu(id, name) {
            deleteItemId = id;
            document.getElementById('deleteModalTitle').innerText = "Xóa món ăn";
            document.getElementById('deleteModalMsg').innerHTML = `Bạn có chắc chắn muốn xóa món "<span class="text-white font-bold">${name}</span>"?`;
            
            const confirmBtn = document.getElementById('btnConfirmDelete');
            confirmBtn.onclick = executeDeleteMenu;
            openDeleteModal();
        }

        async function executeDeleteMenu() {
            if(!deleteItemId) return;
            const btn = document.getElementById('btnConfirmDelete');
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';
            btn.disabled = true;

            try {
                const response = await fetch('/Partner/DeleteMenuItem', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                    body: `id=${deleteItemId}`
                });
                const result = await response.json();
                if(result.success) {
                    showNotification("Đã xóa món ăn!", "success");
                    location.reload();
                } else {
                    showNotification(result.message, "error");
                    btn.innerHTML = "Đồng ý xóa";
                    btn.disabled = false;
                }
            } catch(e) { showNotification("Lỗi hệ thống.", "error"); btn.disabled = false; }
        }

        // --- CATEGORY MODAL LOGIC ---
        // In-memory list of categories, seeded from server
        let categoryList = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(allCategories));

        function openCategoryModal() {
            const modal = document.getElementById('categoryModal');
            const content = document.getElementById('categoryModalContent');
            modal.classList.remove('hidden');
            gsap.fromTo(content, { opacity: 0, scale: 0.9, y: 20 }, { duration: 0.4, opacity: 1, scale: 1, y: 0, ease: "back.out(1.5)" });
        }

        function closeCategoryModal() {
            const modal = document.getElementById('categoryModal');
            const content = document.getElementById('categoryModalContent');
            gsap.to(content, { duration: 0.3, opacity: 0, scale: 0.9, y: 20, ease: "power2.in", onComplete: () => modal.classList.add('hidden') });
        }

        function renderCategoryTags() {
            const container = document.getElementById('categoryTagList');
            container.innerHTML = categoryList.map(cat => `
                <span class="px-4 py-2 rounded-xl bg-white/5 border border-white/10 text-xs font-bold text-white flex items-center gap-2">
                    <i class="fa-solid fa-tag text-brand-orange text-[10px]"></i> ${cat}
                </span>
            `).join('');
        }

        let isCatDropdownOpen = false;

        function toggleCatDropdown() {
            const list = document.getElementById('customCatList');
            if(isCatDropdownOpen) {
                gsap.to(list, {duration: 0.2, opacity: 0, scale: 0.95, ease: "power2.in", onComplete: () => list.classList.replace('flex', 'hidden')});
                isCatDropdownOpen = false;
            } else {
                list.classList.replace('hidden', 'flex');
                gsap.fromTo(list, {opacity: 0, scale: 0.95}, {duration: 0.3, opacity: 1, scale: 1, ease: "back.out(1.5)"});
                isCatDropdownOpen = true;
            }
        }

        function selectCategory(cat) {
            document.getElementById('menuItemCategory').value = cat;
            document.getElementById('customCatText').innerText = cat;
            toggleCatDropdown();
        }

        document.addEventListener('click', function(e) {
            const wrapper = document.getElementById('customCatWrapper');
            if(isCatDropdownOpen && wrapper && !wrapper.contains(e.target)) {
                toggleCatDropdown();
            }
        });

        function syncCategorySelect(selectedValue) {
            const defaultCat = selectedValue || categoryList[0];
            document.getElementById('menuItemCategory').value = defaultCat;
            const textEl = document.getElementById('customCatText');
            if(textEl) textEl.innerText = defaultCat;
            
            const listContainer = document.getElementById('customCatList');
            if(listContainer) {
                listContainer.innerHTML = categoryList.map(cat => `
                    <button type="button" onclick="selectCategory('${cat.replace(/'/g, "\\'")}')" class="w-full text-left px-5 py-3 text-sm font-bold text-brand-gray hover:text-white hover:bg-brand-orange/20 transition-all ${cat === defaultCat ? 'bg-white/5 text-white' : ''}">
                        ${cat}
                    </button>
                `).join('');
            }
        }

        async function addNewCategory(btn) {
            const input = document.getElementById('newCategoryInput');
            const name = input.value.trim();
            if (!name) { input.focus(); return; }
            if (categoryList.map(c => c.toLowerCase()).includes(name.toLowerCase())) {
                showNotification('Danh mục này đã tồn tại!', 'error');
                return;
            }

            if(!btn) btn = document.getElementById('addCatBtn');
            const originalContent = btn.innerHTML;
            btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i> Đang thêm...';
            btn.disabled = true;

            try {
                const formData = new FormData();
                formData.append('storeId', '@Model.Id');
                formData.append('categoryName', name);

                const response = await fetch('/Partner/AddCustomCategory', {
                    method: 'POST',
                    body: formData
                });

                const text = await response.text();
                try {
                    const result = JSON.parse(text);
                    if(result.success) {
                        // Insert and keep Khác at the end
                        categoryList.push(name);
                        categoryList.sort();
                        const khacIdx = categoryList.indexOf("Khác");
                        if (khacIdx > -1) {
                            categoryList.splice(khacIdx, 1);
                            categoryList.push("Khác");
                        }
                        
                        showNotification(`Đã thêm danh mục "${name}"`, 'success');
                        setTimeout(() => location.reload(), 1000);
                    } else {
                        showNotification(result.message || 'Lỗi khi thêm danh mục', 'error');
                        btn.innerHTML = originalContent;
                        btn.disabled = false;
                    }
                } catch (jsonErr) {
                    throw new Error("Lỗi máy chủ trả về: " + text.substring(0, 50) + "...");
                }
            } catch(e) {
                showNotification(e.message, 'error');
                btn.innerHTML = originalContent;
                btn.disabled = false;
            }
        }

        // Override openMenuModal to sync dropdown with current categoryList
        const _origOpenMenuModal = openMenuModal;
        openMenuModal = function(data = null) {
            _origOpenMenuModal(data);
            syncCategorySelect(data ? data.category : null);
        };



        let catToDelete = "";
        function confirmDeleteCategory(name, itemCount) {
            catToDelete = name;
            document.getElementById('deleteModalTitle').innerText = "Xóa danh mục";
            
            let msg = `Bạn có chắc chắn muốn xóa danh mục "<span class="text-white font-bold">${name}</span>"?`;
            if(itemCount > 0) {
                msg += `<br><span class="text-xs text-brand-gray mt-2 block">Cảnh báo: Tác vụ này sẽ tự động chuyển ${itemCount} món ăn trong danh mục sang danh mục "Khác".</span>`;
            }
            document.getElementById('deleteModalMsg').innerHTML = msg;
            
            const confirmBtn = document.getElementById('btnConfirmDelete');
            confirmBtn.onclick = async function() {
                const prevHtml = this.innerHTML;
                this.innerHTML = '<i class="fa-solid fa-spinner fa-spin"></i>';
                this.disabled = true;

                try {
                    const formData = new FormData();
                    formData.append('storeId', '@Model.Id');
                    formData.append('categoryName', catToDelete);

                    const response = await fetch('/Partner/DeleteCustomCategory', {
                        method: 'POST',
                        body: formData
                    });
                    const result = await response.json();
                    if(result.success) {
                        showNotification(`Đã xóa danh mục "${catToDelete}"`, "success");
                        location.reload();
                    } else {
                        showNotification(result.message || 'Lỗi khi xóa', "error");
                        this.innerHTML = prevHtml;
                        this.disabled = false;
                    }
                } catch(e) {
                    showNotification("Lỗi kết nối.", "error");
                    this.innerHTML = prevHtml;
                    this.disabled = false;
                }
            };

            openDeleteModal();
        }
    </script>
}

