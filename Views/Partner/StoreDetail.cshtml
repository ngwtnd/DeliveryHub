                <button type="button" onclick="closeEditModal()" class="flex-1 bg-white/5 text-white font-bold py-4 rounded-2xl hover:bg-white/10 transition-all">Hủy bỏ</button>
                <button type="submit" class="flex-1 bg-brand-orange text-black font-black py-4 rounded-2xl hover:bg-white hover:scale-105 transition-all shadow-[0_0_20px_rgba(255,107,0,0.3)]">
