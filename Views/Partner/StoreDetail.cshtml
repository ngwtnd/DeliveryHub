    <div id="editModalContent" class="bg-brand-dark border border-white/10 rounded-[2.5rem] w-full max-w-lg overflow-hidden flex flex-col shadow-[0_0_50px_rgba(0,0,0,0.5)] relative z-10 transition-all opacity-0 scale-95">
        <div class="p-8 border-b border-white/5 bg-white/5">
            <h2 class="text-2xl font-black text-white flex items-center gap-3">
                <i class="fa-solid fa-store text-brand-orange"></i> Chỉnh sửa Chi nhánh
            </h2>
        </div>
        
        <form id="editStoreForm" class="p-8 space-y-6">
            <input type="hidden" name="id" value="@Model.Id" />
            
            <div class="space-y-2">
                <label class="text-xs font-black text-brand-gray uppercase tracking-widest">Tên chi nhánh</label>
