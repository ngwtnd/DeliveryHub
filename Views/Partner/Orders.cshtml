@model IEnumerable<DeliveryHubWeb.Models.Order>
@{
    Layout = "~/Views/Shared/_PartnerLayout.cshtml";
    ViewData["Title"] = "Lịch sử đơn hàng";

    // Helper function for Status Labels
    string GetStatusLabel(DeliveryHubWeb.Models.OrderStatus status) => status switch {
        DeliveryHubWeb.Models.OrderStatus.Pending or DeliveryHubWeb.Models.OrderStatus.Preparing => "Nhận đơn",
        DeliveryHubWeb.Models.OrderStatus.SearchingShipper or DeliveryHubWeb.Models.OrderStatus.Accepted => "Chờ vận chuyển",
        DeliveryHubWeb.Models.OrderStatus.Delivering => "Đang giao",
        DeliveryHubWeb.Models.OrderStatus.Completed => "Thành công",
        DeliveryHubWeb.Models.OrderStatus.Cancelled => "Đã hủy",
        DeliveryHubWeb.Models.OrderStatus.Failed => "Thất bại",
        _ => status.ToString()
    };

    string GetStatusClass(DeliveryHubWeb.Models.OrderStatus status) => status switch {
        DeliveryHubWeb.Models.OrderStatus.Pending or DeliveryHubWeb.Models.OrderStatus.Preparing => "bg-yellow-500/10 text-yellow-500",
        DeliveryHubWeb.Models.OrderStatus.SearchingShipper or DeliveryHubWeb.Models.OrderStatus.Accepted => "bg-pink-500/10 text-pink-500 border border-pink-500/20",
        DeliveryHubWeb.Models.OrderStatus.Delivering => "bg-brand-orange/10 text-brand-orange",
        DeliveryHubWeb.Models.OrderStatus.Completed => "bg-green-500/20 text-green-400 border border-green-500/20",
        DeliveryHubWeb.Models.OrderStatus.Cancelled => "bg-blue-500/10 text-blue-400 border border-blue-500/20",
        DeliveryHubWeb.Models.OrderStatus.Failed => "bg-red-500/20 text-red-500 border border-red-500/20",
        _ => "bg-gray-500/10 text-gray-500"
    };

    int storeId = ViewBag.StoreId != null ? (int)ViewBag.StoreId : 0;
}

<div class="mb-12 mt-4 p-8 bg-white/[0.03] border border-white/5 rounded-[40px] flex justify-between items-center fade-in relative z-10 backdrop-blur-xl shadow-2xl">
    <div class="space-y-1">
        <div class="flex items-center gap-3 mb-2">
            <a href="/Partner/Index@(storeId > 0 ? "?storeId=" + storeId : "")" class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-brand-orange hover:text-black transition-all">
                <i class="fa-solid fa-arrow-left text-xs"></i>
            </a>
            <span class="px-2 py-0.5 bg-brand-orange/10 border border-brand-orange/20 rounded text-[10px] font-bold text-brand-orange uppercase tracking-wider">Dashboard</span>
        </div>
        <h2 class="text-4xl font-black text-white tracking-tighter">Lịch sử <span class="text-brand-orange">Đơn hàng</span></h2>
        <p class="text-brand-gray text-[10px] font-bold uppercase tracking-widest mt-1">
            Đang hiển thị <span class="text-white font-black">@Model.Count()</span> đơn hàng của 
            @if(ViewBag.StoreName != null) {
                <span class="text-brand-orange">chi nhánh @ViewBag.StoreName</span>
            } else {
                <span class="text-brand-orange">toàn bộ chi nhánh</span>
            }
        </p>
    </div>

    <form method="get" action="/Partner/Orders" class="flex flex-col md:flex-row items-center gap-4">
        <select name="storeId" class="bg-white/5 border border-white/10 rounded-2xl px-4 py-3 text-xs font-bold text-white outline-none focus:border-brand-orange/50 transition-all appearance-none cursor-pointer">
            <option value="" class="bg-brand-dark">Tất cả chi nhánh</option>
            @if(ViewBag.Stores != null)
            {
                foreach(var s in ViewBag.Stores)
                {
                    if(storeId == s.Id) {
                        <option value="@s.Id" class="bg-brand-dark" selected>@s.Name</option>
                    } else {
                        <option value="@s.Id" class="bg-brand-dark">@s.Name</option>
                    }
                }
            }
        </select>

        <select name="status" class="bg-white/5 border border-white/10 rounded-2xl px-4 py-3 text-xs font-bold text-white outline-none focus:border-brand-orange/50 transition-all appearance-none cursor-pointer">
            <option value="" class="bg-brand-dark">Tất cả trạng thái</option>
            @{
                var statuses = Enum.GetValues(typeof(DeliveryHubWeb.Models.OrderStatus)).Cast<DeliveryHubWeb.Models.OrderStatus>();
                var currentStatus = ViewBag.CurrentStatus as DeliveryHubWeb.Models.OrderStatus?;
                foreach(var st in statuses) {
                    if(currentStatus.HasValue && currentStatus.Value == st) {
                        <option value="@st" class="bg-brand-dark" selected>@GetStatusLabel(st)</option>
                    } else {
                        <option value="@st" class="bg-brand-dark">@GetStatusLabel(st)</option>
                    }
                }
            }
        </select>
        
        <button type="submit" class="bg-brand-orange text-black font-extrabold px-6 py-3 rounded-2xl shadow-[0_0_15px_rgba(255,107,0,0.2)] hover:bg-white transition-all text-xs">
            Lọc
        </button>

        <div class="relative group ml-4">
            <input type="text" id="tableSearch" placeholder="Tìm tên/mã đơn..." 
                   class="bg-white/5 border border-white/10 rounded-2xl px-6 py-3 text-xs font-bold text-white placeholder-brand-gray/50 focus:border-brand-orange/50 w-48 outline-none transition-all pl-12" />
            <i class="fa-solid fa-search absolute left-5 top-1/2 -translate-y-1/2 text-[12px] text-brand-gray group-focus-within:text-brand-orange"></i>
        </div>
    </form>
</div>

<div class="bg-brand-dark/50 backdrop-blur-xl rounded-[3rem] border border-white/5 overflow-hidden shadow-2xl fade-in" style="animation-delay: 0.2s">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse" id="ordersTable">
            <thead>
                <tr class="bg-white/[0.02] text-[10px] font-extrabold text-brand-gray uppercase tracking-[2px]">
                    <th class="py-6 px-8">Mã đơn</th>
                    <th class="py-6 px-4">Nhà hàng & Khách</th>
                    <th class="py-6 px-4">Địa chỉ giao</th>
                    <th class="py-6 px-4 text-right">Tổng tiền</th>
                    <th class="py-6 px-4">Trạng thái</th>
                    <th class="py-6 px-4 text-center">Chi tiết</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-white/5">
                @foreach (var order in Model)
                {
                    <tr class="group hover:bg-white/[0.02] transition-all order-row">
                        <td class="py-5 px-8">
                            <span class="text-brand-orange font-black text-xs tracking-wider">@order.OrderCode</span>
                            <p class="text-[9px] text-brand-gray font-bold uppercase mt-1">@order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
                        </td>
                        <td class="py-5 px-4">
                            <div class="space-y-1">
                                <p class="text-white text-xs font-black truncate max-w-[150px]">@order.Store?.Name</p>
                                <p class="text-brand-gray text-[10px] font-bold truncate max-w-[150px]">@order.User?.FullName</p>
                            </div>
                        </td>
                        <td class="py-5 px-4">
                            <p class="text-brand-gray text-xs font-bold truncate max-w-[250px]">@order.DeliveryAddress</p>
                        </td>
                        <td class="py-5 px-4 text-right font-black text-xs text-white">
                            @string.Format("{0:N0}", order.TotalPrice + order.ShippingFee) đ
                        </td>
                        <td class="py-5 px-4">
                            <span class="px-3 py-1.5 rounded-full text-[10px] font-black uppercase tracking-wider @GetStatusClass(order.Status)">
                                @GetStatusLabel(order.Status)
                            </span>
                        </td>
                        <td class="py-5 px-4 text-center">
                            <button onclick="viewOrderDetail(@order.Id)" class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-brand-gray hover:bg-brand-orange hover:text-black hover:border-brand-orange hover:shadow-[0_0_15px_rgba(255,107,0,0.3)] transition-all group/btn mx-auto">
                                <i class="fa-solid fa-eye text-sm"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<template id="orderData">
    @foreach(var order in Model) {
        <div data-id="@order.Id" 
             data-code="@order.OrderCode"
             data-customer="@order.User?.FullName"
             data-merchant="@order.Store?.Name"
             data-merchant-addr="@order.Store?.Address"
             data-delivery-addr="@order.DeliveryAddress"
             data-status="@order.Status"
             data-price="@string.Format("{0:N0}", order.TotalPrice + order.ShippingFee)"
             data-time1="@order.CreatedAt.ToString("HH:mm - dd/MM")"
             data-time2="@(order.AcceptedAt?.ToString("HH:mm - dd/MM") ?? "--:--")"
             data-time3="@(order.PickedUpAt?.ToString("HH:mm - dd/MM") ?? "--:--")"
             data-time4="@((order.Status == DeliveryHubWeb.Models.OrderStatus.Completed ? order.CompletedAt : order.CancelledAt)?.ToString("HH:mm - dd/MM") ?? "--:--")"
             data-shipper-name="@(order.Shipper?.FullName ?? "")"
             data-shipper-code=""
             data-note="@order.Note">
             <div class="items-json">
                @Html.Raw(System.Text.Json.JsonSerializer.Serialize(order.OrderItems.Select(oi => new { name = oi.MenuItem?.Name, qty = oi.Quantity, price = oi.Price })))
             </div>
        </div>
    }
</template>

@await Html.PartialAsync("_OrderDetailModal")

@section Scripts {

<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<script>
    function viewOrderDetail(id) {
        const dataDiv = document.querySelector(`template#orderData`).content.querySelector(`[data-id="${id}"]`);
        if (!dataDiv) return;

        const items = JSON.parse(dataDiv.querySelector('.items-json').innerText);
        
        const data = {
            id: id,
            code: dataDiv.dataset.code,
            customer: dataDiv.dataset.customer,
            merchant: dataDiv.dataset.merchant,
            merchantAddr: dataDiv.dataset.merchantAddr,
            deliveryAddr: dataDiv.dataset.deliveryAddr,
            status: dataDiv.dataset.status,
            totalPrice: dataDiv.dataset.price,
            time1: dataDiv.dataset.time1,
            time2: dataDiv.dataset.time2,
            time3: dataDiv.dataset.time3,
            time4: dataDiv.dataset.time4,
            shipperName: dataDiv.dataset.shipperName,
            shipperCode: dataDiv.dataset.shipperCode,
            note: dataDiv.dataset.note,
            items: items
        };

        if (typeof renderOrderDetail === 'function') {
            renderOrderDetail(data);
        }

        const modal = document.getElementById('orderDetailModal');
        const body = document.getElementById('modalBody');
        modal.classList.remove('hidden');
        gsap.set(body, { scale: 0.9, opacity: 0 });
        gsap.to(body, { duration: 0.5, scale: 1, opacity: 1, ease: "back.out(1.2)" });
    }

    function closeModal() {
        const modal = document.getElementById('orderDetailModal');
        const body = document.getElementById('modalBody');
        if (typeof gsap !== 'undefined') {
            gsap.to(body, { duration: 0.3, scale: 0.9, opacity: 0, ease: "power2.in", onComplete: () => {
                modal.classList.add('hidden');
            }});
        } else {
            modal.classList.add('hidden');
        }
    }

    // Quick Search implementation
    document.getElementById('tableSearch').addEventListener('keyup', function() {
        let val = this.value.toLowerCase();
        let rows = document.querySelectorAll('#ordersTable tbody tr');
        rows.forEach(row => {
            row.style.display = row.innerText.toLowerCase().includes(val) ? '' : 'none';
        });
    });
</script>
}
