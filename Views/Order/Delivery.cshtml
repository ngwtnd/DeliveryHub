@{
    ViewData["Title"] = "Giao hàng";
}

@section Styles {
    <!-- Leaflet CSS -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        .delivery-card {
            background: #1a1a1a;
            border: 1px solid #333;
            border-radius: 1.5rem;
            padding: 1.5rem;
            transition: all 0.3s ease;
        }
        .delivery-card:hover {
            border-color: #FF6B00;
            box-shadow: 0 0 20px rgba(255, 107, 0, 0.1);
        }
        input, select, textarea {
            background: #222 !important;
            border: 1px solid #444 !important;
            color: white !important;
            border-radius: 0.75rem !important;
            padding: 0.75rem 1rem !important;
            width: 100%;
            transition: all 0.3s ease;
        }
        input:focus, select:focus, textarea:focus {
            border-color: #FF6B00 !important;
            outline: none;
            background: #2a2a2a !important;
        }
        label {
            display: block;
            margin-bottom: 0.5rem;
            font-weight: 500;
            color: #ccc;
            font-size: 0.9rem;
        }
        .step-number {
            background: #FF6B00;
            color: black;
            width: 24px;
            height: 24px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            margin-right: 0.75rem;
            font-size: 0.8rem;
        }
        #map {
            height: 300px;
            border-radius: 1rem;
            z-index: 10;
        }
    </style>
}

<main class="relative z-10 pt-32 pb-20 px-6 md:px-12 max-w-[1440px] mx-auto">
    <div class="flex flex-col lg:flex-row gap-8">
        
        <!-- Left Column: Order Form -->
        <div class="lg:w-2/3 flex flex-col gap-8">
            
            <!-- Step 1: Pickup -->
            <div class="delivery-card">
                <h2 class="text-xl font-bold mb-6 flex items-center">
                    <span class="step-number">1</span> Điểm lấy hàng
                </h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="md:col-span-2">
                        <label>Địa chỉ lấy hàng</label>
                        <input type="text" placeholder="Nhập địa chỉ nhà, số đường...">
                    </div>
                    <div>
                        <label>Người liên hệ</label>
                        <input type="text" placeholder="Tên người gửi">
                    </div>
                    <div>
                        <label>Số điện thoại</label>
                        <input type="text" placeholder="0xxx xxx xxx">
                    </div>
                </div>
            </div>

            <!-- Step 2: Delivery -->
            <div class="delivery-card border-orange-900/30">
                <h2 class="text-xl font-bold mb-6 flex items-center text-brand-orange">
                    <span class="step-number">2</span> Điểm giao hàng
                </h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="md:col-span-2">
                        <label>Địa chỉ giao hàng</label>
                        <input type="text" placeholder="Nhập địa chỉ nhận hàng...">
                    </div>
                    <div>
                        <label>Người nhận</label>
                        <input type="text" placeholder="Tên người nhận">
                    </div>
                    <div>
                        <label>SĐT người nhận</label>
                        <input type="text" placeholder="0xxx xxx xxx">
                    </div>
                </div>
            </div>

            <!-- Step 3: Service -->
            <div class="delivery-card border-green-900/30">
                <h2 class="text-xl font-bold mb-6 flex items-center text-green-500">
                    <span class="step-number bg-green-500 text-black">3</span> Dịch vụ & Hàng hóa
                </h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label>Loại dịch vụ</label>
                        <select id="service-type">
                            <option value="standard">Giao hàng tiêu chuẩn</option>
                            <option value="fast">Giao hàng hỏa tốc</option>
                        </select>
                    </div>
                    <div>
                        <label>Trọng lượng (kg)</label>
                        <input type="number" id="weight" value="1" min="1">
                    </div>
                    <div class="md:col-span-2">
                        <label>Tên hàng hóa</label>
                        <input type="text" placeholder="VD: Quần áo, tài liệu...">
                    </div>
                    <div class="md:col-span-2">
                        <label>Ghi chú cho tài xế</label>
                        <textarea rows="3" placeholder="Ghi chú về hàng hóa hoặc chỉ dẫn đường..."></textarea>
                    </div>
                </div>
            </div>

            <button id="create-order-btn" class="w-full bg-brand-orange text-black font-bold py-4 rounded-2xl text-lg hover:shadow-[0_0_30px_rgba(255,107,0,0.4)] transition-all flex items-center justify-center gap-3">
                <i class="fa-solid fa-paper-plane"></i> Tạo đơn hàng ngay
            </button>
        </div>

        <!-- Right Column: Summary & Map -->
        <div class="lg:w-1/3 flex flex-col gap-6">
            <!-- Fee Estimate -->
            <div class="delivery-card bg-brand-dark border-brand-orange/30">
                <h3 class="text-lg font-bold mb-4 flex items-center gap-2">
                    <i class="fa-solid fa-calculator text-brand-orange"></i> Ước tính phí
                </h3>
                <div class="flex justify-between items-center py-4 border-t border-gray-800">
                    <span class="text-brand-gray">Tổng phí dịch vụ:</span>
                    <span id="estimated-fee" class="text-2xl font-bold text-brand-orange">---</span>
                </div>
                <p class="text-xs text-brand-gray italic">(*) Phí đã bao gồm VAT và phụ phí xăng dầu.</p>
            </div>

            <!-- Map Widget -->
            <div class="delivery-card bg-brand-dark">
                <h3 class="text-lg font-bold mb-4 flex items-center gap-2">
                    <i class="fa-solid fa-map-location-dot text-brand-orange"></i> Bản đồ
                </h3>
                <div id="map"></div>
            </div>
        </div>

    </div>
</main>

@section Scripts {
    <!-- Leaflet JS -->
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="~/js/delivery.js" asp-append-version="true"></script>
}
