@using DeliveryHubWeb.Models
@model DeliveryHubWeb.Models.Order

@{
    ViewData["Title"] = "Trạng thái đơn hàng";
    Layout = "~/Views/Shared/_Layout.cshtml"; 
}

<section class="pt-32 pb-16 px-6 md:px-12 bg-brand-black min-h-screen">
    <div class="max-w-[1200px] mx-auto">
        <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8 border-b border-gray-800 pb-4 gap-4">
            <div>
                <h1 class="text-3xl md:text-5xl font-black text-white">Đơn hàng <span class="text-brand-orange">@Model.OrderCode</span></h1>
                <p class="text-brand-gray mt-2"><i class="fa-solid fa-clock text-brand-orange"></i> Đặt lúc: @Model.CreatedAt.ToString("HH:mm - dd/MM/yyyy")</p>
            </div>
            <div id="status-badge" class="px-6 py-2 rounded-full font-black text-sm uppercase tracking-widest bg-yellow-500/20 text-yellow-500 border border-yellow-500/30">
                @Model.Status.ToString()
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Left Column: Map & Shipper Info -->
            <div class="lg:col-span-2 space-y-6">
                <!-- Map Container -->
                <div class="bg-gray-900 border border-gray-800 rounded-2xl p-2 relative">
                    <div id="trackingMap" class="w-full h-[400px] rounded-xl z-10 relative"></div>
                    <div id="map-loader" class="absolute inset-0 bg-gray-900/80 z-20 flex items-center justify-center rounded-2xl backdrop-blur-sm">
                        <i class="fa-solid fa-spinner fa-spin text-4xl text-brand-orange"></i>
                    </div>
                </div>

                <!-- Shipper Info (nếu có) -->
                <div id="shipper-info" class="bg-gray-900 border border-gray-800 rounded-2xl p-6 @(Model.ShipperId == null ? "hidden" : "")">
                    <h2 class="text-xl font-bold text-white mb-4 flex items-center gap-2"><i class="fa-solid fa-motorcycle text-brand-orange"></i> Thông tin Tài xế</h2>
                    <div class="flex items-center gap-4">
                        <div class="w-16 h-16 rounded-full bg-brand-orange text-black flex items-center justify-center text-xl font-black">
                            <i class="fa-solid fa-user-astronaut"></i>
                        </div>
                        <div>
                            <h3 class="text-lg font-bold text-white" id="shipper-name">@(Model.Shipper?.FullName ?? "Đang tải...")</h3>
                            <p class="text-brand-gray text-sm"><i class="fa-solid fa-phone text-brand-orange"></i> <span id="shipper-phone">@(Model.Shipper?.PhoneNumber ?? "---")</span></p>
                            <p class="text-xs text-brand-gray mt-1"><i class="fa-solid fa-id-card text-brand-orange"></i> <span id="shipper-plate">Biển số: Đang cập nhật</span></p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column: Order Details -->
            <div class="lg:col-span-1">
                <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6 sticky top-28">
                    <!-- Progress Timeline -->
                    <div class="mb-8">
                        <h2 class="text-lg font-bold text-white mb-4"><i class="fa-solid fa-bars-progress text-brand-orange"></i> Tiến trình giao hàng</h2>
                        <div class="relative pl-6 space-y-6 before:content-[''] before:absolute before:left-2 before:top-2 before:bottom-2 before:w-[2px] before:bg-gray-800">
                            <!-- Step 1 -->
                            <div class="relative">
                                <div class="absolute -left-[29px] top-1 w-4 h-4 rounded-full border-4 border-gray-900 @(Model.Status >= OrderStatus.Pending ? "bg-brand-orange" : "bg-gray-700")"></div>
                                <h4 class="text-white font-bold text-sm @(Model.Status >= OrderStatus.Pending ? "" : "text-brand-gray")">Đã tiếp nhận đơn</h4>
                                <p class="text-[10px] text-brand-gray">Hệ thống đang tìm tài xế gần nhất.</p>
                            </div>
                            <!-- Step 2 -->
                            <div class="relative">
                                <div class="absolute -left-[29px] top-1 w-4 h-4 rounded-full border-4 border-gray-900 @(Model.Status >= OrderStatus.Accepted ? "bg-brand-orange" : "bg-gray-700")"></div>
                                <h4 class="text-white font-bold text-sm @(Model.Status >= OrderStatus.Accepted ? "" : "text-brand-gray")">Tài xế đã nhận đơn</h4>
                                <p class="text-[10px] text-brand-gray">Tài xế đang di chuyển đến nhà hàng.</p>
                            </div>
                            <!-- Step 3 -->
                            <div class="relative">
                                <div class="absolute -left-[29px] top-1 w-4 h-4 rounded-full border-4 border-gray-900 @(Model.Status >= OrderStatus.Preparing ? "bg-brand-orange" : "bg-gray-700")"></div>
                                <h4 class="text-white font-bold text-sm @(Model.Status >= OrderStatus.Preparing ? "" : "text-brand-gray")">Nhà hàng chuẩn bị</h4>
                                <p class="text-[10px] text-brand-gray">Tài xế đã đến quán và đợi món.</p>
                            </div>
                            <!-- Step 4 -->
                            <div class="relative">
                                <div class="absolute -left-[29px] top-1 w-4 h-4 rounded-full border-4 border-gray-900 @(Model.Status >= OrderStatus.Delivering ? "bg-brand-orange" : "bg-gray-700")"></div>
                                <h4 class="text-white font-bold text-sm @(Model.Status >= OrderStatus.Delivering ? "" : "text-brand-gray")">Đang giao hàng</h4>
                                <p class="text-[10px] text-brand-gray">Tài xế đang trên đường đến giao cho bạn.</p>
                            </div>
                            <!-- Step 5 -->
                            <div class="relative">
                                <div class="absolute -left-[29px] top-1 w-4 h-4 rounded-full border-4 border-gray-900 @(Model.Status == OrderStatus.Completed ? "bg-green-500" : "bg-gray-700")"></div>
                                <h4 class="text-white font-bold text-sm @(Model.Status == OrderStatus.Completed ? "text-green-500" : "text-brand-gray")">Hoàn thành</h4>
                                <p class="text-[10px] text-brand-gray">Đơn hàng đã được giao thành công.</p>
                            </div>
                        </div>
                    </div>

                    <!-- Summary details -->
                    <div class="pt-4 border-t border-gray-800">
                        <div class="flex justify-between items-center mb-2">
                            <span class="text-xs text-brand-gray">Phí giao hàng</span>
                            <span class="text-sm font-bold text-white">@Model.ShippingFee.ToString("N0") đ</span>
                        </div>
                        <div class="flex justify-between items-center mb-6">
                            <span class="text-xs text-brand-gray">Tiền món ăn</span>
                            <span class="text-sm font-bold text-white">@Model.TotalPrice.ToString("N0") đ</span>
                        </div>
                        <div class="flex justify-between items-end border-t border-gray-800 pt-4">
                            <span class="text-white font-bold">Tổng cộng</span>
                            <span class="text-2xl font-black text-brand-orange">@((Model.TotalPrice + Model.ShippingFee).ToString("N0")) đ</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <!-- Leaflet & OSRM -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/7.0.5/signalr.min.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const currentStatus = '@Model.Status.ToString()';
            const orderId = @Model.Id;
            const orderCode = '@Model.OrderCode';
            let map, pickupMarker, deliveryMarker, shipperMarker, routeLine;

            const pLat = @Model.PickupLatitude.ToString(System.Globalization.CultureInfo.InvariantCulture);
            const pLng = @Model.PickupLongitude.ToString(System.Globalization.CultureInfo.InvariantCulture);
            const dLat = @Model.DeliveryLatitude.ToString(System.Globalization.CultureInfo.InvariantCulture);
            const dLng = @Model.DeliveryLongitude.ToString(System.Globalization.CultureInfo.InvariantCulture);

            // Init map
            map = L.map('trackingMap', { attributionControl: false }).setView([dLat, dLng], 14);
            L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png').addTo(map);

            const pickupIcon = L.divIcon({ className: 'custom-div-icon', html: "<div class='w-10 h-10 bg-black border-2 border-brand-orange rounded-full flex items-center justify-center shadow-[0_0_15px_rgba(255,107,0,0.5)]'><i class='fa-solid fa-store text-brand-orange'></i></div>", iconSize: [40, 40], iconAnchor: [20, 20] });
            const userIcon = L.divIcon({ className: 'custom-div-icon', html: "<div class='w-10 h-10 bg-brand-orange rounded-full flex items-center justify-center shadow-[0_0_15px_rgba(255,107,0,0.5)]'><i class='fa-solid fa-house text-black'></i></div>", iconSize: [40, 40], iconAnchor: [20, 20] });
            const shipperIcon = L.divIcon({ className: 'custom-div-icon', html: "<div class='w-12 h-12 bg-yellow-500 rounded-full flex items-center justify-center border-4 border-black z-50'><i class='fa-solid fa-motorcycle text-black text-xl'></i></div>", iconSize: [48, 48], iconAnchor: [24, 24] });

            pickupMarker = L.marker([pLat, pLng], { icon: pickupIcon }).addTo(map);
            deliveryMarker = L.marker([dLat, dLng], { icon: userIcon }).addTo(map);

            const group = new L.featureGroup([pickupMarker, deliveryMarker]);
            map.fitBounds(group.getBounds(), { padding: [50, 50] });

            // Fetch Route from Store to User
            async function drawRoute(startPoint, endPoint) {
                try {
                    const osrmUrl = `https://router.project-osrm.org/route/v1/driving/${startPoint[1]},${startPoint[0]};${endPoint[1]},${endPoint[0]}?overview=full&geometries=geojson`;
                    const res = await fetch(osrmUrl);
                    const data = await res.json();
                    
                    if (data.code === 'Ok') {
                        const coords = data.routes[0].geometry.coordinates.map(c => [c[1], c[0]]);
                        if (routeLine) map.removeLayer(routeLine);
                        
                        routeLine = L.polyline(coords, { color: '#FF6B00', weight: 4, dashArray: '10, 10' }).addTo(map);
                        document.getElementById('map-loader').classList.add('hidden');
                    }
                } catch (e) {
                    console.error("Lỗi vẽ đường OSRM", e);
                    document.getElementById('map-loader').classList.add('hidden');
                }
            }

            drawRoute([pLat, pLng], [dLat, dLng]);

            // SignalR Connection for Real-time update
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/orderHub")
                .withAutomaticReconnect()
                .build();

            connection.on("OrderStatusUpdated", (updatedOrderCode, status, shipperId, shipperName, shipperPhone) => {
                if (updatedOrderCode === orderCode) {
                    // Refresh trang luôn cho an toàn cập nhật UI
                    window.location.reload();
                }
            });

            // Giao diện shipper location (giả lập nếu shipper nhận đơn)
            if (currentStatus === 'Delivering' || currentStatus === 'Accepted') {
                shipperMarker = L.marker([pLat, pLng], { icon: shipperIcon, zIndexOffset: 1000 }).addTo(map);
            }

            connection.start().catch(err => console.error("SignalR Connection Error: ", err));

            // Format UI Status Label
            const badge = document.getElementById('status-badge');
            const mapStatusStr = {
                'Pending': 'Mới tạo',
                'SearchingShipper': 'Đang tìm tài xế',
                'Accepted': 'Tài xế đã nhận',
                'Preparing': 'Nhà hàng chuẩn bị',
                'Delivering': 'Đang giao hàng',
                'Completed': 'Hoàn thành',
                'Cancelled': 'Đã hủy'
            };
            badge.innerText = mapStatusStr[currentStatus] || currentStatus;
            
            if (currentStatus === 'Completed') {
                badge.className = 'px-6 py-2 rounded-full font-black text-sm uppercase tracking-widest bg-green-500/20 text-green-500 border border-green-500/30';
            } else if (currentStatus === 'Delivering') {
                badge.className = 'px-6 py-2 rounded-full font-black text-sm uppercase tracking-widest bg-brand-orange/20 text-brand-orange border border-brand-orange/30';
            }
        });
    </script>
}
