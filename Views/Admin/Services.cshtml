@model IEnumerable<DeliveryHubWeb.Models.DeliveryService>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Quản lý Dịch vụ & Giá cước";
}

<div class="mb-12 mt-4 p-8 bg-white/[0.03] border border-white/5 rounded-[40px] flex justify-between items-center fade-in relative z-10 backdrop-blur-xl shadow-2xl flex-wrap gap-4">
    <div class="space-y-1">
        <h2 class="text-4xl font-black text-white tracking-tighter">Dịch vụ & <span class="text-brand-orange">Giá cước</span></h2>
        <div class="flex items-center gap-3">
            <span class="px-2 py-0.5 bg-brand-orange/10 border border-brand-orange/20 rounded text-[10px] font-bold text-brand-orange uppercase tracking-wider">Dashboard</span>
            <p class="text-brand-gray text-[10px] font-bold uppercase tracking-widest mt-1 flex gap-2">
                <span>Tổng cộng <span class="text-white font-black">@Model.Count()</span> dịch vụ</span>
                <span>&bull;</span>
                <span><span class="text-green-500 font-black">@Model.Count(s => s.IsActive)</span> Đang hoạt động</span>
                <span>&bull;</span>
                <span><span class="text-red-500 font-black">@Model.Count(s => !s.IsActive)</span> Ngừng hoạt động</span>
            </p>
        </div>
    </div>

    <div class="flex flex-wrap items-center gap-4">
        <!-- Status Filter -->
        <div class="relative flex items-center bg-white/5 p-1.5 rounded-2xl border border-white/10">
            <div id="statusPill" class="absolute top-1.5 bottom-1.5 rounded-xl transition-all duration-500 ease-in-out pointer-events-none z-0 bg-white/10 shadow-lg shadow-white/5"></div>
            <button onclick="filterServices('status', 'all', this)" data-color="text-white" data-pill="bg-white/10 shadow-lg shadow-white/5" class="filter-btn status-btn active relative z-10 px-4 py-2 rounded-xl text-xs font-bold text-white transition-all duration-300">Tất cả</button>
            <button onclick="filterServices('status', 'active', this)" data-color="text-green-500" data-pill="bg-green-500/10 border border-green-500/50 shadow-[0_0_15px_rgba(34,197,94,0.2)]" class="filter-btn status-btn relative z-10 px-4 py-2 rounded-xl text-xs font-bold text-brand-gray hover:text-white transition-all duration-300">Đang hoạt động</button>
            <button onclick="filterServices('status', 'inactive', this)" data-color="text-red-500" data-pill="bg-red-500/10 border border-red-500/50 shadow-[0_0_15px_rgba(239,68,68,0.2)]" class="filter-btn status-btn relative z-10 px-4 py-2 rounded-xl text-xs font-bold text-brand-gray hover:text-white transition-all duration-300">Ngừng hoạt động</button>
        </div>

        <!-- Type Filter -->
        <div class="relative flex items-center bg-white/5 p-1.5 rounded-2xl border border-white/10">
            <div id="typePill" class="absolute top-1.5 bottom-1.5 rounded-xl transition-all duration-500 ease-in-out pointer-events-none z-0 bg-white/10 shadow-lg shadow-white/5"></div>
            <button onclick="filterServices('type', 'all', this)" data-color="text-white" data-pill="bg-white/10 shadow-lg shadow-white/5" class="filter-btn type-btn active relative z-10 px-4 py-2 rounded-xl text-xs font-bold text-white transition-all duration-300">Tất cả</button>
            <button onclick="filterServices('type', 'package', this)" data-color="text-brand-orange" data-pill="bg-brand-orange/10 border border-brand-orange/50 shadow-[0_0_15px_rgba(255,107,0,0.2)]" class="filter-btn type-btn relative z-10 px-4 py-2 rounded-xl text-xs font-bold text-brand-gray hover:text-white transition-all duration-300">Hàng hóa</button>
            <button onclick="filterServices('type', 'food', this)" data-color="text-yellow-400" data-pill="bg-yellow-400/10 border border-yellow-400/50 shadow-[0_0_15px_rgba(250,204,21,0.2)]" class="filter-btn type-btn relative z-10 px-4 py-2 rounded-xl text-xs font-bold text-brand-gray hover:text-white transition-all duration-300">Đồ ăn</button>
        </div>

        <button onclick="openModal()" class="h-12 px-6 bg-brand-orange text-black font-black text-xs rounded-2xl hover:bg-white hover:scale-105 active:scale-95 transition-all shadow-lg shadow-brand-orange/20 flex items-center justify-center gap-2">
            <i class="fa-solid fa-plus"></i> Thêm dịch vụ
        </button>
    </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-8 pb-12 fade-in" style="animation-delay: 0.2s">
@foreach (var srv in Model)
    {
        var pinnedClass = srv.IsPinned ? "border-brand-orange" : "border-white/5";
        var pinnedGlow = srv.IsPinned ? "box-shadow: 0 0 15px rgba(255,107,0,0.15);" : "";

        <div class="service-card bg-brand-dark/50 backdrop-blur-xl rounded-[2rem] border @pinnedClass p-8 shadow-2xl relative group hover:border-brand-orange/50 transition-colors flex flex-col h-full" style="@pinnedGlow" data-status="@(srv.IsActive ? "active" : "inactive")" data-type="@(srv.ServiceType == "Giao đồ ăn" ? "food" : "package")">
            
            <!-- Actions (Pin & Context Menu) -->
            <div class="absolute top-1 right-1 z-10 flex gap-2">
                <button onclick="togglePin(@srv.Id)" class="w-8 h-8 rounded-full flex items-center justify-center transition-colors @(srv.IsPinned ? "bg-brand-orange/10 text-brand-orange" : "bg-white/5 text-brand-gray hover:bg-white/10")" title="Ghim">
                    <i class="fa-solid fa-thumbtack text-[11px]"></i>
                </button>
                <div class="relative service-menu-container">
                    <button onclick="toggleServiceMenu(@srv.Id, event)" class="w-8 h-8 rounded-full bg-white/5 hover:bg-white/10 flex items-center justify-center text-brand-gray transition-colors">
                        <i class="fa-solid fa-ellipsis-vertical"></i>
                    </button>
                    <div id="menu-@srv.Id" class="absolute right-0 top-10 w-32 bg-[#1e293b] border border-white/10 rounded-2xl shadow-xl hidden overflow-hidden p-1 z-50">
                        <button onclick="openModal(@srv.Id)" class="w-full px-3 py-2.5 rounded-lg text-left text-[13px] font-bold text-blue-400 hover:bg-white/5 flex items-center gap-2 mb-0.5">
                            <i class="fa-solid fa-pen text-[11px] w-4 text-center"></i> Sửa
                        </button>
                        <button onclick="deleteService(@srv.Id, '@srv.Name')" class="w-full px-3 py-2.5 rounded-lg text-left text-[13px] font-bold text-red-500 hover:bg-white/5 flex items-center gap-2 border-t border-white/5">
                            <i class="fa-solid fa-trash-can text-[11px] w-4 text-center"></i> Xóa
                        </button>
                    </div>
                </div>
            </div>

            <!-- Header: Title & Status -->
            <div class="mb-4">
                <div class="flex items-center gap-3 w-full mb-3">
                    <h3 class="text-xl font-black text-white flex items-center gap-3 max-w-[70%]">
                        <i class="fa-solid @srv.Icon text-brand-orange w-6 text-center"></i>
                        <span class="truncate">@srv.Name</span>
                    </h3>
                    @if(srv.ServiceType == "Giao đồ ăn") {
                        <span class="text-[9px] font-black text-brand-orange tracking-widest uppercase bg-brand-orange/10 px-2 py-1 rounded backdrop-blur-sm border border-brand-orange/20 whitespace-nowrap mt-0.5">Món ăn</span>
                    } else {
                        <span class="text-[9px] font-black text-brand-orange tracking-widest uppercase bg-brand-orange/10 px-2 py-1 rounded backdrop-blur-sm border border-brand-orange/20 whitespace-nowrap mt-0.5">Hàng hóa</span>
                    }
                </div>
                <div class="mt-3 flex items-center gap-2">
                    @if(srv.IsActive) {
                        <div class="px-2.5 py-1 rounded-full bg-green-500/10 border border-green-500/20 flex items-center gap-1.5 w-max">
                            <div class="w-1.5 h-1.5 rounded-full bg-green-500"></div>
                            <span class="text-[9px] font-black text-green-500 uppercase tracking-wider">Đang hoạt động</span>
                        </div>
                    } else {
                        <div class="px-2.5 py-1 rounded-full bg-red-500/10 border border-red-500/20 flex items-center gap-1.5 w-max">
                            <div class="w-1.5 h-1.5 rounded-full bg-red-500"></div>
                            <span class="text-[9px] font-black text-red-500 uppercase tracking-wider">Ngừng hoạt động</span>
                        </div>
                    }
                </div>
            </div>

            <!-- Description -->
            <p class="text-xs text-brand-gray/80 font-bold leading-relaxed mb-6 flex-1 min-h-[40px]">@srv.Description</p>

            <!-- Pricing List -->
            <div class="space-y-3 mb-6 bg-white/[0.02] p-4 rounded-2xl border border-white/5">
                <div class="flex justify-between items-center">
                    <span class="text-[11px] font-bold text-brand-gray/80">Phí cơ bản</span>
                    <span class="text-sm font-black text-white">@srv.BaseFee.ToString("N0")<span class="text-[9px] text-brand-orange ml-0.5">vnd</span></span>
                </div>
                <div class="flex justify-between items-center">
                    <span class="text-[11px] font-bold text-brand-gray/80">Phí/km</span>
                    <span class="text-sm font-black text-white">@srv.FeePerKm.ToString("N0")<span class="text-[9px] text-brand-orange ml-0.5">vnd</span></span>
                </div>
                @if (srv.ServiceType != "Giao đồ ăn")
                {
                    <div class="flex justify-between items-center">
                        <span class="text-[11px] font-bold text-brand-gray/80">Phụ phí/kg</span>
                        <span class="text-sm font-black text-brand-orange">@srv.ExtraFeePerKg.ToString("N0")<span class="text-[9px] text-brand-orange/50 ml-0.5">vnd</span></span>
                    </div>
                }
            </div>

            <!-- Footer Tags -->
            <div class="flex flex-wrap items-center gap-3 pt-4 border-t border-white/5">
                <div class="px-3 py-1.5 rounded-lg bg-white/5 border border-white/5 text-[9px] font-bold text-brand-gray uppercase tracking-widest flex items-center gap-1.5">
                    @if(srv.ServiceType == "Giao đồ ăn")
                    {
                        <i class="fa-solid fa-burger text-white/40"></i> <span>Giao đồ ăn</span>
                    }
                    else
                    {
                         <i class="fa-solid fa-weight-scale text-white/40"></i> <span>Tối đa: @srv.MaxWeightKg kg</span>
                    }
                </div>
                <div class="px-3 py-1.5 rounded-lg bg-white/5 border border-white/5 text-[9px] font-bold text-brand-gray uppercase tracking-widest flex items-center gap-1.5">
                    <i class="fa-solid fa-stopwatch text-white/40"></i> ~@srv.EstimatedMinutesPerKm phút/km
                </div>
                @if(srv.ServiceType != "Giao đồ ăn")
                {
                    <div class="px-3 py-1.5 rounded-lg bg-brand-orange/10 border border-brand-orange/20 text-[9px] font-black text-brand-orange uppercase tracking-widest flex items-center gap-1.5 ml-auto">
                        <i class="fa-solid fa-van-shuttle"></i> @srv.VehicleType
                    </div>
                }
            </div>
        </div>
    }
</div>

<!-- Modal Form -->
<div id="serviceModal" class="fixed inset-0 z-50 hidden flex items-center justify-center p-4">
    <div class="absolute inset-0 bg-brand-black/80 backdrop-blur-md" onclick="closeModal()"></div>
    <div id="modalBody" class="bg-brand-dark w-full max-w-xl rounded-[2rem] border border-white/10 shadow-2xl relative z-10 scale-95 opacity-0 transform-gpu overflow-hidden flex flex-col max-h-[90vh]">
        <!-- Header -->
        <div class="px-8 py-6 border-b border-white/5 flex justify-between items-center bg-transparent">
            <h3 id="modalTitle" class="text-xl font-black text-white tracking-tight">Thêm Dịch Vụ Mới</h3>
            <button onclick="closeModal()" class="w-8 h-8 rounded-full bg-white/5 hover:bg-red-500/20 text-brand-gray hover:text-white flex items-center justify-center transition-colors">
                <i class="fa-solid fa-xmark"></i>
            </button>
        </div>

        <!-- Body -->
        <div class="p-8 overflow-y-auto custom-scrollbar">
            <form id="serviceForm" class="space-y-6">
                <input type="hidden" id="serviceId" value="0" />

                <!-- Row 1: Name -->
                <div>
                    <label class="block text-[10px] font-black text-brand-gray uppercase tracking-widest mb-2">Tên dịch vụ <span class="text-brand-orange">*</span></label>
                    <input type="text" id="serviceName" required placeholder="VD: Giao hàng nhanh" class="w-full bg-[#1e293b] border border-white/5 rounded-xl px-4 py-3 text-sm font-bold text-white focus:border-brand-orange/50 outline-none transition-colors" />
                </div>

                <!-- Row 2: Description -->
                <div>
                    <label class="block text-[10px] font-black text-brand-gray uppercase tracking-widest mb-2">Mô tả</label>
                    <textarea id="serviceDesc" rows="2" placeholder="Giao hàng ngay trong 1-2 giờ..." class="w-full bg-[#1e293b] border border-white/5 rounded-xl px-4 py-3 text-sm font-bold text-white focus:border-brand-orange/50 outline-none transition-colors resize-none"></textarea>
                </div>

                <div class="grid grid-cols-3 gap-4 relative" id="row-1" style="overflow: visible;">
                    <input type="hidden" id="serviceType" value="Giao hàng" />
                    <input type="hidden" id="serviceVehicle" value="Tất cả" />
                    <input type="hidden" id="serviceStatus" value="true" />
                    
                    <!-- Custom Service Type Dropdown -->
                    <div class="relative custom-dropdown">
                        <label class="block text-[10px] font-black text-brand-gray uppercase tracking-widest mb-2">Loại dịch vụ</label>
                        <div onclick="toggleDropdown('dd-type', event)" class="w-full bg-[#1e293b] border border-white/5 rounded-xl px-4 py-3 text-sm font-bold text-white flex justify-between items-center cursor-pointer transition-colors hover:border-brand-orange/50">
                            <span id="label-type">Giao hàng</span>
                            <i class="fa-solid fa-chevron-down text-[10px] text-brand-gray transition-transform duration-300"></i>
                        </div>
                        <div id="dd-type" class="absolute top-[110%] left-0 w-full bg-[#1e293b] border border-white/5 rounded-2xl shadow-[0_10px_30px_rgba(0,0,0,0.5)] hidden flex-col z-[100] p-1.5 transition-all opacity-0 origin-top scale-95 border-brand-orange/20">
                            <div onclick="selectType('Giao hàng')" class="px-4 py-2.5 rounded-lg cursor-pointer text-[13px] font-bold text-white hover:bg-brand-orange/10 hover:text-brand-orange transition-colors">Giao hàng</div>
                            <div onclick="selectType('Giao đồ ăn')" class="px-4 py-2.5 rounded-lg cursor-pointer text-[13px] font-bold text-white hover:bg-brand-orange/10 hover:text-brand-orange transition-colors">Giao đồ ăn</div>
                        </div>
                    </div>

                    <!-- Custom Vehicle Type Dropdown -->
                    <div class="relative custom-dropdown" id="container-vehicle">
                        <label class="block text-[10px] font-black text-brand-gray uppercase tracking-widest mb-2">Loại xe yêu cầu</label>
                        <div onclick="toggleDropdown('dd-vehicle', event)" class="w-full bg-[#1e293b] border border-white/5 rounded-xl px-4 py-3 text-sm font-bold text-white flex justify-between items-center cursor-pointer transition-colors hover:border-brand-orange/50">
                            <span id="label-vehicle">Tất cả</span>
                            <i class="fa-solid fa-chevron-down text-[10px] text-brand-gray transition-transform duration-300"></i>
                        </div>
                        <div id="dd-vehicle" class="absolute top-[110%] left-0 w-full bg-[#1e293b] border border-white/5 rounded-2xl shadow-[0_10px_30px_rgba(0,0,0,0.5)] hidden flex-col z-[100] p-1.5 transition-all opacity-0 origin-top scale-95 border-brand-orange/20">
                            <div onclick="selectVehicle('Tất cả')" class="px-4 py-2.5 rounded-lg cursor-pointer text-[13px] font-bold text-white hover:bg-brand-orange/10 hover:text-brand-orange transition-colors">Tất cả</div>
                            <div onclick="selectVehicle('Xe máy')" class="px-4 py-2.5 rounded-lg cursor-pointer text-[13px] font-bold text-white hover:bg-brand-orange/10 hover:text-brand-orange transition-colors">Xe máy</div>
                            <div onclick="selectVehicle('Xe ba gác')" class="px-4 py-2.5 rounded-lg cursor-pointer text-[13px] font-bold text-white hover:bg-brand-orange/10 hover:text-brand-orange transition-colors">Xe ba gác</div>
                            <div onclick="selectVehicle('Xe tải')" class="px-4 py-2.5 rounded-lg cursor-pointer text-[13px] font-bold text-white hover:bg-brand-orange/10 hover:text-brand-orange transition-colors">Xe tải</div>
                        </div>
                    </div>
                    
                    <!-- Custom Status Dropdown -->
                    <div class="relative custom-dropdown">
                        <label class="block text-[10px] font-black text-brand-gray uppercase tracking-widest mb-2">Trạng thái</label>
                        <div onclick="toggleDropdown('dd-status', event)" class="w-full bg-[#1e293b] border border-white/5 rounded-xl px-4 py-3 text-sm font-bold flex justify-between items-center cursor-pointer transition-colors hover:border-brand-orange/50">
                            <span id="label-status" class="text-green-500">Đang hoạt động</span>
                            <i class="fa-solid fa-chevron-down text-[10px] text-brand-gray transition-transform duration-300"></i>
                        </div>
                        <div id="dd-status" class="absolute top-[110%] left-0 w-full bg-[#1e293b] border border-white/5 rounded-2xl shadow-[0_10px_30px_rgba(0,0,0,0.5)] hidden flex-col z-[100] p-1.5 transition-all opacity-0 origin-top scale-95 border-brand-orange/20">
                            <div onclick="selectStatus('true', 'Đang hoạt động', 'text-green-500')" class="px-4 py-2.5 rounded-lg cursor-pointer text-[13px] font-bold text-green-500 border-l-[3px] border-transparent hover:border-green-500 hover:bg-green-500/10 transition-all mb-0.5">Đang hoạt động</div>
                            <div onclick="selectStatus('false', 'Ngừng hoạt động', 'text-red-500')" class="px-4 py-2.5 rounded-lg cursor-pointer text-[13px] font-bold text-red-500 border-l-[3px] border-transparent hover:border-red-500 hover:bg-red-500/10 transition-all">Ngừng hoạt động</div>
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-6" id="row-2">
                    <!-- Max Weight -->
                    <div class="relative group" id="container-weight">
                        <label class="block text-[10px] font-black text-brand-gray uppercase tracking-widest mb-2">Trọng lượng tối đa (kg)</label>
                        <input type="number" id="serviceWeight" value="30" class="w-full bg-[#1e293b] border border-white/5 rounded-xl px-4 py-3 text-sm font-bold text-white focus:border-brand-orange/50 outline-none transition-colors appearance-none scroll-smooth" />
                    </div>
                    <!-- Est Time -->
                    <div class="relative group">
                        <label class="block text-[10px] font-black text-brand-gray uppercase tracking-widest mb-2">Thời gian dự kiến (phút/km)</label>
                        <input type="number" id="serviceTime" value="4" class="w-full bg-[#1e293b] border border-white/5 rounded-xl px-4 py-3 text-sm font-bold text-white focus:border-brand-orange/50 outline-none transition-colors appearance-none scroll-smooth" />
                    </div>
                </div>

                <hr class="border-white/5" />

                <!-- Pricing -->
                <div class="grid grid-cols-3 gap-4" id="row-3">
                    <div class="relative group">
                        <label class="block text-[10px] font-black text-brand-gray uppercase tracking-widest mb-2">Phí cơ bản</label>
                        <input type="number" id="serviceBaseFee" value="15000" class="w-full bg-[#1e293b] border border-white/5 rounded-xl px-4 py-3 text-sm font-bold text-white focus:border-brand-orange/50 outline-none transition-colors appearance-none scroll-smooth" />
                    </div>
                    <div class="relative group">
                        <label class="block text-[10px] font-black text-brand-gray uppercase tracking-widest mb-2">Phí / km</label>
                        <input type="number" id="serviceFeeKm" value="5000" class="w-full bg-[#1e293b] border border-white/5 rounded-xl px-4 py-3 text-sm font-bold text-white focus:border-brand-orange/50 outline-none transition-colors appearance-none scroll-smooth" />
                    </div>
                    <div class="relative group" id="container-extrafee">
                        <label class="block text-[10px] font-black text-brand-orange uppercase tracking-widest mb-2">Phụ phí / kg</label>
                        <input type="number" id="serviceExtraFee" value="2000" class="w-full bg-brand-orange/10 border border-brand-orange/20 rounded-xl px-4 py-3 text-sm font-black text-brand-orange focus:border-brand-orange outline-none transition-colors appearance-none scroll-smooth" />
                    </div>
                </div>
            </form>
        </div>

        <!-- Footer -->
        <div class="px-8 py-5 border-t border-white/5 bg-white/[0.02] flex justify-end gap-4">
            <button type="button" onclick="closeModal()" class="px-6 py-2.5 rounded-xl border border-white/10 text-xs font-bold text-brand-gray hover:text-white hover:bg-white/5 transition-colors">
                Đóng
            </button>
            <button type="button" onclick="saveService()" class="px-6 py-2.5 rounded-xl bg-blue-600 text-white text-xs font-black hover:bg-blue-500 hover:shadow-[0_0_15px_rgba(37,99,235,0.4)] transition-all flex items-center gap-2">
                <i class="fa-solid fa-save"></i> Lưu thông tin
            </button>
        </div>
    </div>
</div>


<style>
    .fade-in { animation: fadeIn 0.6s ease-out forwards; opacity: 0; }
    @@keyframes fadeIn { from { opacity: 0; transform: translateY(15px); } to { opacity: 1; transform: translateY(0); } }
    .custom-scrollbar::-webkit-scrollbar { width: 6px; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 10px; }

    /* Custom Number Input Spin Buttons */
    input[type=number]::-webkit-inner-spin-button, 
    input[type=number]::-webkit-outer-spin-button { 
        -webkit-appearance: none; 
        margin: 0; 
    }
    input[type=number] {
        -moz-appearance: textfield;
    }
</style>

<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<script>
    // --- FILTER LOGIC ---
    let currentStatusFilter = 'all';
    let currentTypeFilter = 'all';

    function filterServices(filterCategory, value, btnElem) {
        // Find pill
        const pillId = filterCategory === 'status' ? 'statusPill' : 'typePill';
        const pill = document.getElementById(pillId);
        
        // Update button styles
        const btns = btnElem.parentElement.querySelectorAll(`.${filterCategory}-btn`);
        btns.forEach(btn => {
            const colorClass = btn.getAttribute('data-color');
            if (colorClass) {
                btn.classList.remove('active', colorClass);
            }
            btn.classList.add('text-brand-gray');
        });
        
        const colorClass = btnElem.getAttribute('data-color');
        btnElem.classList.remove('text-brand-gray');
        if (colorClass) {
            btnElem.classList.add('active', colorClass);
        }

        // Update Pill
        if (pill) {
            const pillClasses = btnElem.getAttribute('data-pill');
            pill.className = `absolute top-1.5 bottom-1.5 rounded-xl transition-all duration-500 ease-in-out pointer-events-none z-0 ${pillClasses}`;
            pill.style.left = btnElem.offsetLeft + 'px';
            pill.style.width = btnElem.offsetWidth + 'px';
        }

        // Update state
        if (filterCategory === 'status') currentStatusFilter = value;
        if (filterCategory === 'type') currentTypeFilter = value;

        // Apply filters
        const cards = document.querySelectorAll('.service-card');
        cards.forEach(card => {
            const matchStatus = currentStatusFilter === 'all' || card.dataset.status === currentStatusFilter;
            const matchType = currentTypeFilter === 'all' || card.dataset.type === currentTypeFilter;

            if (matchStatus && matchType) {
                card.style.display = 'flex';
            } else {
                card.style.display = 'none';
            }
        });
    }

    function initPills() {
        document.querySelectorAll('.filter-btn.active').forEach(activeBtn => {
            const isStatus = activeBtn.classList.contains('status-btn');
            const pill = document.getElementById(isStatus ? 'statusPill' : 'typePill');
            if (pill) {
                setTimeout(() => {
                    pill.style.left = activeBtn.offsetLeft + 'px';
                    pill.style.width = activeBtn.offsetWidth + 'px';
                }, 50); // Short delay to ensure DOM is ready
            }
        });
    }

    if (document.fonts) {
        document.fonts.ready.then(initPills);
    } else {
        window.addEventListener('load', initPills);
    }
    window.addEventListener('resize', initPills);

    // --- DROPDOWN & MENU LOGIC ---
    let activeDropdown = null;

    function toggleDropdown(id, event) {
        event.stopPropagation();
        const isOpening = activeDropdown !== id;
        closeAllDropdowns();
        
        if (isOpening) {
            const dropdown = document.getElementById(id);
            const icon = dropdown.previousElementSibling.querySelector('i');
            dropdown.classList.remove('hidden');
            // small delay for transition
            setTimeout(() => {
                dropdown.classList.remove('opacity-0', 'scale-95');
                icon.classList.add('rotate-180');
            }, 10);
            activeDropdown = id;
        }
    }

    function selectVehicle(val) {
        document.getElementById('serviceVehicle').value = val;
        document.getElementById('label-vehicle').innerText = val;
        closeAllDropdowns();
    }

    function selectType(val) {
        document.getElementById('serviceType').value = val;
        document.getElementById('label-type').innerText = val;
        closeAllDropdowns();
        
        let shouldHide = (val === 'Giao đồ ăn');
        document.getElementById('container-vehicle').style.display = shouldHide ? 'none' : 'block';
        document.getElementById('container-weight').style.display = shouldHide ? 'none' : 'block';
        document.getElementById('container-extrafee').style.display = shouldHide ? 'none' : 'block';

        if(shouldHide) {
            document.getElementById('row-1').classList.replace('grid-cols-3', 'grid-cols-2');
            document.getElementById('row-2').classList.replace('grid-cols-2', 'grid-cols-1');
            document.getElementById('row-3').classList.replace('grid-cols-3', 'grid-cols-2');
            
            selectVehicle("Tất cả");
            document.getElementById('serviceWeight').value = "0";
            document.getElementById('serviceExtraFee').value = "0";
        } else {
            document.getElementById('row-1').classList.replace('grid-cols-2', 'grid-cols-3');
            document.getElementById('row-2').classList.replace('grid-cols-1', 'grid-cols-2');
            document.getElementById('row-3').classList.replace('grid-cols-2', 'grid-cols-3');
        }
    }

    function selectStatus(val, text, colorClass) {
        document.getElementById('serviceStatus').value = val;
        const label = document.getElementById('label-status');
        label.innerText = text;
        label.className = colorClass; // e.g. text-green-500
        closeAllDropdowns();
    }

    function closeAllDropdowns() {
        document.querySelectorAll('.custom-dropdown > div[id^="dd-"]').forEach(dd => {
            if (!dd.classList.contains('hidden')) {
                dd.classList.add('opacity-0', 'scale-95');
                const icon = dd.previousElementSibling.querySelector('i');
                if(icon) icon.classList.remove('rotate-180');
                setTimeout(() => dd.classList.add('hidden'), 200);
            }
        });
        activeDropdown = null;
    }

    let activeMenuId = null;
    function toggleServiceMenu(id, event) {
        event.stopPropagation();
        const menu = document.getElementById(`menu-${id}`);
        if(activeMenuId && activeMenuId !== id) {
            document.getElementById(`menu-${activeMenuId}`).classList.add('hidden');
        }
        if (menu.classList.contains('hidden')) {
            menu.classList.remove('hidden');
            activeMenuId = id;
        } else {
            menu.classList.add('hidden');
            activeMenuId = null;
        }
    }

    function closeAllMenus() {
        if(activeMenuId) {
            document.getElementById(`menu-${activeMenuId}`).classList.add('hidden');
            activeMenuId = null;
        }
    }

    // Global click listener to close dropdowns and menus
    document.addEventListener('click', function(e) {
        if (!e.target.closest('.custom-dropdown')) closeAllDropdowns();
        if (!e.target.closest('.service-menu-container')) closeAllMenus();
    });

    // --- CRUD & PIN LOGIC ---
    function openModal(id = 0) {
        closeAllMenus();
        document.getElementById('serviceId').value = id;
        document.getElementById('modalTitle').innerText = id === 0 ? "Thêm Dịch Vụ Mới" : "Sửa Dịch Vụ";
        
        if (id === 0) {
            document.getElementById('serviceForm').reset();
            document.getElementById('serviceId').value = "0";
            selectType("Giao hàng");
            selectVehicle("Tất cả");
            selectStatus("true", "Đang hoạt động", "text-green-500");
            showModal();
        } else {
            fetch(`/Admin/GetDeliveryService/${id}`)
                .then(r => r.json())
                .then(data => {
                    document.getElementById('serviceName').value = data.name;
                    document.getElementById('serviceDesc').value = data.description;
                    
                    selectType(data.serviceType || "Giao hàng");
                    selectVehicle(data.vehicleType || "Tất cả");
                    if(data.isActive) selectStatus("true", "Đang hoạt động", "text-green-500");
                    else selectStatus("false", "Ngừng hoạt động", "text-red-500");

                    document.getElementById('serviceWeight').value = data.maxWeightKg;
                    document.getElementById('serviceTime').value = data.estimatedMinutesPerKm;
                    document.getElementById('serviceBaseFee').value = data.baseFee;
                    document.getElementById('serviceFeeKm').value = data.feePerKm;
                    document.getElementById('serviceExtraFee').value = data.extraFeePerKg;
                    showModal();
                });
        }
    }

    function showModal() {
        const modal = document.getElementById('serviceModal');
        const body = document.getElementById('modalBody');
        modal.classList.remove('hidden');
        gsap.to(body, { duration: 0.5, scale: 1, opacity: 1, ease: "back.out(1.2)" });
    }

    function closeModal() {
        closeAllDropdowns();
        const modal = document.getElementById('serviceModal');
        const body = document.getElementById('modalBody');
        gsap.to(body, { duration: 0.3, scale: 0.95, opacity: 0, ease: "power2.in", onComplete: () => {
            modal.classList.add('hidden');
        }});
    }

    function saveService() {
        const payload = {
            id: parseInt(document.getElementById('serviceId').value),
            name: document.getElementById('serviceName').value,
            description: document.getElementById('serviceDesc').value,
            serviceType: document.getElementById('serviceType').value,
            vehicleType: document.getElementById('serviceVehicle').value,
            isActive: document.getElementById('serviceStatus').value === "true",
            maxWeightKg: parseInt(document.getElementById('serviceWeight').value) || 0,
            estimatedMinutesPerKm: parseInt(document.getElementById('serviceTime').value) || 0,
            baseFee: parseFloat(document.getElementById('serviceBaseFee').value) || 0,
            feePerKm: parseFloat(document.getElementById('serviceFeeKm').value) || 0,
            extraFeePerKg: parseFloat(document.getElementById('serviceExtraFee').value) || 0
        };

        if(!payload.name) {
            alert('Vui lòng nhập tên dịch vụ!');
            return;
        }

        fetch('/Admin/SaveDeliveryService', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload)
        })
        .then(r => r.json())
        .then(res => {
            if (res.success) {
                window.location.reload();
            } else {
                alert('Lỗi: ' + res.message);
            }
        });
    }

    async function deleteService(id, name) {
        closeAllMenus();
        const res = await window.showAdminConfirm(
            'Xóa Dịch vụ này', 
            `Bạn có chắc muốn xóa dịch vụ "${name}" vĩnh viễn`, 
            'error', 
            'Đồng ý xóa', 'Từ chối'
        );
        if (res.isConfirmed) {
            fetch('/Admin/DeleteDeliveryService', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(id)
            })
            .then(r => r.json())
            .then(async result => {
                if(result.success) {
                    await window.showAdminAlert("Thành công", "Đã xóa dịch vụ.", "destructive-success");
                    window.location.reload();
                } else {
                    await window.showAdminAlert("Lỗi", "Lỗi: " + result.message, "error");
                }
            });
        }
    }

    function togglePin(id) {
        fetch('/Admin/TogglePinService', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(id)
        })
        .then(r => r.json())
        .then(res => {
            if(res.success) window.location.reload();
        });
    }
</script>
