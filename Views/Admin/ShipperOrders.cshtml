@model IEnumerable<DeliveryHubWeb.Models.Order>
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Lịch sử đơn hàng - " + ViewBag.ShipperName;

    // Helper function for Status Labels
    string GetStatusLabel(OrderStatus status) => status switch {
        OrderStatus.Pending or OrderStatus.Preparing => "Nhận đơn",
        OrderStatus.SearchingShipper or OrderStatus.Accepted => "Chờ vận chuyển",
        OrderStatus.Delivering => "Đang giao",
        OrderStatus.Completed => "Thành công",
        OrderStatus.Cancelled => "Đã hủy",
        OrderStatus.Failed => "Thất bại",
        _ => status.ToString()
    };

    string GetStatusClass(OrderStatus status) => status switch {
        OrderStatus.Pending or OrderStatus.Preparing => "bg-yellow-500/10 text-yellow-500",
        OrderStatus.SearchingShipper or OrderStatus.Accepted => "bg-pink-500/10 text-pink-500 border border-pink-500/20",
        OrderStatus.Delivering => "bg-brand-orange/10 text-brand-orange",
        OrderStatus.Completed => "bg-green-500/20 text-green-400 border border-green-500/20",
        OrderStatus.Cancelled => "bg-blue-500/10 text-blue-400 border border-blue-500/20",
        OrderStatus.Failed => "bg-red-500/20 text-red-500 border border-red-500/20",
        _ => "bg-gray-500/10 text-gray-500"
    };
}

<div class="mb-12 mt-4 p-8 bg-white/[0.03] border border-white/5 rounded-[40px] flex justify-between items-center fade-in relative z-10 backdrop-blur-xl shadow-2xl">
    <div class="space-y-1">
        <div class="flex items-center gap-3 mb-2">
            <a href="/Admin/ShipperDetail/@ViewBag.ShipperId" class="w-8 h-8 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-brand-orange hover:text-black transition-all">
                <i class="fa-solid fa-arrow-left text-xs"></i>
            </a>
            <span class="px-2 py-0.5 bg-brand-orange/10 border border-brand-orange/20 rounded text-[10px] font-bold text-brand-orange uppercase tracking-wider">Chi tiết Shipper</span>
        </div>
        <h2 class="text-4xl font-black text-white tracking-tighter">Lịch sử <span class="text-brand-orange">Đơn hàng</span></h2>
        <p class="text-brand-gray text-[10px] font-bold uppercase tracking-widest mt-1">Đang hiển thị toàn bộ <span class="text-white font-black">@Model.Count()</span> đơn hàng của <span class="text-brand-orange">@ViewBag.ShipperName</span></p>
    </div>

    <div class="flex items-center gap-4">
        <div class="relative group">
            <input type="text" id="tableSearch" placeholder="Tìm kiếm nhanh..." 
                   class="bg-white/5 border border-white/10 rounded-2xl px-6 py-3 text-xs font-bold text-white placeholder-brand-gray/50 focus:border-brand-orange/50 w-64 outline-none transition-all pl-12" />
            <i class="fa-solid fa-search absolute left-5 top-1/2 -translate-y-1/2 text-[12px] text-brand-gray group-focus-within:text-brand-orange"></i>
        </div>
    </div>
</div>

<div class="bg-brand-dark/50 backdrop-blur-xl rounded-[3rem] border border-white/5 overflow-hidden shadow-2xl fade-in" style="animation-delay: 0.2s">
    <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse" id="ordersTable">
            <thead>
                <tr class="bg-white/[0.02] text-[10px] font-extrabold text-brand-gray uppercase tracking-[2px]">
                    <th class="py-6 px-8">Mã đơn</th>
                    <th class="py-6 px-4">Nhà hàng & Khách</th>
                    <th class="py-6 px-4">Địa chỉ giao</th>
                    <th class="py-6 px-4 text-right">Tổng tiền</th>
                    <th class="py-6 px-4">Trạng thái</th>
                    <th class="py-6 px-4 text-center">Chi tiết</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-white/5">
                @foreach (var order in Model)
                {
                    <tr class="group hover:bg-white/[0.02] transition-all">
                        <td class="py-5 px-8">
                            <span class="text-brand-orange font-black text-xs tracking-wider">@order.OrderCode</span>
                            <p class="text-[9px] text-brand-gray font-bold uppercase mt-1">@order.CreatedAt.ToString("dd/MM/yyyy HH:mm")</p>
                        </td>
                        <td class="py-5 px-4">
                            <div class="space-y-1">
                                <p class="text-white text-xs font-black truncate max-w-[150px]">@order.Store?.Name</p>
                                <p class="text-brand-gray text-[10px] font-bold truncate max-w-[150px]">@order.User?.FullName</p>
                            </div>
                        </td>
                        <td class="py-5 px-4">
                            <p class="text-brand-gray text-xs font-bold truncate max-w-[250px]">@order.DeliveryAddress</p>
                        </td>
                        <td class="py-5 px-4 text-right font-black text-xs text-white">
                            @string.Format("{0:N0}", order.TotalPrice + order.ShippingFee) VND
                        </td>
                        <td class="py-5 px-4">
                            <span class="px-3 py-1.5 rounded-full text-[10px] font-black uppercase tracking-wider @GetStatusClass(order.Status)">
                                @GetStatusLabel(order.Status)
                            </span>
                        </td>
                        <td class="py-5 px-4 text-center">
                            <button onclick="viewOrderDetail(@order.Id)" class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center text-brand-gray hover:bg-brand-orange hover:text-black hover:border-brand-orange hover:shadow-[0_0_15px_rgba(255,107,0,0.3)] transition-all group/btn mx-auto">
                                <i class="fa-solid fa-eye text-sm"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@* Include the Modal and Logic from Orders *@
@await Html.PartialAsync("_OrderDetailModal")

@section Scripts {

<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<script>
    function viewOrderDetail(id) {
        const modal = document.getElementById('orderDetailModal');
        const body = document.getElementById('modalBody');
        const content = document.getElementById('modalContent');

        // Show loading state
        content.innerHTML = `
            <div class="flex flex-col items-center justify-center py-40 gap-4">
                <div class="w-12 h-12 border-4 border-brand-orange/20 border-t-brand-orange rounded-full animate-spin"></div>
                <p class="text-xs font-black text-brand-orange uppercase tracking-widest">Đang tải...</p>
            </div>
        `;
        
        modal.classList.remove('hidden');
        gsap.to(body, { duration: 0.5, scale: 1, opacity: 1, ease: "back.out(1.2)" });

        fetch(`/Admin/GetOrderDetailJson/${id}`)
            .then(res => res.json())
            .then(data => {
                renderOrderDetail(data);
            })
            .catch(err => {
                console.error("Error loading order detail:", err);
                content.innerHTML = `<p class="p-20 text-center text-red-500 font-bold uppercase tracking-widest">Lỗi khi tải thông tin đơn hàng</p>`;
            });
    }

    // Quick Search implementation
    document.getElementById('tableSearch').addEventListener('keyup', function() {
        let val = this.value.toLowerCase();
        let rows = document.querySelectorAll('#ordersTable tbody tr');
        rows.forEach(row => {
            row.style.display = row.innerText.toLowerCase().includes(val) ? '' : 'none';
        });
    });
</script>
}
