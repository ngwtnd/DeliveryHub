@model IEnumerable<DeliveryHubWeb.Models.Store>
@{
    var storesList = Model.OrderByDescending(s => s.IsMainBranch).ThenBy(s => s.Id).ToList();
    var mainStore = storesList.FirstOrDefault();
    var partnerCode = mainStore != null ? $"DT-{mainStore.Id:D3}" : "DT-000";
}

<div class="space-y-4 max-h-[60vh] overflow-y-auto custom-scrollbar pr-2">
    @for (int i = 0; i < storesList.Count; i++)
    {
        var store = storesList[i];
        var pendingIds = ViewBag.PendingStoreIds as List<string> ?? new List<string>();
        bool isPending = pendingIds.Contains(store.Id.ToString());
        bool isHighlighted = ViewBag.HighlightStoreId != null && store.Id == (int)ViewBag.HighlightStoreId;
        
        <div id="store-row-@store.Id" class="flex items-center justify-between p-4 bg-white/5 rounded-2xl border transition-all group/branch animate-slide-in @(isHighlighted ? "border-brand-orange ring-2 ring-brand-orange/50 shadow-[0_0_20px_rgba(255,126,0,0.2)] highlight-pulse" : "border-white/5 hover:border-brand-orange/30")">
            <div class="flex items-center gap-4">
                <div class="flex flex-col items-center gap-1.5 shrink-0">
                    <div class="w-16 h-12 rounded-xl overflow-hidden border border-white/10 shadow-lg">
                        @if (!string.IsNullOrEmpty(store.ImageUrl)) {
                            <img src="@store.ImageUrl" class="w-full h-full object-cover group-hover/branch:scale-110 transition-transform duration-500" alt="branch" />
                        } else {
                            <div class="w-full h-full bg-brand-dark flex items-center justify-center text-brand-orange">
                                <i class="fa-solid fa-store text-xl"></i>
                            </div>
                        }
                    </div>
                    <span class="text-[9px] font-bold text-brand-orange bg-brand-orange/10 px-2 py-0.5 rounded border border-brand-orange/20 whitespace-nowrap">
                        @($"{partnerCode}-CN{(i + 1):D3}")
                    </span>
                </div>
                <div>
                    @{
                        var stats = ViewBag.ReviewStats as Dictionary<int, (int Count, double Avg)>;
                        var count = stats != null && stats.ContainsKey(store.Id) ? stats[store.Id].Count : 0;
                        var avg = stats != null && stats.ContainsKey(store.Id) ? stats[store.Id].Avg : 0.0;
                        var width = avg * 20; // 5 sao = 100%
                    }
                    <h4 class="text-sm font-extrabold text-white">@store.Name</h4>
                    <p class="text-xs text-brand-gray mt-1 flex items-center gap-1.5">
                        <i class="fa-solid fa-location-dot text-[10px] text-brand-orange"></i>
                        @store.Address
                    </p>
                    <div class="flex items-center gap-3 mt-1.5">
                        <p class="text-[10px] font-bold text-brand-gray/60 uppercase tracking-widest flex items-center gap-1">
                            <i class="fa-regular fa-clock"></i> Đăng ký: @(new DateTime(2023, 1, 1).AddDays(store.Id * 15).ToString("dd/MM/yyyy"))
                        </p>
                        <div class="w-px h-3 bg-white/10"></div>
                        <div class="flex items-center gap-1.5">
                            <div class="relative inline-block text-brand-gray/30 text-[11px]" title="@avg.ToString("0.0") sao">
                                <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i>
                                <div class="absolute top-0 left-0 overflow-hidden text-yellow-400 whitespace-nowrap" style="width: @((int)width)%;">
                                    <i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i><i class="fa-solid fa-star"></i>
                                </div>
                            </div>
                            <span class="text-[10px] text-brand-gray/80 font-bold">(@count)</span>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="flex items-center gap-6">
                <!-- Status Column -->
                <div class="flex items-center gap-2 px-3 py-1.5 rounded-full w-fit @(isPending ? "bg-orange-500/10 text-orange-500 border border-orange-500/20" : (!store.IsOpen ? "bg-red-500/10 text-red-500 border border-red-500/20" : "bg-green-500/10 text-green-500 border border-green-500/20"))">
                    <span class="w-1.5 h-1.5 rounded-full @(isPending ? "bg-orange-500" : (!store.IsOpen ? "bg-red-500" : "bg-green-500"))"></span>
                    <span class="text-[10px] font-black uppercase tracking-tighter">@(isPending ? "Chờ phê duyệt" : (!store.IsOpen ? "Ngưng hoạt động" : "Đang hoạt động"))</span>
                </div>
                
                <div class="flex items-center gap-2">
                    <button onclick="window.location.href='/Admin/StoreDetail/@store.Id'" class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center hover:bg-brand-orange hover:text-black transition-all" title="Xem chi tiết chi nhánh">
                        <i class="fa-solid fa-eye text-xs"></i>
                    </button>
                    
                    @if (ViewBag.IsPartnerActive)
                    {
                        @if (isPending) {
                            <button onclick="handleApproveStore(@store.Id, '@store.Name')" class="w-8 h-8 rounded-lg bg-green-500/10 flex items-center justify-center hover:bg-green-500 hover:text-white transition-all border border-green-500/20" title="Phê duyệt chi nhánh">
                                <i class="fa-solid fa-check text-xs"></i>
                            </button>
                            <button onclick="handleRejectStore(@store.Id, '@store.Name')" class="w-8 h-8 rounded-lg bg-red-500/10 flex items-center justify-center hover:bg-red-500 hover:text-white transition-all border border-red-500/20" title="Từ chối chi nhánh">
                                <i class="fa-solid fa-times text-xs"></i>
                            </button>
                        } else if (store.ActivityState != DeliveryHubWeb.Models.StoreActivityState.Active) {
                            <button onclick="handleRestoreStore(@store.Id)" class="w-8 h-8 rounded-lg bg-red-500/10 flex items-center justify-center hover:bg-green-500 hover:text-white transition-all border border-red-500/20" title="Mở khóa chi nhánh">
                                <i class="fa-solid fa-lock-open text-xs text-red-500 group-hover:text-white"></i>
                            </button>
                        } else {
                            <button onclick="handleSuspendStore(@store.Id)" class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center hover:bg-red-500 hover:text-white transition-all" title="Đình chỉ chi nhánh">
                                <i class="fa-solid fa-triangle-exclamation text-xs text-red-500 group-hover:text-white"></i>
                            </button>
                        }
                    }
                </div>
            </div>
        </div>
    }
</div>

<style>
    .animate-slide-in { animation: branchSlideIn 0.4s ease-out forwards; opacity: 0; }
    @@keyframes branchSlideIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
    @for (int i = 0; i < Model.Count(); i++) {
        <text>.animate-slide-in:nth-child(@(i + 1)) { animation-delay: @(i * 0.1)s; }</text>
    }
    
    .highlight-pulse {
        animation: highlightPulse 2s infinite;
    }
    
    @@keyframes highlightPulse {
        0% { border-color: rgba(255, 126, 0, 0.3); box-shadow: 0 0 0 0 rgba(255, 126, 0, 0.4); }
        50% { border-color: rgba(255, 126, 0, 1); box-shadow: 0 0 20px 0 rgba(255, 126, 0, 0.4); }
        100% { border-color: rgba(255, 126, 0, 0.3); box-shadow: 0 0 0 0 rgba(255, 126, 0, 0.1); }
    }
</style>
