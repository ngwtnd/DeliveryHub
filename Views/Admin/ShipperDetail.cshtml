@model DeliveryHubWeb.Models.ShipperDetailViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Chi tiết Shipper";

    string GetStatusBadge(string status) => status switch {
        "Completed" => "bg-green-500/10 text-green-500 border border-green-500/20|Thành công",
        "Delivering" => "bg-brand-orange/10 text-brand-orange border border-brand-orange/20|Đang giao",
        "Failed" or "Cancelled" => "bg-red-500/10 text-red-500 border border-red-500/20|Thất bại",
        "SearchingShipper" or "Accepted" => "bg-pink-500/10 text-pink-500 border border-pink-500/20|Đang tìm",
        _ => "bg-yellow-500/10 text-yellow-500 border border-yellow-500/20|Chờ xử lý"
    };
}

<div class="mb-8 mt-4 flex items-center justify-between">
    <div class="flex items-center gap-4">
        <a href="javascript:history.back()" class="w-10 h-10 rounded-xl bg-white/5 border border-white/5 flex items-center justify-center hover:bg-brand-orange hover:text-black transition-all text-brand-gray group">
            <i class="fa-solid fa-arrow-left text-xs group-hover:-translate-x-0.5 transition-transform"></i>
        </a>
        <h2 class="text-3xl font-black text-white tracking-tighter">Chi tiết <span class="text-brand-orange">Shipper</span></h2>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 pb-12">
    <!-- Profile Card (1/3) -->
    <div class="lg:col-span-1 space-y-6">
        <div class="bg-brand-dark/50 backdrop-blur-xl rounded-[3rem] border border-white/5 p-10 flex flex-col items-center text-center shadow-2xl relative overflow-hidden group">
            <!-- Background Decoration -->
            <div class="absolute -top-24 -right-24 w-48 h-48 bg-brand-orange/10 blur-[80px] rounded-full group-hover:bg-brand-orange/20 transition-all duration-700"></div>
            
            <div class="relative mb-6">
                <div class="w-28 h-28 rounded-[2.5rem] p-1 bg-gradient-to-tr from-brand-orange to-orange-400">
                    <img src="@Model.AvatarUrl" alt="@Model.FullName" class="w-full h-full object-cover rounded-[2.2rem]" />
                </div>
                <div class="absolute -bottom-2 -right-2 w-8 h-8 rounded-xl bg-green-500 border-4 border-brand-dark flex items-center justify-center shadow-lg">
                    <i class="fa-solid fa-check text-[10px] text-white"></i>
                </div>
            </div>

            <h3 class="text-2xl font-black text-white mb-1">@Model.FullName</h3>
            <p class="text-brand-orange font-bold text-[10px] uppercase tracking-[0.2em] mb-4">@Model.ShipperCode</p>

            <div class="flex items-center gap-1 mb-6">
                @for (int i = 1; i <= 5; i++) {
                    <i class="fa-solid fa-star @(i <= Math.Floor(Model.AvgRating) ? "text-brand-orange" : (i <= Model.AvgRating ? "text-brand-orange/50" : "text-white/10")) text-xs"></i>
                }
                <span class="text-xs font-black text-white ml-2">@Model.AvgRating.ToString("F1")</span>
                <span class="text-[10px] font-bold text-brand-gray ml-1">(@Model.TotalReviews đánh giá)</span>
            </div>

            <div class="w-full space-y-4 pt-8 border-t border-white/5 text-left">
                <div class="flex items-center gap-4">
                    <div class="w-9 h-9 rounded-2xl bg-white/5 flex items-center justify-center text-brand-gray shadow-inner">
                        <i class="fa-solid fa-route text-xs"></i>
                    </div>
                    <div>
                        <p class="text-[9px] text-brand-gray font-black uppercase tracking-widest opacity-60">Đã chạy</p>
                        <p class="text-[13px] font-bold text-white tracking-tight">@Model.TotalDistance.ToString("N1") km</p>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <div class="w-9 h-9 rounded-2xl bg-white/5 flex items-center justify-center text-brand-gray shadow-inner">
                        <i class="fa-solid fa-envelope text-xs"></i>
                    </div>
                    <div>
                        <p class="text-[9px] text-brand-gray font-black uppercase tracking-widest opacity-60">Email</p>
                        <p class="text-[13px] font-bold text-white tracking-tight">@Model.Email</p>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <div class="w-9 h-9 rounded-2xl bg-white/5 flex items-center justify-center text-brand-gray shadow-inner">
                        <i class="fa-solid fa-id-card text-xs"></i>
                    </div>
                    <div>
                        <p class="text-[9px] text-brand-gray font-black uppercase tracking-widest opacity-60">CCCD (12 số)</p>
                        <p class="text-[13px] font-bold text-white tracking-tight">@Model.CitizenId</p>
                    </div>
                </div>
                <div class="flex items-center gap-4">
                    <div class="w-9 h-9 rounded-2xl bg-white/5 flex items-center justify-center text-brand-gray shadow-inner">
                        <i class="fa-solid fa-calendar-check text-xs"></i>
                    </div>
                    <div>
                        <p class="text-[9px] text-brand-gray font-black uppercase tracking-widest opacity-60">Ngày đăng ký</p>
                        <p class="text-[13px] font-bold text-white tracking-tight">@Model.CreatedAt.ToString("dd/MM/yyyy")</p>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-2 gap-4 w-full mt-10">
                <div class="bg-white/5 p-5 rounded-[2rem] border border-white/5 text-center shadow-inner group/stat hover:bg-white/10 transition-all cursor-default">
                    <p class="text-[9px] text-brand-gray font-black uppercase mb-1 opacity-50 tracking-widest hidden sm:block">Đã giao thành công</p>
                    <p class="text-[10px] text-brand-gray font-black uppercase mb-1 opacity-50 sm:hidden">Đã giao</p>
                    <p class="text-2xl font-black text-white group-hover/stat:scale-110 transition-transform">@Model.TotalOrders</p>
                </div>
                <div class="bg-white/5 p-5 rounded-[2rem] border border-white/5 text-center shadow-inner group/stat hover:bg-white/10 transition-all cursor-default">
                    <p class="text-[10px] text-brand-gray font-black uppercase mb-1 opacity-50">Thu nhập</p>
                    <p class="text-2xl font-black text-brand-orange group-hover/stat:scale-110 transition-transform">@Model.TotalIncome.ToString("N0")<span class="text-[10px] ml-1 font-bold text-white opacity-60">VND</span></p>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Orders (2/3) -->
    <div class="lg:col-span-2">
        <div class="bg-brand-dark/50 backdrop-blur-xl rounded-[3rem] border border-white/5 overflow-hidden shadow-2xl flex flex-col h-full">
            <div class="p-10 border-b border-white/5 flex justify-between items-center">
                <div class="space-y-1">
                    <p class="text-xs font-black text-white uppercase tracking-[0.3em]">Các đơn hàng gần nhất</p>
                </div>
                <a href="/Admin/ShipperOrders/@Model.Id" class="px-6 py-2.5 rounded-xl bg-white/5 border border-white/10 text-[10px] font-black text-brand-orange uppercase tracking-widest hover:bg-brand-orange hover:text-black transition-all">Xem toàn bộ</a>
            </div>

            <div class="flex-1 overflow-x-auto custom-scrollbar">
                <table class="w-full text-left">
                    <thead>
                        <tr class="bg-white/[0.02] text-[10px] font-black text-brand-gray uppercase tracking-[0.2em] border-b border-white/5">
                            <th class="py-6 px-10">Mã đơn</th>
                            <th class="py-6 px-4">Điểm giao</th>
                            <th class="py-6 px-4 text-right">Giá tiền</th>
                            <th class="py-6 px-4 text-center">Trạng thái</th>
                            <th class="py-6 px-4 text-center">Chi tiết</th>
                            <th class="py-6 px-10 text-right">Thời gian</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white/5">
                        @foreach (var order in Model.RecentOrders) {
                            <tr class="group hover:bg-white/[0.03] transition-all relative">
                                <td class="py-6 px-10 relative">
                                    <div class="absolute inset-y-4 left-0 w-1 bg-brand-orange scale-y-0 group-hover:scale-y-100 transition-transform rounded-r-full"></div>
                                    <span class="text-[11px] font-black text-brand-orange tracking-tight">#@order.OrderCode</span>
                                </td>
                                <td class="py-6 px-4">
                                    <p class="text-xs font-bold text-white max-w-[220px] truncate leading-relaxed">@order.DeliveryAddress</p>
                                </td>
                                <td class="py-6 px-4 text-right">
                                    <span class="text-[11px] font-black text-white">@order.ShippingFee.ToString("N0") <span class="text-[10px] opacity-40 ml-0.5">VND</span></span>
                                </td>
                                <td class="py-6 px-4">
                                    <div class="flex justify-center">
                                        <div class="px-3 py-1.5 rounded-xl text-[9px] font-black uppercase tracking-tighter @(GetStatusBadge(order.Status).Split('|')[0])">
                                            @(GetStatusBadge(order.Status).Split('|')[1])
                                        </div>
                                    </div>
                                </td>
                                <td class="py-6 px-4 text-center">
                                    <button onclick="showOrderDetail(@order.Id)" class="w-10 h-10 rounded-xl bg-white/5 border border-white/5 flex items-center justify-center text-brand-gray hover:bg-brand-orange hover:text-black hover:border-brand-orange transition-all group/btn mx-auto">
                                        <i class="fa-solid fa-eye text-sm"></i>
                                    </button>
                                </td>
                                <td class="py-6 px-10 text-right">
                                    <span class="text-[11px] font-bold text-brand-gray tracking-tight group-hover:text-white transition-colors">@order.Time</span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
                @if (!Model.RecentOrders.Any()) {
                    <div class="flex flex-col items-center justify-center p-24 text-center space-y-4">
                        <div class="w-20 h-20 rounded-[2rem] bg-white/5 flex items-center justify-center text-brand-gray opacity-20 shadow-inner">
                            <i class="fa-solid fa-box-open text-3xl"></i>
                        </div>
                        <div class="space-y-1">
                            <p class="text-xs font-black text-brand-gray uppercase tracking-[0.2em]">Danh sách trống</p>
                            <p class="text-[10px] text-brand-gray/50 font-bold uppercase tracking-widest">Shipper này chưa thực hiện đơn hàng nào</p>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-12">
    <!-- Revenue Growth -->
    <div class="lg:col-span-2 bg-brand-dark/50 backdrop-blur-xl p-8 rounded-[3rem] border border-white/5 overflow-hidden shadow-2xl fade-in" style="animation-delay: 0.5s">
        <div class="flex justify-between items-center mb-6">
            <h4 class="text-xl flex items-center gap-3">
                <i class="fa-solid fa-chart-line text-brand-orange"></i>
                <span class="font-black text-white tracking-tighter">Thống kê <span class="text-brand-orange">Hoạt động</span></span>
            </h4>
            <select id="chartFilterDropdown" class="bg-[#1e293b] border border-white/10 rounded-xl px-5 py-2.5 text-xs font-bold text-white focus:border-brand-orange focus:ring-1 focus:ring-brand-orange outline-none transition-all cursor-pointer">
                <option value="7" selected>7 ngày qua</option>
                <option value="30">30 ngày qua</option>
                <option value="0">Toàn thời gian</option>
            </select>
        </div>
        <div class="h-[300px] w-full">
            <canvas id="shipperActivityChart"></canvas>
        </div>
    </div>

    <!-- Order Status Pie -->
    <div class="bg-brand-dark/50 backdrop-blur-xl p-8 rounded-[3rem] border border-white/5 overflow-hidden shadow-2xl fade-in" style="animation-delay: 0.6s">
        <h4 class="text-xl flex items-center gap-3 mb-8">
            <i class="fa-solid fa-chart-pie text-brand-orange"></i>
            <span class="font-black text-white tracking-tighter">Trạng thái <span class="text-brand-orange">đơn hàng</span></span>
        </h4>
        <div class="relative h-[250px] w-full flex justify-center items-center">
            <canvas id="statusChart"></canvas>
        </div>
        <div class="mt-8 space-y-3" id="status-legend">
            <!-- Render via JS -->
        </div>
    </div>
</div>

@functions {
    string GetStatusBadge(string status) {
        return status switch {
            "Completed" => "bg-green-500/10 text-green-500 border border-green-500/20|Thành công",
            "Failed" => "bg-red-500/10 text-red-500 border border-red-500/20|Thất bại",
            "Delivering" => "bg-brand-orange/10 text-brand-orange border border-brand-orange/20|Đang giao",
            "Cancelled" => "bg-blue-500/10 text-blue-500 border border-blue-500/20|Đã hủy",
            "SearchingShipper" or "Accepted" => "bg-pink-500/10 text-pink-500 border border-pink-500/20|Chờ vận chuyển",
            "Pending" or "Preparing" => "bg-yellow-500/10 text-yellow-500 border border-yellow-500/20|Nhận đơn",
            _ => "bg-brand-gray/10 text-brand-gray border border-brand-gray/20|Không rõ"
        };
    }
}

<style>
    .custom-scrollbar::-webkit-scrollbar { width: 5px; height: 5px; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: rgba(255,107,0,0.2); border-radius: 10px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
</style>


@await Html.PartialAsync("_OrderDetailModal")

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
<script>
    function showOrderDetail(id) {
        // Show loading
        const modal = document.getElementById('orderDetailModal');
        const body = document.getElementById('modalBody');
        const content = document.getElementById('modalContent');
        
        content.innerHTML = `
            <div class="flex flex-col items-center justify-center py-40 gap-4">
                <div class="w-12 h-12 border-4 border-brand-orange/20 border-t-brand-orange rounded-full animate-spin"></div>
                <p class="text-xs font-black text-brand-orange uppercase tracking-widest">Đang tải...</p>
            </div>
        `;
        
        modal.classList.remove('hidden');
        gsap.to(body, { duration: 0.5, scale: 1, opacity: 1, ease: "back.out(1.2)" });

        fetch(`/Admin/GetOrderDetailJson/${id}`)
            .then(res => res.json())
            .then(data => {
                renderOrderDetail(data);
            })
            .catch(err => {
                console.error("Error loading order detail:", err);
                content.innerHTML = `<p class="p-20 text-center text-red-500 font-bold uppercase tracking-widest">Lỗi khi tải thông tin đơn hàng</p>`;
            });
    }

    // Modal cleanup: highlightSteps, resetTimeline, and closeModal are now in _OrderDetailModal.cshtml

    // Dynamic Chart Logic
    const allOrders = @Html.Raw(ViewBag.AllOrders ?? "[]");
    let lineChartObj = null;
    let pieChartObj = null;

    const colorsMap = {
        'Completed': '#22c55e', 
        'Delivering': '#f97316', 
        'Failed': '#ef4444', 
        'Cancelled': '#ef4444', 
        'Accepted': '#ec4899', 
        'SearchingShipper': '#ec4899', 
        'Pending': '#f59e0b',
        'Preparing': '#f59e0b',
    };

    const statusLabels = {
        'Completed': 'Thành công',
        'Delivering': 'Đang giao',
        'Failed': 'Thất bại',
        'Cancelled': 'Thất bại',
        'Accepted': 'Chờ vận chuyển',
        'SearchingShipper': 'Chờ vận chuyển',
        'Pending': 'Đang chuẩn bị',
        'Preparing': 'Đang chuẩn bị',
    };

    function renderCharts(daysFilter) {
        const now = new Date();
        const filteredOrders = daysFilter == 0 ? allOrders : allOrders.filter(o => {
            const diffTime = Math.abs(now - new Date(o.CreatedAt));
            const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24)); 
            return diffDays <= daysFilter;
        });

        // 1. Process Doughnut Chart Data
        const counts = {};
        filteredOrders.forEach(o => {
            const labelStr = statusLabels[o.Status] || o.Status;
            counts[labelStr] = (counts[labelStr] || 0) + 1;
        });

        const statusStats = Object.keys(counts).map(k => ({ Status: k, Count: counts[k] })).sort((a,b) => b.Count - a.Count);

        const ctxStatus = document.getElementById('statusChart');
        if (ctxStatus) {
            if (pieChartObj) pieChartObj.destroy();
            
            // Generate colors safely
            const getKeyByValue = (obj, val) => Object.keys(obj).find(key => obj[key] === val);
            const pieColors = statusStats.map(s => {
                let origKey = getKeyByValue(statusLabels, s.Status) || s.Status;
                return colorsMap[origKey] || '#94a3b8';
            });

            pieChartObj = new Chart(ctxStatus.getContext('2d'), {
                type: 'doughnut',
                data: {
                    labels: statusStats.map(d => d.Status),
                    datasets: [{
                        data: statusStats.map(d => d.Count),
                        backgroundColor: pieColors,
                        borderColor: '#0f172a',
                        borderWidth: 5,
                        cutout: '75%'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } }
                }
            });

            const legendContainer = document.getElementById('status-legend');
            legendContainer.innerHTML = '';
            statusStats.forEach((stat, i) => {
                const item = document.createElement('div');
                item.className = 'flex items-center justify-between';
                item.innerHTML = `
                    <div class="flex items-center gap-2">
                        <span class="w-2.5 h-2.5 rounded-full" style="background-color: ${pieColors[i]}"></span>
                        <span class="text-xs font-bold text-brand-gray uppercase tracking-wider">${stat.Status}</span>
                    </div>
                    <span class="text-xs font-bold">${stat.Count}</span>
                `;
                legendContainer.appendChild(item);
            });
        }

        // 2. Process Line Chart Data
        const lineLimit = daysFilter == 0 ? 30 : daysFilter;
        const lineDates = [];
        let cur = new Date();
        for (let i = lineLimit - 1; i >= 0; i--) {
            let d = new Date(cur);
            d.setDate(d.getDate() - i);
            
            // Build YYYY-MM-DD strictly from local time getter methods to avoid UTC shifts
            const yyyy = d.getFullYear();
            const mm = ('0' + (d.getMonth() + 1)).slice(-2);
            const dd = ('0' + d.getDate()).slice(-2);
            
            lineDates.push({
                rawObj: d,
                iso: `${yyyy}-${mm}-${dd}`,
                display: `${dd}/${mm}`
            });
        }

        const dateMap = {};
        lineDates.forEach(d => {
            dateMap[d.iso] = { Accepted: 0, Delivering: 0, Completed: 0, Failed: 0 };
        });

        filteredOrders.forEach(o => {
            if (dateMap[o.CreatedAt]) {
                dateMap[o.CreatedAt][o.NormalizedStatus] += 1;
            }
        });

        const ctxAct = document.getElementById('shipperActivityChart');
        if (ctxAct) {
            if (lineChartObj) lineChartObj.destroy();
            lineChartObj = new Chart(ctxAct.getContext('2d'), {
                type: 'line',
                data: {
                    labels: lineDates.map(d => d.display),
                    datasets: [
                        { label: 'Chờ vận chuyển', data: lineDates.map(d => dateMap[d.iso].Accepted), borderColor: '#ec4899', backgroundColor: 'transparent', borderWidth: 2, tension: 0.4 },
                        { label: 'Đang giao', data: lineDates.map(d => dateMap[d.iso].Delivering), borderColor: '#f97316', backgroundColor: 'transparent', borderWidth: 2, tension: 0.4 },
                        { label: 'Thất bại', data: lineDates.map(d => dateMap[d.iso].Failed), borderColor: '#ef4444', backgroundColor: 'transparent', borderWidth: 2, borderDash: [5, 5], tension: 0.4 },
                        { label: 'Thành công', data: lineDates.map(d => dateMap[d.iso].Completed), borderColor: '#22c55e', backgroundColor: 'transparent', borderWidth: 2, borderDash: [5, 5], tension: 0.4 }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    interaction: { mode: 'index', intersect: false },
                    plugins: { legend: { display: true, position: 'top', align: 'end', labels: { color: '#94a3b8', font: { size: 10, weight: 'bold' }, boxWidth: 12, usePointStyle: true } } },
                    scales: {
                        x: { grid: { display: false }, ticks: { color: '#94a3b8', font: { size: 10, weight: 'bold' } } },
                        y: { beginAtZero: true, grid: { color: 'rgba(255,255,255,0.05)', borderDash: [5, 5] }, ticks: { color: '#ffffff', font: { size: 10 }, stepSize: 1 } }
                    }
                }
            });
        }
    }

    const dropdown = document.getElementById('chartFilterDropdown');
    dropdown.addEventListener('change', (e) => {
        renderCharts(parseInt(e.target.value));
    });
    
    // Initial Render
    renderCharts(parseInt(dropdown.value));
</script>
}
